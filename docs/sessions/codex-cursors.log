diff --git a/src/Runtime/UI/TcCursorApplicator.cs b/src/Runtime/UI/TcCursorApplicator.cs
new file mode 100644
index 0000000000000000000000000000000000000000..73563eedce0d4e64d706214008ed6cd7edf9ae33
