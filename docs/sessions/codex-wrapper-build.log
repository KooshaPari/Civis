+                            connection_error: conn,
+                            stdin_hang: false,
+                            output_delta: job.last_output_offset.saturating_sub(stdout_offset),
+                        };
+                    }
+                    Ok(None) => {
+                        if timed_out && last_output.elapsed() >= Duration::from_secs(hang_seconds) {
+                            let _ = child.kill();
+                            return Attempt {
+                                success: false,
+                                exit_code: None,
+                                error: Some("Reading additional input from stdin (hang timeout)".to_string()),
+                                capacity_error: false,
+                                connection_error: false,
+                                stdin_hang: true,
+                                output_delta: job.last_output_offset.saturating_sub(stdout_offset),
+                            };
+                        }
+                        now = Instant::now();
+                        continue;
+                    }
+                    Err(err) => {
+                        let _ = child.kill();
+                        return Attempt {
+                            success: false,
+                            exit_code: None,
+                            error: Some(format!("process monitor failed: {err}")),
+                            capacity_error: false,
+                            connection_error: is_connection_error(&err.to_string()),
+                            stdin_hang: false,
+                            output_delta: job.last_output_offset.saturating_sub(stdout_offset),
+                        };
+                    }
+                }
+            }
+        }
+    }
+}
