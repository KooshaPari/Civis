using UnityEditor;
using UnityEngine;
public static class TmpEssentialsImport
{
    // Pass 1: import TMP essentials so the SDF shader asset lands on disk + compiles.
    public static void Run()
    {
        try {
            var t = System.Type.GetType("TMPro.TMP_PackageResourceImporter, Unity.TextMeshPro.Editor")
                 ?? System.Type.GetType("TMPro.TMP_PackageResourceImporter, Unity.TextMeshPro");
            if (t != null) {
                var m = t.GetMethod("ImportResources", System.Reflection.BindingFlags.Public|System.Reflection.BindingFlags.Static);
                if (m != null) m.Invoke(null, new object[]{ true, false, false });
            }
            AssetDatabase.Refresh(ImportAssetOptions.ForceSynchronousImport);
            AssetDatabase.SaveAssets();
            Debug.Log("[TmpEssentialsImport] essentials imported pass-1");
            EditorApplication.Exit(0);
        } catch (System.Exception e) { Debug.LogError("[TmpEssentialsImport] "+e); EditorApplication.Exit(1); }
    }
}

