{
  "version": "1.0",
  "coverage": {
    "min": 80,
    "branch": true,
    "fail_under": 80
  },
  "complexity": {
    "max_cyclomatic": 10,
    "max_cognitive": 15,
    "min_maintainability_index": 20,
    "max_function_lines": 40,
    "max_duplication_pct": 5,
    "ratchet_enabled": true,
    "baseline_file": ".complexity-baseline.json",
    "tools": {
      "python": "radon",
      "go": "gocyclo",
      "typescript": "eslint",
      "shell": "shellcheck"
    }
  },
  "mutation_score": {
    "min": 60
  },
  "suppression_patterns": [
    "# credo:disable",
    "# noqa",
    "# nosec",
    "# pragma: no cover",
    "# rubocop:disable",
    "# tfsec:ignore",
    "# type: ignore",
    "#[allow(",
    "#[cfg_attr(",
    "-- luacheck: ignore",
    "-- noqa",
    "/* eslint-disable",
    "/* stylelint-disable",
    "// @phpstan-ignore",
    "// eslint-disable",
    "// ignore:",
    "// ignore_for_file:",
    "// nosemgrep",
    "// phpcs:disable",
    "// swiftlint:disable",
    "//nolint",
    "<!-- markdownlint-disable",
    "@Suppress(",
    "@SuppressWarnings",
    "@ts-expect-error",
    "@ts-ignore",
    "{- HLINT ignore"
  ],
  "traceability": {
    "require_fr_tags": true,
    "orphan_check": true,
    "tag_patterns": [
      "@trace FR-[A-Z]+-[0-9]+",
      "@pytest.mark.requirement",
      "@fr:",
      "FR-[A-Z]+-[0-9]+"
    ]
  },
  "secret_patterns": [
    "(?i)(api[_-]?key|apikey)\\s*[:=]\\s*['\"][^'\"]{8,}",
    "(?i)(secret|password|passwd|pwd)\\s*[:=]\\s*['\"][^'\"]{8,}",
    "(?i)(token|bearer)\\s*[:=]\\s*['\"][^'\"]{8,}",
    "(?i)(aws_access_key_id|aws_secret_access_key)\\s*[:=]\\s*['\"][^'\"]{16,}",
    "(?i)private[_-]?key\\s*[:=]\\s*['\"][^'\"]{8,}",
    "-----BEGIN (RSA |EC |DSA )?PRIVATE KEY-----",
    "ghp_[a-zA-Z0-9]{36}",
    "sk-[a-zA-Z0-9]{20,}"
  ],
  "stacks": {
    "python": {
      "lint": "ruff check --no-fix",
      "format": "ruff format --check",
      "typecheck": "ty check",
      "test": "pytest",
      "security": "bandit -r"
    },
    "typescript": {
      "lint": "oxlint",
      "typecheck": "tsc --noEmit",
      "test": "vitest run",
      "format": "prettier --check"
    },
    "go": {
      "lint": "golangci-lint run",
      "test": "go test ./...",
      "vet": "go vet ./..."
    },
    "rust": {
      "lint": "cargo clippy -- -D warnings",
      "test": "cargo test",
      "format": "cargo fmt --check"
    },
    "shell": {
      "lint": "shellcheck",
      "test": "bats",
      "syntax": "bash -n"
    },
    "c_cpp": {
      "lint": "clang-tidy",
      "format": "clang-format --dry-run --Werror",
      "security": "cppcheck --enable=all --error-exitcode=1",
      "test": "ctest",
      "syntax": "gcc -fsyntax-only"
    },
    "java": {
      "lint": "checkstyle -c /google_checks.xml",
      "format": "google-java-format --dry-run --set-exit-if-changed",
      "security": "spotbugs",
      "test": "mvn test"
    },
    "kotlin": {
      "lint": "detekt --build-upon-default-config",
      "format": "ktlint --reporter=plain",
      "test": "gradle test"
    },
    "swift": {
      "lint": "swiftlint lint --strict",
      "format": "swiftformat --lint",
      "test": "swift test"
    },
    "ruby": {
      "lint": "rubocop --format simple",
      "format": "rubocop -a --format simple",
      "security": "brakeman -q",
      "test": "rspec"
    },
    "php": {
      "lint": "phpstan analyse --level=max",
      "format": "php-cs-fixer fix --dry-run --diff",
      "security": "psalm --taint-analysis",
      "test": "phpunit",
      "syntax": "php -l"
    },
    "dart": {
      "lint": "dart analyze --fatal-infos",
      "format": "dart format --set-exit-if-changed",
      "test": "dart test"
    },
    "scala": {
      "lint": "scalafmt --check",
      "test": "sbt test"
    },
    "lua": {
      "lint": "luacheck",
      "syntax": "luac -p"
    },
    "perl": {
      "lint": "perlcritic --harsh",
      "syntax": "perl -c"
    },
    "zig": {
      "lint": "zig build",
      "test": "zig build test"
    },
    "haskell": {
      "lint": "hlint",
      "typecheck": "ghc -fno-code",
      "test": "cabal test"
    },
    "elixir": {
      "lint": "mix credo --strict",
      "format": "mix format --check-formatted",
      "security": "mix sobelow",
      "test": "mix test"
    },
    "r": {
      "lint": "Rscript -e 'lintr::lint_dir()'",
      "test": "Rscript -e 'testthat::test_dir(\"tests\")'"
    },
    "sql": {
      "lint": "sqlfluff lint",
      "format": "sqlfluff fix --check"
    },
    "markdown": {
      "lint": "markdownlint-cli2",
      "prose": "vale"
    },
    "html": {
      "lint": "htmlhint",
      "accessibility": "pa11y"
    },
    "css_scss": {
      "lint": "stylelint"
    },
    "xml": {
      "lint": "xmllint --noout",
      "syntax": "xmllint --noout"
    },
    "dockerfile": {
      "lint": "hadolint"
    },
    "terraform": {
      "lint": "tflint",
      "security": "tfsec",
      "format": "terraform fmt -check"
    },
    "protobuf": {
      "lint": "buf lint",
      "format": "buf format --diff --exit-code"
    },
    "graphql": {
      "lint": "graphql-schema-linter"
    },
    "latex": {
      "lint": "chktex",
      "syntax": "lacheck"
    }
  },
  "pyramid": {
    "unit": 70,
    "integration": 20,
    "e2e": 10,
    "tolerance": 5
  },
  "methodology": {
    "test_first": true,
    "bdd": {
      "require_feature_files": false,
      "gherkin_lint": true
    },
    "tdd": {
      "test_before_implementation": true,
      "red_green_refactor": true
    },
    "test_types_required": {
      "unit": true,
      "integration": true,
      "e2e": false,
      "property_based": false,
      "contract": false,
      "mutation": false,
      "snapshot": false,
      "accessibility": false,
      "security": true,
      "fuzz": false,
      "approval": false
    },
    "mutation_testing": {
      "tool": "mutmut",
      "min_score": 60,
      "enabled": false
    },
    "property_testing": {
      "python": "hypothesis",
      "typescript": "fast-check",
      "enabled": false
    },
    "architecture_enforcement": {
      "python": [
        "tach",
        "import-linter"
      ],
      "go": "depguard",
      "typescript": "eslint-plugin-boundaries",
      "enabled": false
    }
  },
  "specification_verification": {
    "enabled": true,
    "fr_file": "FUNCTIONAL_REQUIREMENTS.md",
    "fr_pattern": "FR-[A-Z]+-[0-9]+",
    "test_trace_patterns": [
      "@trace FR-[A-Z]+-[0-9]+",
      "@pytest.mark.requirement",
      "@test \"FR-[A-Z]+-[0-9]+",
      "// @fr: FR-[A-Z]+-[0-9]+",
      "describe.*FR-[A-Z]+-[0-9]+"
    ],
    "require_100_percent": false,
    "warn_threshold": 80,
    "orphan_test_check": true
  },
  "security_pipeline": {
    "layers": [
      "secrets",
      "sast",
      "dependencies",
      "infrastructure",
      "supply_chain"
    ],
    "tools": {
      "secrets": [
        "gitleaks",
        "regex"
      ],
      "sast": [
        "semgrep",
        "bandit",
        "gosec",
        "brakeman",
        "psalm"
      ],
      "dependencies": [
        "pip-audit",
        "npm-audit",
        "govulncheck",
        "cargo-audit",
        "bundle-audit",
        "osv-scanner"
      ],
      "infrastructure": [
        "tfsec",
        "hadolint",
        "trivy"
      ],
      "supply_chain": ["syft", "osv-scanner", "opengrep"]
    },
    "semgrep_config": "auto",
    "custom_rules": "~/.claude/templates/quality/semgrep-rules.yaml",
    "fail_on_high": true,
    "warn_on_medium": true
  },
  "test_maturity": {
    "enabled": true,
    "levels": {
      "1_mvp": {
        "min_score": 0,
        "requirements": [
          "tests_exist",
          "runnable"
        ]
      },
      "2_production": {
        "min_score": 21,
        "requirements": [
          "coverage_60",
          "integration",
          "ci",
          "no_suppressions"
        ]
      },
      "3_scale": {
        "min_score": 41,
        "requirements": [
          "coverage_80",
          "pyramid",
          "fr_trace_50",
          "sast",
          "strict_lint"
        ]
      },
      "4_high_reliability": {
        "min_score": 61,
        "requirements": [
          "fr_trace_80",
          "property_tests",
          "contract_tests",
          "arch_enforcement",
          "complexity_ratchet",
          "snapshot_tests",
          "approval_tests"
        ]
      },
      "5_mission_critical": {
        "min_score": 81,
        "requirements": [
          "fr_trace_100",
          "mutation_60",
          "chaos_tests",
          "runtime_verification",
          "zero_suppressions",
          "spec_verified",
          "fuzz_tests",
          "chaos_resilience"
        ]
      }
    },
    "target_level": 3,
    "test_type_config": {
      "snapshot_tests": {
        "enabled": true,
        "tools": {
          "javascript": "jest-snapshots",
          "typescript": "jest-snapshots",
          "python": "syrupy",
          "rust": "insta",
          "go": "cupaloy"
        },
        "detection_patterns": ["toMatchSnapshot", "syrupy", "__snapshots__", "insta::assert_snapshot", "cupaloy"]
      },
      "approval_tests": {
        "enabled": true,
        "tools": {
          "python": "approvaltests",
          "javascript": "approvaltests",
          "go": "approvals"
        },
        "detection_patterns": ["approvaltests", "verify(", "approvals.VerifyString"]
      },
      "fuzz_tests": {
        "enabled": true,
        "tools": {
          "python": "atheris",
          "go": "native",
          "rust": "cargo-fuzz",
          "c": "AFL"
        },
        "detection_patterns": ["atheris", "func Fuzz", "cargo-fuzz", "AFL_", "libFuzzer"]
      },
      "chaos_resilience": {
        "enabled": true,
        "tools": {
          "generic": "chaos-toolkit",
          "network": "toxiproxy",
          "kubernetes": "litmus"
        },
        "detection_patterns": ["chaos-toolkit", "toxiproxy", "litmus", "chaoskube", "fault_injection"]
      }
    }
  },
  "dead_code": {
    "enabled": true,
    "tools": {
      "python": "vulture",
      "javascript": "knip",
      "typescript": "knip"
    },
    "vulture_min_confidence": 80,
    "knip_config": "--no-progress"
  },
  "duplication": {
    "enabled": true,
    "tool": "jscpd",
    "min_lines": 5,
    "min_tokens": 50,
    "max_percentage": 5,
    "ignore_patterns": ["**/node_modules/**", "**/__pycache__/**", "**/vendor/**", "**/.shadow-*/**", "**/.git-cache/**", "**/.worktrees/**", "**/.venv/**", "**/.venv-*/**", "**/target/**", "**/dist/**", "**/build/**", "**/*.lock", "**/*.min.js"]
  },
  "sbom": {
    "enabled": true,
    "tool": "syft",
    "format": "cyclonedx-json",
    "output_dir": "/tmp"
  },
  "slop_detection": {
    "enabled": true,
    "patterns": [
      "TODO:\\s*(implement|add|fix|replace)",
      "Lorem ipsum",
      "example\\.com",
      "your-.*-here|replace-with|CHANGEME",
      "As an AI|I cannot|I apologize",
      "pass\\s+#\\s*(placeholder|TODO)",
      "throw new Error\\(.*(not implemented|todo)",
      "panic\\(.*(not implemented|todo|unimplemented)"
    ],
    "exclude_paths": ["test/fixtures/", "__fixtures__/", "testdata/"]
  },
  "runtime_verification": {
    "python": {
      "type_checking": "beartype",
      "contracts": "deal",
      "enabled": false
    },
    "go": {
      "goroutine_leak": "goleak",
      "race_detector": true,
      "enabled": false
    },
    "resilience": {
      "tool": "toxiproxy",
      "chaos": "chaos-toolkit",
      "enabled": false
    }
  }
}
