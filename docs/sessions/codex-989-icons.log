2415	        /// <summary>Populates the per-pack settings section with runtime configuration controls.</summary>
2416	        private void RefreshSettings(PackDisplayInfo p)
2417	        {
2418	            if (_settingsSection == null || _settingsContent == null) return;
2419	
2420	            // Clear existing controls
2421	            for (int i = _settingsContent.childCount - 1; i >= 0; i--)
2422	            {
2423	                Transform child = _settingsContent.GetChild(i);
2424	                child.SetParent(null, false);
2425	                Destroy(child.gameObject);
2426	            }
2427	
2428	            // Get settings from the pack manifest
2429	            if (p.Settings == null || p.Settings.Count == 0)
2430	            {
2431	                _settingsSection.SetActive(false);
2432	                return;
2433	            }
2434	
2435	            _settingsSection.SetActive(true);
2436	
2437	            // Add a header
2438	            Text settingsHeader = UiBuilder.MakeText(_settingsContent, "SettingsHeader",
2439	                "Pack Settings", 12, UiBuilder.Accent, bold: true);
2440	            settingsHeader.gameObject.AddComponent<LayoutElement>().preferredHeight = 18f;
2441	
2442	            UiBuilder.MakeHorizontalSeparator(_settingsContent, UiBuilder.Border);
2443	
2444	            // Get the settings store
2445	            var settingsStore = Settings.PackSettingsStore.Instance;
2446	
2447	            // Render each setting
2448	            foreach (SDK.Models.PackSetting setting in p.Settings)
2449	            {
2450	                BuildSettingControl(_settingsContent, p.Id, setting, settingsStore);
2451	            }
2452	        }
