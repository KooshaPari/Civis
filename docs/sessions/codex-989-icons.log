1070	        // ------------------------------------------------------------------ //
1071	        // Cluster 6a: Interactivity (active + interactable + CanvasGroup)
1072	        // ------------------------------------------------------------------ //
1073	
1074	        /// <summary>
1075	        /// Ensure button GameObject is active, button is interactable, and any CanvasGroup
1076	        /// on the button doesn't block interaction.
1077	        /// </summary>
1078	        private void EnsureButtonInteractivity(Button modsButton, long attemptId)
1079	        {
1080	            // Ensure button is fully interactive
1081	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 3: Ensuring button is fully interactive...");
1082	            modsButton.gameObject.SetActive(true);
1083	            modsButton.interactable = true;
1084	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 3 OK: Button activated: active={modsButton.gameObject.activeSelf}, interactable={modsButton.interactable}");
1085	
1086	            // Ensure CanvasGroup doesn't block interaction
1087	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 4: Checking CanvasGroup...");
1088	            CanvasGroup? cg = modsButton.GetComponent<CanvasGroup>();
1089	            if (cg != null)
1090	            {
1091	                cg.interactable = true;
1092	                cg.blocksRaycasts = true;
1093	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 4 OK: CanvasGroup configured (interactable={cg.interactable}, blocksRaycasts={cg.blocksRaycasts})");
1094	            }
1095	            else
1096	            {
1097	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 4 INFO: No CanvasGroup on button (OK, not required)");
1098	            }
1099	        }
