1369	            }
1370	            dropdown.value = 0;
1371	
1372	            // Setup label
1373	            GameObject label = new GameObject("Label", typeof(RectTransform), typeof(Text));
1374	            label.transform.SetParent(go.transform, false);
1375	            RectTransform labelRt = label.GetComponent<RectTransform>();
1376	            labelRt.anchorMin = Vector2.zero;
1377	            labelRt.anchorMax = Vector2.one;
