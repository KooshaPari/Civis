+            max_attempts,
+            hang_seconds,
+        } => dispatch(prompt, model, cwd, id, max_attempts, hang_seconds).map(|_| ()),
+        Commands::Resume { id } => resume(id),
+        Commands::Status { id, tail } => status(&id, tail),
+        Commands::Queue {
+            jobs_file,
+            concurrency,
+            default_model,
+        } => queue(jobs_file, concurrency, default_model),
+    };
