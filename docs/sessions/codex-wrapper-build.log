+        cwd: workdir.clone(),
+        prompt: prompt.clone(),
+        attempts: 0,
+        state: State::Queued,
+        last_output_offset: 0,
+        cli: if pick_backend(&model) == Backend::Composer { "composer".into() } else { "codex".into() },
+        output_path: output_path.display().to_string(),
+        last_error: None,
+        created_at: now,
+        updated_at: now,
+    };
+    update_state(&job_file(&id), &job)?;
+    let mut final_job = run_with_ladder(
+        job.clone(),
+        Some(model),
+        hang,
+        attempts,
+        None,
+    )?;
+    final_job.updated_at = now_ts();
+    update_state(&job_file(&id), &final_job)?;
