10:    /// <summary>
11:    /// Applies the active total_conversion pack's <c>ui_theme</c> colors to EVERY non-MainMenu
12:    /// native canvas — the Settings screen and its sub-tabs (GAME / VIDEO / SOUND / CONTROLS /
13:    /// TWITCH), plus the game create / select screens. <see cref="MainMenuThemer"/> owns the
14:    /// MainMenu canvas (full art takeover); this reskinner covers the remaining pages with a
15:    /// color-only pass so the whole UI reads as one themed skin.
16:    ///
17:    /// Design:
18:    ///   - Idempotent and re-runnable. Settings/sub-tab panels are created lazily by DINO when the
19:    ///     user navigates, so a single apply at menu-load time misses them. The runtime pump calls
20:    ///     <see cref="ReskinAllPages"/> on a bounded retry cadence; each call re-walks all active
21:    ///     canvases and re-applies. A per-object marker component (<see cref="ReskinMarker"/>)
22:    ///     prevents redundant re-tinting of objects already skinned this session.
23:    ///   - Never touches the MainMenu canvas (left to MainMenuThemer) or DINOForge-owned objects.
24:    ///   - Color-only: no sprite/art swaps, so it degrades gracefully on any unknown panel layout.
25:    ///   - All operations are best-effort and never throw into the pump.
26:    /// </summary>
27:    internal sealed class CanvasReskinner
28:    {
29:        private readonly ManualLogSource? _log;
30:        private readonly string _packsDirectory;
31:
32:        // Cached resolved theme (re-resolved when the pack set changes).
33:        private MenuThemeReader.MenuTheme _theme = MenuThemeReader.MenuTheme.Default;
34:        private bool _themeResolved;
35:
36:        public CanvasReskinner(ManualLogSource? log, string packsDirectory)
37:        {
38:            _log = log;
39:            _packsDirectory = packsDirectory ?? string.Empty;
40:        }
41:
42:        /// <summary>Re-resolve the theme on the next reskin pass (call on scene change / pack reload).</summary>
43:        public void Invalidate() => _themeResolved = false;
44:
45:        /// <summary>
46:        /// Marker component left on objects already reskinned this session so repeated pump passes
47:        /// are cheap and don't fight DINO's own per-frame restyle.
48:        /// </summary>
49:        private sealed class ReskinMarker : MonoBehaviour { }
50:
51:        /// <summary>
52:        /// Walk every active canvas except MainMenu and apply the theme color block to each
53:        /// Selectable, and the theme text color to each Text / TMP_Text. Returns the number of
54:        /// newly-skinned objects (0 when nothing new appeared).
55:        /// </summary>
56:        public int ReskinAllPages(IReadOnlyList<PackDisplayInfo>? packs)
57:        {
58:            try
59:            {
60:                if (!_themeResolved)
61:                {
62:                    _theme = MenuThemeReader.Resolve(packs, _packsDirectory);
63:                    _themeResolved = true;
64:                }
65:
66:                int total = 0;
67:                Canvas[] canvases = UnityEngine.Object.FindObjectsOfType<Canvas>();
68:                foreach (Canvas canvas in canvases)
69:                {
70:                    if (canvas == null || !canvas.gameObject.activeInHierarchy) continue;
71:                    // MainMenuThemer owns the MainMenu canvas (full art takeover) — skip it.
72:                    if (canvas.name.IndexOf("MainMenu", StringComparison.OrdinalIgnoreCase) >= 0) continue;
73:                    // Never reskin DINOForge's own UI (F10 panel / native mods page / quick panel).
74:                    if (canvas.name.IndexOf("DINOForge", StringComparison.Ordinal) >= 0) continue;
75:                    total += ReskinCanvas(canvas);
76:                }
77:
78:                if (total > 0)
79:                    _log?.LogInfo($"[CanvasReskinner] Skinned {total} new native element(s) across non-MainMenu pages.");
80:                return total;
81:            }
82:            catch (Exception ex)
83:            {
84:                _log?.LogWarning($"[CanvasReskinner] ReskinAllPages failed: {ex.Message}"); // pattern-96-ok: diagnostic
85:                return 0;
86:            }
87:        }
