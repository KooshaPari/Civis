330	        /// once <c>_injected</c> is true.
331	        /// </summary>
332	        internal void TryInjectMenuButton()
333	        {
334	            // GUARD: Prevent re-entrant LoadScene calls. When SceneManager.LoadScene(1) is
335	            // called below, it synchronously destroys the RuntimeDriver (even though it has
336	            // DontDestroyOnLoad) and triggers the creation of a new RuntimeDriver via
337	            // resurrection. The new RuntimeDriver's TryInjectMenuButton runs before the old
338	            // call stack unwinds, leading to a second LoadScene(1) call on the same frame.
339	            // That second call destabilizes the scene transition and crashes the game.
340	            if (_s_sceneTransitionGuard) return;
341	            _s_sceneTransitionGuard = true;
342	
343	            _injectionAttemptCount++;
344	            long attemptId = _injectionAttemptCount;
345	
346	            // #920: Telemetry — count each injection attempt.
347	            try { MetricsCollector.Instance.IncrementCounter("mods_button.inject_attempts"); } catch { /* best-effort */ }
348	
349	            try
350	            {
351	                LogInfo($"[NativeMenuInjector::{_sessionId}] ═══ INJECTION ATTEMPT #{attemptId} at {System.DateTime.UtcNow:HH:mm:ss.fff} UTC ═══");
352	
353	                // If already injected and button is alive, skip scan
354	                if (_injected && _injectedButton != null)
355	                {
356	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}: Already injected + button alive, skipping scan");
357	                    return;
358	                }
359	
360	                Canvas[] allCanvases = Resources.FindObjectsOfTypeAll<Canvas>();
361	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}: Scan started — found {allCanvases.Length} canvases total");
362	                DebugLog.Write("NativeMenuInjector", $"[{_sessionId}] Attempt#{attemptId}: Scan started — {allCanvases.Length} canvases");
363	                DebugLog.Write("NativeMenuInjector", $"[{_sessionId}] Attempt#{attemptId}: All canvases dump:");
364	                foreach (Canvas c in allCanvases)
365	                    DebugLog.Write("NativeMenuInjector", $"[{_sessionId}]   Canvas '{c.name}' active={c.gameObject.activeInHierarchy}");
366	
367	                int activeCount = 0;
368	
369	                foreach (Canvas canvas in allCanvases)
370	                {
371	                    // Check if canvas is active in hierarchy
372	                    if (!IsCanvasActive(canvas))
373	                    {
374	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   Canvas '{canvas.name}': INACTIVE (skipped)");
375	                        continue;
376	                    }
377	                    activeCount++;
378	
379	                    // Search all active canvases regardless of name — the DINO menu
380	                    // canvas name may vary; we rely on finding the Settings/Options button.
381	                    DebugLog.Write("NativeMenuInjector", $"[{_sessionId}] Attempt#{attemptId} Canvas '{canvas.name}': searching for buttons...");
382	
383	                    _pendingSelectableDonor = null; // reset per-canvas before FindSettingsButton populates it
384	                    Button? settingsButton = FindSettingsButton(canvas);
385	                    if (settingsButton == null)
386	                    {
387	                        // #882: Selectable-donor fallback — FindSettingsButton may have set
388	                        // _pendingSelectableDonor when it found a MainMenuButton-style Selectable.
389	                        if (_pendingSelectableDonor != null)
390	                        {
391	                            Selectable selectableDonor = _pendingSelectableDonor;
392	                            _pendingSelectableDonor = null;
393	                            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} ✓ Selectable-donor path: donor='{selectableDonor.name}' type={selectableDonor.GetType().Name} in canvas '{canvas.name}'");
394	                            InjectButtonFromSelectable(selectableDonor, attemptId);
395	                            if (_injected)
396	                            {
397	                                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} ✓✓✓✓✓ SELECTABLE-DONOR INJECTION SUCCESSFUL! Mods button is now ACTIVE.");
398	                                // #920: Telemetry — count successful injections (selectable-donor path).
399	                                try { MetricsCollector.Instance.IncrementCounter("mods_button.inject_success"); } catch { /* best-effort */ }
400	                                TakeAutoCheckpointScreenshot("cp1_mods_injected_selectable", 180);
401	                                return;
402	                            }
403	                        }
404	                        else
405	                        {
406	                            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   Canvas '{canvas.name}': NO Settings/Options button found");
407	                        }
408	                        continue;
409	                    }
410	
411	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} ✓✓✓ SUCCESS FOUND Settings button '{settingsButton.name}' in canvas '{canvas.name}'. INJECTING Mods button...");
412	
413	                    InjectButton(settingsButton, attemptId);
414	
415	                    if (_injected)
416	                    {
417	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} ✓✓✓✓✓ INJECTION SUCCESSFUL! Mods button is now ACTIVE.");
418	                        // #920: Telemetry — count successful injections.
419	                        try { MetricsCollector.Instance.IncrementCounter("mods_button.inject_success"); } catch { /* best-effort */ }
420	                        // Auto-checkpoint screenshot: schedule 180 frames later (Update-based, may not fire)
421	                        TakeAutoCheckpointScreenshot("cp1_mods_injected", 180);
422	                        return;
423	                    }
424	                }
425	
426	                // ── ISSUE-044 InitialGameLoader auto-advance ─────────────────────
427	                // If the game is stuck on InitialGameLoader waiting for Input.anyKey,
428	                // skip to scene 1 (main menu). We call LoadScene and immediately return —
429	                // OnActiveSceneChanged will fire when the scene is ready and trigger re-scan.
430	                if (attemptId >= 2 && !_anyKeyPatchApplied)
431	                {
432	                    bool hasInitialLoader = false;
433	                    foreach (Canvas c in allCanvases)
434	                    {
435	                        if (c.name != null && c.name.IndexOf("InitialGameLoader", StringComparison.OrdinalIgnoreCase) >= 0 && c.gameObject.activeInHierarchy)
436	                        {
437	                            hasInitialLoader = true;
438	                            break;
439	                        }
440	                    }
441	                    if (hasInitialLoader)
442	                    {
443	                        _anyKeyPatchApplied = true;  // prevent re-triggering
444	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} — InitialGameLoader stuck. Loading scene 1 to skip splash screen.");
445	                        DebugLog.Write("NativeMenuInjector", $"[{_sessionId}] InitialGameLoader auto-advance: SceneManager.LoadScene(1)");
446	                        SceneManager.LoadScene(1);
447	                        return;  // IMPORTANT: return immediately; OnActiveSceneChanged will re-trigger scan
448	                    }
449	                }
450	
451	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} SCAN COMPLETE: {allCanvases.Length} total, {activeCount} active searched, 0 Settings buttons found. Will retry in {RescanInterval}s.");
452	            }
453	            catch (Exception ex)
454	            {
455	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} TryInjectMenuButton EXCEPTION: {ex}");
456	            }
457	        }
458	
459	        /// <summary>
460	        /// Searches a canvas for buttons whose label contains "Settings" or "Options".
461	        /// If multiple "Options" buttons are found, stores them so we can repurpose the last one.
462	        /// </summary>
463	        private Button? FindSettingsButton(Canvas canvas)
464	        {
465	            try
466	            {
467	                // #778: Diagnostic inventory — DINO uses a CUSTOM non-Unity-Button class for menu
468	                // buttons, so `GetComponentsInChildren<Button>` returns 0. Log Selectables and any
469	                // component whose Type.Name ends with "Button" so we have data on the next session
470	                // even if the predicate below doesn't match.
471	                Selectable[] selectables = canvas.GetComponentsInChildren<Selectable>(includeInactive: true);
472	                DebugLog.Write("NativeMenuInjector", $"[#778] Canvas '{canvas.name}' has {selectables.Length} Selectables (incl. inactive)");
473	                int sampleCap = selectables.Length < 20 ? selectables.Length : 20;
474	                for (int i = 0; i < sampleCap; i++)
475	                {
476	                    Selectable s = selectables[i];
477	                    if (s == null) continue;
478	                    DebugLog.Write("NativeMenuInjector", $"[#778]   Selectable[{i}] name='{s.gameObject.name}' type={s.GetType().FullName}");
479	                }
480	
481	                // #778: Reflection fallback — walk every Component, capture any whose Type.Name
482	                // ends with "Button" (catches DINO's custom button class regardless of base).
483	                Component[] allComponents = canvas.GetComponentsInChildren<Component>(includeInactive: true);
484	                System.Collections.Generic.List<Component> buttonLike = new System.Collections.Generic.List<Component>();
485	                System.Text.StringBuilder typeSample = new System.Text.StringBuilder();
486	                foreach (Component c in allComponents)
487	                {
488	                    if (c == null) continue;
489	                    string tn = c.GetType().Name;
490	                    if (tn.EndsWith("Button", StringComparison.OrdinalIgnoreCase))
491	                    {
492	                        buttonLike.Add(c);
493	                        if (buttonLike.Count <= 10)
494	                        {
495	                            if (typeSample.Length > 0) typeSample.Append(", ");
496	                            typeSample.Append(tn);
497	                        }
498	                    }
499	                }
500	                DebugLog.Write("NativeMenuInjector", $"[#778] Canvas '{canvas.name}' has {buttonLike.Count} *Button components: [{typeSample}]");
501	
502	                // Try to find Settings button
503	                Button? settings = NativeUiHelper.FindButtonByText(canvas.transform, "Settings");
504	                if (settings != null)
505	                {
506	                    LogInfo($"[NativeMenuInjector]     Found 'Settings' button: '{settings.name}'");
507	                    return settings;
508	                }
509	
510	                // Find ALL "Options" buttons (case-insensitive)
511	                Button[] allButtons = canvas.GetComponentsInChildren<Button>(includeInactive: false);
512	                System.Collections.Generic.List<Button> optionsButtons = new System.Collections.Generic.List<Button>();
513	                foreach (Button b in allButtons)
514	                {
515	                    string label = NativeUiHelper.GetButtonText(b);
516	                    if (label.IndexOf("Options", StringComparison.OrdinalIgnoreCase) >= 0)
517	                    {
518	                        optionsButtons.Add(b);
519	                        LogInfo($"[NativeMenuInjector]     Found 'Options' button: '{b.name}' (count: {optionsButtons.Count})");
520	                    }
521	                }
522	
523	                // #882: Second query — DINO's MainMenuButton inherits Selectable (NOT Button), so
524	                // the Button-typed query above returns 0 candidates. Filter Selectables to those
525	                // whose runtime type-name contains "Button" (Pattern #99/#171: explicit Ordinal).
526	                Selectable[] activeSelectables = canvas.GetComponentsInChildren<Selectable>(includeInactive: false);
527	                System.Collections.Generic.List<Selectable> selectableCandidates = new System.Collections.Generic.List<Selectable>();
528	                foreach (Selectable s in activeSelectables)
529	                {
530	                    if (s == null) continue;
531	                    if (s is Button) continue; // already counted in allButtons
532	                    if (s.GetType().Name.IndexOf("Button", StringComparison.Ordinal) < 0) continue;
533	                    string label = ReadGameObjectLabel(s.gameObject);
534	                    if (label.Length == 0) continue;
535	                    if (label.IndexOf("Options", StringComparison.OrdinalIgnoreCase) >= 0
536	                        || label.IndexOf("Settings", StringComparison.OrdinalIgnoreCase) >= 0)
537	                    {
538	                        selectableCandidates.Add(s);
539	                    }
540	                }
541	
542	                // #778 / #882: Broadened pass — also scan ALL Selectables (catches custom buttons that
543	                // inherit Selectable but not Button) by reading child Text/TMP_Text labels directly.
544	                // When a match is found and no Button-typed donor exists yet, store it as
545	                // _pendingSelectableDonor for the CloneSelectableAsButton path.
546	                if (optionsButtons.Count == 0)
547	                {
548	                    foreach (Selectable s in selectables)
549	                    {
550	                        if (s == null || s is Button) continue; // Button already covered above
551	                        string label = ReadGameObjectLabel(s.gameObject);
552	                        if (label.Length == 0) continue;
553	                        if (label.IndexOf("Settings", StringComparison.OrdinalIgnoreCase) >= 0
554	                            || label.IndexOf("Options", StringComparison.OrdinalIgnoreCase) >= 0)
555	                        {
556	                            LogInfo($"[NativeMenuInjector] [#778/#882]   Selectable-match '{s.gameObject.name}' type={s.GetType().Name} label='{label}' — storing as _pendingSelectableDonor for Selectable-clone path");
557	                            DebugLog.Write("NativeMenuInjector", $"[#778] MATCH (Selectable) canvas='{canvas.name}' go='{s.gameObject.name}' type={s.GetType().FullName} label='{label}'");
558	                            // First match wins; don't overwrite a candidate already set by
559	                            // the selectableCandidates pass above.
560	                            if (_pendingSelectableDonor == null)
561	                                _pendingSelectableDonor = s;
562	                        }
563	                    }
564	
565	                    // Also surface any *Button-typed component matches (reflection-fallback)
566	                    foreach (Component c in buttonLike)
567	                    {
568	                        string label = ReadGameObjectLabel(c.gameObject);
569	                        if (label.Length == 0) continue;
570	                        if (label.IndexOf("Settings", StringComparison.OrdinalIgnoreCase) >= 0
571	                            || label.IndexOf("Options", StringComparison.OrdinalIgnoreCase) >= 0)
572	                        {
573	                            DebugLog.Write("NativeMenuInjector", $"[#778] MATCH (*Button reflection) canvas='{canvas.name}' go='{c.gameObject.name}' type={c.GetType().FullName} label='{label}'");
574	                            // If the component is also a Selectable, it qualifies as donor.
575	                            if (_pendingSelectableDonor == null && c is Selectable cs && !(cs is Button))
576	                                _pendingSelectableDonor = cs;
577	                        }
578	                    }
579	                }
580	
581	                // Store all found Options buttons; InjectButton will repurpose whichever is best.
582	                if (optionsButtons.Count >= 1)
583	                {
584	                    _allOptionsButtons = optionsButtons;
585	                    LogInfo($"[NativeMenuInjector]     Found {optionsButtons.Count} 'Options' button(s); will repurpose for Mods");
586	                    return optionsButtons[0];
587	                }
588	
589	                // #882: Selectable-fallback — promote first custom-Button-typed Selectable as donor.
590	                if (selectableCandidates.Count >= 1)
591	                {
592	                    Selectable donor = selectableCandidates[0];
593	                    LogInfo($"[NativeMenuInjector] Selectable-fallback used: donor='{donor.name}' typeName='{donor.GetType().Name}'");
594	                    // Last-ditch: if the donor GameObject also carries a UnityEngine.UI.Button
595	                    // sibling component, promote it directly.
596	                    Button? donorButton = donor.gameObject.GetComponent<Button>();
597	                    if (donorButton != null)
598	                    {
599	                        LogInfo($"[NativeMenuInjector]     Selectable donor has sibling UnityEngine.UI.Button — using it as clone source");
600	                        return donorButton;
601	                    }
602	                    // #882 extension: store the Selectable donor for the new CloneSelectableAsButton
603	                    // path in TryInjectMenuButton. This lets InjectButtonFromSelectable clone the
604	                    // GameObject and swap the custom component for a UnityEngine.UI.Button.
605	                    LogInfo($"[NativeMenuInjector]     Selectable donor has no UnityEngine.UI.Button sibling — storing as _pendingSelectableDonor for Selectable-clone path");
606	                    _pendingSelectableDonor = donor;
607	                }
608	
609	                // #882: Early-exit diagnostic — surfaces *why* we're returning null even when
610	                // Selectables exist on the canvas. Pairs with the Selectable-fallback log above.
611	                LogInfo($"[NativeMenuInjector.probe] EARLY-EXIT canvas='{canvas.name}' UnityButtons={allButtons.Length} customSelectables={selectableCandidates.Count}");
612	
613	                // Log all buttons found for diagnostics
614	                LogInfo($"[NativeMenuInjector]     No 'Settings' or 'Options' button found in canvas. Dumping all {allButtons.Length} active buttons:");
615	                foreach (Button b in allButtons)
616	                {
617	                    string label = b.GetComponentInChildren<UnityEngine.UI.Text>()?.text ?? "(no text)";
618	                    LogInfo($"[NativeMenuInjector]       Button '{b.name}' label='{label}'");
619	                }
620	                return null;
621	            }
622	            catch (Exception ex)
623	            {
624	                LogWarning($"[NativeMenuInjector] FindSettingsButton exception: {ex}");
625	                return null;
626	            }
627	        }
628	
629	        // #778: Read a label string from any GameObject by checking legacy Text and TMP_Text
630	        // children. Used by the Selectable / reflection-fallback scans so we can match labels
631	        // on DINO's custom (non-Unity-Button) menu buttons.
632	        private static string ReadGameObjectLabel(GameObject go)
633	        {
634	            if (go == null) return string.Empty;
635	            try
636	            {
637	                UnityEngine.UI.Text? legacy = go.GetComponentInChildren<UnityEngine.UI.Text>(true);
638	                if (legacy != null && !string.IsNullOrEmpty(legacy.text)) return legacy.text;
639	
640	                Type? tmpType = Type.GetType("TMPro.TMP_Text, Unity.TextMeshPro")
641	                             ?? Type.GetType("TMPro.TMP_Text, Assembly-CSharp");
642	                if (tmpType != null)
643	                {
644	                    Component? tmp = go.GetComponentInChildren(tmpType, true);
645	                    if (tmp != null)
646	                    {
647	                        System.Reflection.PropertyInfo? prop = tmpType.GetProperty("text");
648	                        object? val = prop?.GetValue(tmp);
649	                        if (val is string s && !string.IsNullOrEmpty(s)) return s;
650	                    }
651	                }
652	            }
653	            catch { /* safe-swallow: diagnostic helper is best-effort and must not throw */ }
654	            return string.Empty;
655	        }
656	
657	        /// <summary>
658	        /// Enforces consistent state on an existing Mods button without re-cloning.
659	        /// Sets all Text/TMPro children to "Mods", ensures onClick has OnModsButtonClicked listener,
660	        /// and ensures targetGraphic is properly set for visual state transitions.
661	        /// </summary>
662	        private void EnforceModsButtonState(Button modsButton, long attemptId)
663	        {
664	            // Set all text components to "Mods"
665	            foreach (UnityEngine.UI.Text legacyText in modsButton.GetComponentsInChildren<UnityEngine.UI.Text>(true))
666	            {
667	                legacyText.text = "Mods";
668	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Enforced Text '{legacyText.name}' to 'Mods'");
669	            }
670	            System.Type? tmpType = System.Type.GetType("TMPro.TMP_Text, Unity.TextMeshPro");
671	            if (tmpType != null)
672	            {
673	                foreach (Component c in modsButton.GetComponentsInChildren(tmpType, true))
674	                {
675	                    tmpType.GetProperty("text")?.SetValue(c, "Mods");
676	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Enforced TMP_Text '{c.name}' to 'Mods'");
677	                }
678	            }
679	
680	            // Ensure onClick only has OnModsButtonClicked
681	            modsButton.onClick.RemoveAllListeners();
682	            LogInfo($"[NativeMenuInjector.probe] WIRING onClick listener — button name={modsButton.name}, listenerCount-before={modsButton.onClick.GetPersistentEventCount()}");
683	            modsButton.onClick.AddListener(OnModsButtonClicked);
684	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Wired onClick listener to OnModsButtonClicked");
685	
686	            // Ensure targetGraphic is set for visual state transitions
687	            if (modsButton.targetGraphic == null)
688	            {
689	                Image? fallbackImage = FindPreferredButtonGraphic(modsButton.transform);
690	                if (fallbackImage != null)
691	                {
692	                    modsButton.targetGraphic = fallbackImage;
693	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Set targetGraphic fallback to '{fallbackImage.name}'");
694	                }
695	            }
696	        }
697	
698	        /// <summary>
699	        /// Repurposes the last "Options" button as "Mods" if 2+ exist, otherwise clones the reference button.
700	        /// Labels it "Mods" and wires its onClick event.
701	        ///
702	        /// Decomposed (Pattern #222 refactor, iter-143 / task #479-REOPEN) into 7 cohesive helpers:
703	        /// ResolveCloneSource → TryReEnforceExistingInjection → CloneAndRegisterModsButton →
704	        /// PositionAndRebuildLayout → EnsureButtonInteractivity → ValidateRaycastAndEventSystem →
705	        /// CommitInjectionAndLog. Atomic state-mutation (_injectedButton + _injected) MUST remain
706	        /// in the final helper (CommitInjectionAndLog) to preserve behavior #7 atomicity.
707	        /// Behavior-preserving — see <c>NativeMenuInjectorCharacterizationTests</c> (13 source-text invariants).
708	        /// </summary>
709	        private void InjectButton(Button settingsButton, long attemptId)
710	        {
711	            try
712	            {
713	                if (settingsButton == null)
714	                {
715	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} InjectButton called with NULL settingsButton! ABORT.");
716	                    return;
717	                }
718	
719	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} InjectButton starting with settingsButton='{settingsButton.name}'");
720	
721	                // Cluster 1: decide clone source + positioning hint.
722	                (Button cloneSource, Button? positionAfterSibling) = ResolveCloneSource(settingsButton, attemptId);
723	
724	                // Cluster 2: duplicate-prevention guard. Re-enforces existing button + commits state atomically.
725	                if (TryReEnforceExistingInjection(cloneSource, attemptId))
726	                {
727	                    return;
728	                }
729	
730	                // Cluster 3+4: clone + register + enforce "Mods" text.
731	                Button? modsButton = CloneAndRegisterModsButton(cloneSource, attemptId);
732	                if (modsButton == null)
733	                {
734	                    // CloneAndRegisterModsButton already logged the failure. Early-return without touching state.
735	                    return;
736	                }
737	
738	                // Cluster 5: position + force layout rebuild.
739	                PositionAndRebuildLayout(modsButton, settingsButton, positionAfterSibling, attemptId);
740	
741	                // Cluster 6a: ensure interactivity (active + interactable + CanvasGroup).
742	                EnsureButtonInteractivity(modsButton, attemptId);
743	
744	                // Cluster 6b: raycast diagnostics + EventSystem navigation isolation.
745	                ValidateRaycastAndEventSystem(modsButton, settingsButton, attemptId);
746	
747	                // STEP 6: Wire onClick
748	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 6: Wiring onClick listener...");
749	                RewireModsButtonClick(modsButton, attemptId);
750	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 6 OK: onClick listener attached");
751	
752	                // Cluster 8 (FINAL): atomic state commit + success log. Must remain LAST.
753	                CommitInjectionAndLog(modsButton, attemptId);
754	            }
755	            catch (Exception ex)
756	            {
757	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} ⚠⚠⚠ InjectButton EXCEPTION: {ex}");
758	            }
759	        }
760	
761	        // ------------------------------------------------------------------ //
762	        // Selectable-donor injection path (#882)
763	        // ------------------------------------------------------------------ //
764	
765	        /// <summary>
766	        /// Alternative injection entry point used when the canvas has no Unity
767	        /// <see cref="Button"/> instances but does have a custom
768	        /// <c>MainMenuButton : Selectable</c> donor.
769	        ///
770	        /// Strategy:
771	        ///   1. Clone the donor's GameObject via
772	        ///      <see cref="NativeUiHelper.CloneSelectableAsButton"/> (strips the custom
773	        ///      component, adds a proper <see cref="Button"/>).
774	        ///   2. Build a synthetic <em>settingsButton reference</em> from the donor for
775	        ///      layout positioning (it shares the same parent, so
776	        ///      <see cref="PositionAndRebuildLayout"/> works unchanged).
777	        ///   3. Delegate to the existing <see cref="TryReEnforceExistingInjection"/>,
778	        ///      <see cref="EnsureButtonInteractivity"/>,
779	        ///      <see cref="ValidateRaycastAndEventSystem"/>,
780	        ///      <see cref="RewireModsButtonClick"/>, and
781	        ///      <see cref="CommitInjectionAndLog"/> clusters unchanged.
782	        /// </summary>
783	        private void InjectButtonFromSelectable(Selectable donor, long attemptId)
784	        {
785	            try
786	            {
787	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} InjectButtonFromSelectable: donor='{donor.name}' type={donor.GetType().Name}");
788	
789	                // 1. Clone the donor's GameObject; get a proper Button back.
790	                Button? modsButton = NativeUiHelper.CloneSelectableAsButton(donor, "Mods");
791	                if (modsButton == null)
792	                {
793	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} InjectButtonFromSelectable: CloneSelectableAsButton returned null — ABORT");
794	                    return;
795	                }
796	
797	                // Register clone name for Harmony text-intercept patch (same as Button path).
798	                RepurposedModsButtonGoName = modsButton.gameObject.name;
799	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} InjectButtonFromSelectable: cloned '{modsButton.name}', registered for text intercept");
800	
801	                // #883: Re-apply donor visual state explicitly after clone so hover/press colors
802	                // match the native MainMenuButton (red highlight). CloneSelectableAsButton already
803	                // does this, but re-applying here also logs the applied transition + color block
804	                // so the next debug session has a clear record of what was set.
805	                NativeUiHelper.CopySelectableVisualState(modsButton, donor);
806	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} InjectButtonFromSelectable: visual state synced from donor — transition={modsButton.transition} highlightedColor={modsButton.colors.highlightedColor} selectedColor={modsButton.colors.selectedColor}");
807	
808	                // 2. Enforce "Mods" text on all text children (clone inherited donor label).
809	                foreach (UnityEngine.UI.Text legacyText in modsButton.GetComponentsInChildren<UnityEngine.UI.Text>(true))
810	                {
811	                    legacyText.text = "Mods";
812	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Set Text '{legacyText.name}' to 'Mods'");
813	                }
814	                System.Type? tmpType = System.Type.GetType("TMPro.TMP_Text, Unity.TextMeshPro");
815	                if (tmpType != null)
816	                {
817	                    foreach (Component c in modsButton.GetComponentsInChildren(tmpType, true))
818	                    {
819	                        tmpType.GetProperty("text")?.SetValue(c, "Mods");
820	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Set TMP_Text '{c.name}' to 'Mods'");
821	                    }
822	                }
823	
824	                // 3. Position the Mods button AFTER the donor in the parent layout.
825	                RectTransform? modsRect = modsButton.GetComponent<RectTransform>();
826	                RectTransform? donorRect = donor.GetComponent<RectTransform>();
827	                if (modsRect != null && donorRect != null)
828	                {
829	                    NativeUiHelper.PositionAfterSibling(modsRect, donorRect);
830	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   Positioned AFTER donor (sibling index: {modsButton.transform.GetSiblingIndex()})");
831	
832	                    // Force layout rebuild.
833	                    Transform layoutParent = donorRect.parent;
834	                    if (layoutParent != null)
835	                    {
836	                        var layoutRt = layoutParent.GetComponent<RectTransform>();
837	                        if (layoutRt != null)
838	                            UnityEngine.UI.LayoutRebuilder.ForceRebuildLayoutImmediate(layoutRt);
839	                        if (layoutParent.parent != null)
840	                        {
841	                            var gpRt = layoutParent.parent.GetComponent<RectTransform>();
842	                            if (gpRt != null)
843	                                UnityEngine.UI.LayoutRebuilder.ForceRebuildLayoutImmediate(gpRt);
844	                        }
845	                        UnityEngine.Canvas.ForceUpdateCanvases();
846	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   Layout rebuild forced on '{layoutParent.name}'");
847	                    }
848	                }
849	                else
850	                {
851	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   Could not get RectTransform for modsButton or donor — skipping position");
852	                }
853	
854	                // 4. Ensure interactivity and targetGraphic.
855	                EnsureButtonInteractivity(modsButton, attemptId);
856	
857	                // 5. Raycast diagnostics + EventSystem navigation isolation.
858	                //    ValidateRaycastAndEventSystem takes a settingsButton reference for navigation
859	                //    logging only; pass a fake stub by creating a minimal donor-sibling lookup.
860	                //    We use modsButton as the "settingsButton" reference since navigation.mode
861	                //    on the donor's Selectable isn't accessible from here and the log is
862	                //    diagnostic-only.
863	                ValidateRaycastAndEventSystem(modsButton, modsButton, attemptId);
864	
865	                // 6. Wire onClick.
866	                RewireModsButtonClick(modsButton, attemptId);
867	
868	                // 7. Atomic state commit.
869	                CommitInjectionAndLog(modsButton, attemptId);
870	            }
871	            catch (Exception ex)
872	            {
873	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} ⚠ InjectButtonFromSelectable EXCEPTION: {ex}");
874	            }
875	        }
