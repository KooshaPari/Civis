1343	        /// <summary>
1344	        /// Attempts to show the compact, native-style QUICK panel inside the MainMenu
1345	        /// canvas. This is the DEFAULT MODS click action: a small panel that looks like a
1346	        /// DINO sub-menu (native-cloned button chrome, themed by the active total_conversion
1347	        /// ui_theme) with per-pack ON/OFF toggles and a "Browse all" button that opens the
1348	        /// full-screen <see cref="NativeModsPage"/> browser.
1349	        /// Returns false if the MainMenu canvas cannot be found.
1350	        /// </summary>
1351	        private bool TryShowQuickPanel(long clickId)
1352	        {
1353	            try
1354	            {
1355	                Canvas? mainMenuCanvas = FindActiveCanvasByName("MainMenu")
1356	                    ?? _injectedButton?.GetComponentInParent<Canvas>();
1357	                if (mainMenuCanvas == null)
1358	                {
1359	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} Cannot find MainMenu canvas for quick panel");
1360	                    return false;
1361	                }
1362	
1363	                // Resolve the active theme (SW gold default) from the loaded packs on disk.
1364	                System.Collections.Generic.IReadOnlyList<PackDisplayInfo> packs =
1365	                    PackDataProvider?.Invoke()
1366	                    ?? (System.Collections.Generic.IReadOnlyList<PackDisplayInfo>)System.Array.Empty<PackDisplayInfo>();
1367	                MenuThemeReader.MenuTheme theme = MenuThemeReader.Resolve(packs, PacksDirectory);
1368	
1369	                if (_quickPanel == null)
1370	                {
1371	                    GameObject host = new GameObject("DINOForge_QuickModPanelHost");
1372	                    host.transform.SetParent(mainMenuCanvas.transform, false);
1373	                    _quickPanel = host.AddComponent<NativeQuickModPanel>();
1374	                    if (_log != null) _quickPanel.SetLogger(_log);
1375	
1376	                    _quickPanel.OnPackToggled = (packId, isEnabled) =>
1377	                    {
1378	                        LogInfo($"[NativeMenuInjector::{_sessionId}] QuickPanel pack toggled: {packId} = {isEnabled}");
1379	                        OnNativePackToggled?.Invoke(packId, isEnabled);
1380	                    };
1381	                    _quickPanel.OnBrowseAllClicked = () =>
1382	                    {
1383	                        LogInfo($"[NativeMenuInjector::{_sessionId}] QuickPanel 'Browse all' — opening full browser");
1384	                        // Open the full-screen browser (deep management).
1385	                        if (!TryShowNativeModsPage(clickId) && _menuHost != null)
1386	                            _menuHost.Show();
1387	                    };
1388	                    _quickPanel.OnClosed = () =>
1389	                    {
1390	                        LogInfo($"[NativeMenuInjector::{_sessionId}] QuickPanel closed");
1391	                    };
1392	                }
1393	
1394	                // Use the injected Mods button (a clone of a native DINO menu button) as the
1395	                // native-chrome donor so the panel's rows/buttons match DINO's button style.
1396	                _quickPanel.Configure(_injectedButton, theme);
1397	                _quickPanel.SetPacks(packs);
1398	                _quickPanel.Show(mainMenuCanvas);
1399	                LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} QuickPanel shown with {packs.Count} packs (donor={(_injectedButton != null ? _injectedButton.name : "none")})");
1400	                return true;
1401	            }
1402	            catch (Exception ex)
1403	            {
1404	                LogWarning($"[NativeMenuInjector::{_sessionId}] Click#{clickId} TryShowQuickPanel exception: {ex}");
1405	                return false;
1406	            }
1407	        }
