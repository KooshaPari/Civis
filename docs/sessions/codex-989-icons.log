2402	        /// <summary>Returns a human-readable summary of the stored resolution for the given pack pair.</summary>
2403	        private string GetResolutionStatusText(string selfId, string otherId)
2404	        {
2405	            string? res = _conflictStore?.GetResolution(selfId, otherId);
2406	            if (string.IsNullOrEmpty(res) || string.Equals(res, "merge", StringComparison.Ordinal))
2407	                return "Resolution: Keep Both (default)";
2408	            if (string.Equals(res, "prefer_self", StringComparison.Ordinal))
2409	                return "Resolution: Prefer \"" + selfId + "\"";
2410	            if (string.Equals(res, "prefer_other", StringComparison.Ordinal))
2411	                return "Resolution: Prefer \"" + otherId + "\"";
2412	            return "Resolution: " + res;
2413	        }
