207:        /// Copies hover/press visual state from a donor <see cref="Selectable"/> onto a
208:        /// freshly-created <see cref="Button"/> so it matches the native menu button appearance
209:        /// (red highlight on hover/selection in DINO's MainMenuButton style).
210:        /// Safe to call even when the donor has no configured color block — the default
211:        /// Unity <see cref="ColorBlock"/> is used as-is in that case.
212:        /// </summary>
213:        /// <param name="target">The new Button that needs visual state.</param>
214:        /// <param name="donor">The original Selectable whose visual properties are the template.</param>
215:        internal static void CopySelectableVisualState(Button target, Selectable donor)
216:        {
217:            if (target == null || donor == null) return;
218:            try
219:            {
220:                // 1. Copy the full interaction-transition configuration. This is what drives
221:                //    the hover (highlighted), pressed, selected and disabled rendering.
222:                target.transition = donor.transition;
223:                target.colors = donor.colors;
224:                target.spriteState = donor.spriteState;
225:                target.animationTriggers = donor.animationTriggers;
226:
227:                // 2. CRITICAL (#1 root cause): a Selectable's transition only renders if its
228:                //    targetGraphic is set. CloneSelectableAsButton adds a fresh Button whose
229:                //    targetGraphic is null, so ColorTint/SpriteSwap had nothing to paint —
230:                //    the injected button "acted like the cursor was never over it".
231:                //    Resolve the donor's targetGraphic to the equivalent child on the clone
232:                //    (same relative path), and copy the background Image sprite/material/color
233:                //    so normal-state chrome matches native too.
234:                //    (#970a robust resolve-by-path + #970b full-frame property copy unioned.)
235:                Graphic? resolvedTargetGraphic = ResolveClonedTargetGraphic(target, donor);
