1757	        private int _pendingAutoCheckpointFrames = -1;
1758	        private string? _pendingAutoCheckpointPath = null;
1759	
1760	        /// <summary>
1761	        /// Schedule an auto-checkpoint screenshot N frames from now (main-thread-safe).
1762	        /// Saves to BepInEx root as a PNG with the given name suffix.
1763	        /// Delayed to allow the render loop to settle after UI changes.
1764	        /// </summary>
1765	        private void TakeAutoCheckpointScreenshot(string name, int delayFrames = 120)
1766	        {
1767	            try
1768	            {
1769	                string bepRoot = BepInEx.Paths.BepInExRootPath;
1770	                string path = System.IO.Path.Combine(bepRoot, name + ".png");
1771	                DebugLog.Write("NativeMenuInjector", $"[Screenshot] Auto-checkpoint: scheduled in {delayFrames} frames: {path}");
1772	                _pendingAutoCheckpointPath = path;
1773	                _pendingAutoCheckpointFrames = delayFrames;
1774	            }
1775	            catch (Exception ex)
1776	            {
1777	                DebugLog.Write("NativeMenuInjector", $"[Screenshot] Auto-checkpoint schedule FAILED: {ex.Message}");
1778	            }
1779	        }
1780	
1781	        private void TickAutoCheckpoint()
1782	        {
1783	            if (_pendingAutoCheckpointFrames < 0 || _pendingAutoCheckpointPath == null) return;
1784	            _pendingAutoCheckpointFrames--;
1785	            if (_pendingAutoCheckpointFrames == 0)
1786	            {
1787	                try
1788	                {
1789	                    DebugLog.Write("NativeMenuInjector", $"[Screenshot] Auto-checkpoint: capturing now: {_pendingAutoCheckpointPath}");
1790	                    DINOForge.Runtime.Bridge.FrameCapture.Result fc =
1791	                        DINOForge.Runtime.Bridge.FrameCapture.Capture(_pendingAutoCheckpointPath);
1792	                    DebugLog.Write("NativeMenuInjector", $"[Screenshot] Auto-checkpoint: FrameCapture {(fc.Success ? "OK" : "FAIL")} ({fc.Bytes}B {fc.Method}): {_pendingAutoCheckpointPath}");
1793	                }
1794	                catch (Exception ex)
1795	                {
1796	                    DebugLog.Write("NativeMenuInjector", $"[Screenshot] Auto-checkpoint capture FAILED: {ex.Message}");
