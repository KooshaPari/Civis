{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DINOForge proof policy",
  "type": "object",
  "required": ["version", "policy_id", "features"],
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
    "policy_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "forbidden_judges_global": {
      "type": "array",
      "items": { "type": "string" }
    },
    "features": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["required_judge", "required_artifacts"],
        "properties": {
          "description": { "type": "string" },
          "required_judge": { "type": "string", "minLength": 1 },
          "forbidden_judges": {
            "type": "array",
            "items": { "type": "string" }
          },
          "required_artifacts": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "require_bridge_receipt": { "type": "boolean" },
          "require_external_judge": { "type": "boolean" },
          "max_age_seconds": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
