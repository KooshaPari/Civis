+fn run_resume(id: String) -> io::Result<()> {
+    let path = job_file(&id);
+    let mut job = state_file_read(&path)?;
+    let maybe_model = Some(job.model.clone());
+    let final_job = run_with_ladder(
+        job,
+        maybe_model,
+        DEFAULT_HANG_SECONDS,
+        DEFAULT_MAX_ATTEMPTS.saturating_sub(1),
+        None,
+    )?;
+    println!("READY id={} state={:?}", final_job.id, final_job.state);
+    Ok(())
+}
