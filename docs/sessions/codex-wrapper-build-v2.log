216:    let mut child = match cmd.spawn() {
217:        Ok(c) => c,
218:        Err(e) => {
219:            return Attempt {
220:                success: false,
221:                exit_code: None,
222:                error: Some(format!("spawn failed: {e}")),
223:                capacity_error: false,
224:                connection_error: is_connection(&e.to_string()),
225:                stdin_hang: false,
226:            }
227:        }
228:    };
229:
230:    let stdout = child.stdout.take();
231:    let stderr = child.stderr.take();
232:    if stdout.is_none() || stderr.is_none() {
233:        return Attempt {
234:            success: false,
235:            exit_code: None,
236:            error: Some("missing stdout/stderr pipes".to_string()),
237:            capacity_error: false,
238:            connection_error: false,
239:            stdin_hang: false,
240:        };
241:    }
242:
243:    let mut out = OpenOptions::new()
244:        .create(true)
245:        .append(true)
246:        .open(&job.output_path)
247:        .ok();
248:    let (tx, rx): (Sender<String>, Receiver<String>) = mpsc::channel();
249:    let tx2 = tx.clone();
250:    spawn_reader("stdout", stdout.unwrap(), tx);
251:    spawn_reader("stderr", stderr.unwrap(), tx2);
252:
253:    let mut last_output = Instant::now();
254:    let mut saw_capacity = false;
255:    let mut saw_connection = false;
256:
257:    loop {
258:        match rx.recv_timeout(Duration::from_millis(200)) {
259:            Ok(chunk) => {
260:                if let Some(file) = out.as_mut() {
261:                    let _ = file.write_all(chunk.as_bytes());
262:                    let _ = file.flush();
263:                }
264:                job.last_output_offset = job.last_output_offset.saturating_add(chunk.len() as u64);
265:                last_output = Instant::now();
266:                if is_capacity(&chunk) {
267:                    saw_capacity = true;
268:                }
269:                if is_connection(&chunk) {
270:                    saw_connection = true;
271:                }
272:            }
273:            Err(_) => {
274:                match child.try_wait() {
275:                    Ok(Some(status)) => {
276:                        let code = status.code();
277:                        if code == Some(0) && !saw_capacity && !saw_connection {
278:                            return Attempt {
279:                                success: true,
280:                                exit_code: code,
281:                                error: None,
282:                                capacity_error: false,
283:                                connection_error: false,
284:                                stdin_hang: false,
285:                            };
286:                        }
287:                        if is_connection(&format!("{status}")) || saw_connection {
288:                            return Attempt {
289:                                success: false,
290:                                exit_code: code,
291:                                error: Some(format!("connection error: {status}")),
292:                                capacity_error: false,
293:                                connection_error: true,
294:                                stdin_hang: false,
295:                            };
296:                        }
297:                        return Attempt {
298:                            success: false,
299:                            exit_code: code,
300:                            error: Some(if saw_capacity {
301:                                "Selected model is at capacity".to_string()
302:                            } else {
303:                                format!("exit!=0: {code:?}")
304:                            }),
305:                            capacity_error: saw_capacity,
306:                            connection_error: false,
307:                            stdin_hang: false,
308:                        };
309:                    }
310:                    Ok(None) => {
311:                        if last_output.elapsed() >= Duration::from_secs(hang_seconds) {
312:                            let _ = child.kill();
313:                            return Attempt {
314:                                success: false,
315:                                exit_code: None,
316:                                error: Some("Reading additional input from stdin (no output growth)".to_string()),
317:                                capacity_error: false,
318:                                connection_error: false,
319:                                stdin_hang: true,
320:                            };
321:                        }
322:                    }
323:                    Err(e) => {
324:                        return Attempt {
325:                            success: false,
326:                            exit_code: None,
327:                            error: Some(format!("process wait failed: {e}")),
328:                            capacity_error: false,
329:                            connection_error: is_connection(&e.to_string()),
330:                            stdin_hang: false,
331:                        };
332:                    }
333:                }
334:            }
335:        }
336:    }
337:}
