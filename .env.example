# Runtime logging
RUST_LOG=info

# civ-watch HTTP port
CIV_WATCH_PORT=9090

# civ-server WebSocket port
CIV_SERVER_PORT=3000

# civ-server WebSocket host/path overrides
CIV_WS_HOST=127.0.0.1
CIV_WS_PATH=/ws

# Full WebSocket URL override for dashboards and Bevy clients
CIV_WS_URL=

# Optional host:port override for WebSocket clients
CIVIS_WS_ADDR=

# Binary tick preference for WebSocket clients
CIVIS_WS_BINARY=1

# Dashboard attach behavior and watch base URL
CIVIS_ATTACH=server
CIVIS_WATCH_HTTP=http://127.0.0.1:9090

# Vite-only dashboard overrides
VITE_CIVIS_WS_URL=
VITE_CIVIS_WS_BINARY=1
VITE_CIVIS_WATCH_HTTP=http://127.0.0.1:9090
VITE_CIVIS_SERVER_HTTP=http://127.0.0.1:3000
VITE_CIV_SERVER_PORT=3000

# civ-server process defaults
CIV_SERVER_HOST=0.0.0.0
CIV_METRICS_PORT=9090
CIV_WS_MAX_CLIENTS=16

# Infra service ports
CIV_PG_PORT=5432
CIV_DRAGONFLY_PORT=6379
CIV_NATS_PORT=4222
CIV_MINIO_PORT=9000
CIV_MINIO_CONSOLE_PORT=9001

# Infra service URLs
CIV_PG_URL=postgres://civis:civis@127.0.0.1:5432/civis
CIV_DRAGONFLY_URL=redis://127.0.0.1:6379
CIV_NATS_URL=nats://127.0.0.1:4222
CIV_MINIO_URL=http://127.0.0.1:9000

# Infra credentials
CIV_PG_USER=civis
CIV_PG_PASSWORD=civis
CIV_PG_DB=civis
CIV_MINIO_ACCESS_KEY=civis
CIV_MINIO_SECRET_KEY=

# LLM / research integration
KIMI_API_KEY=
FIREPASS_BASE_URL=https://api.firepass.dev/v1
