{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dinoforge.dev/schemas/provenance_index.schema.json",
  "title": "DINOForge Asset Provenance Index",
  "description": "Detailed provenance tracking and intellectual property assessment records for assets in a pack. Records source authority, license verification, derivative-work assessment, and release-policy decisions per asset.",
  "type": "object",
  "required": [
    "registry_version",
    "registry_format",
    "pack_id",
    "provenance_records"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Reference to this schema (relative or URL)."
    },
    "registry_version": {
      "type": "string",
      "description": "SemVer of the provenance index format.",
      "pattern": "^\\d+\\.\\d+\\.\\d+(?:-[A-Za-z0-9.-]+)?$"
    },
    "registry_format": {
      "type": "string",
      "description": "Free-text human-readable name of the registry format (e.g. 'DINOForge Provenance Index')."
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp of last edit."
    },
    "pack_id": {
      "type": "string",
      "description": "ID of the pack this provenance index belongs to. Must match pack-manifest.id.",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "description": "Free-text purpose statement."
    },
    "provenance_records": {
      "type": "array",
      "description": "One record per asset assessed.",
      "items": { "$ref": "#/$defs/ProvenanceRecord" }
    },
    "summary_statistics": {
      "type": "object",
      "description": "Aggregated counts derived from provenance_records.",
      "properties": {
        "total_assets_assessed": { "type": "integer", "minimum": 0 },
        "private_only_assets": { "type": "integer", "minimum": 0 },
        "public_release_approved": { "type": "integer", "minimum": 0 },
        "average_ip_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "assets_needing_replacement_for_release": { "type": "integer", "minimum": 0 },
        "assets_ready_for_prototyping": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "recommendations": {
      "type": "object",
      "description": "Human-readable recommendation lists keyed by phase (immediate_actions, development_phase, release_phase, etc.).",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "$defs": {
    "ProvenanceRecord": {
      "type": "object",
      "required": [
        "asset_id",
        "assessment_status",
        "ip_classification",
        "release_policy"
      ],
      "properties": {
        "asset_id": {
          "type": "string",
          "description": "Stable identifier; should match the asset's id in asset-manifest."
        },
        "assessment_date": {
          "type": "string",
          "format": "date-time"
        },
        "assessment_status": {
          "type": "string",
          "enum": [
            "pending_verification",
            "metadata_verified",
            "license_verified",
            "approved_internal",
            "approved_public",
            "rejected"
          ]
        },
        "ip_classification": {
          "type": "string",
          "description": "Pack-defined IP bucket (e.g. fan_star_wars_private_only, original, public_domain)."
        },
        "ip_confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "ip_confidence_justification": { "type": "string" },
        "source_authority": {
          "type": "string",
          "enum": ["unknown", "low_trust", "medium_trust", "high_trust", "first_party"]
        },
        "source_authority_rationale": { "type": "string" },
        "license_assessment": { "$ref": "#/$defs/LicenseAssessment" },
        "author_assessment": { "$ref": "#/$defs/AuthorAssessment" },
        "derivative_work_assessment": { "$ref": "#/$defs/DerivativeWorkAssessment" },
        "risk_factors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "release_policy": {
          "type": "string",
          "description": "Free-text description of release constraints."
        },
        "required_actions_before_release": {
          "type": "array",
          "items": { "type": "string" }
        },
        "acquisition_metadata": {
          "type": "object",
          "additionalProperties": true
        },
        "assessment_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "LicenseAssessment": {
      "type": "object",
      "properties": {
        "declared_license": { "type": "string" },
        "license_url": { "type": "string" },
        "license_verified": { "type": "boolean" },
        "license_text_summary": { "type": "string" },
        "license_compatible_with_public_release": { "type": ["boolean", "null"] },
        "license_compatible_with_internal_use": { "type": ["boolean", "null"] },
        "attribution_requirement": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "AuthorAssessment": {
      "type": "object",
      "properties": {
        "author_name": { "type": "string" },
        "author_username": { "type": "string" },
        "author_reputation": { "type": "string" },
        "author_sketchfab_profile": { "type": "string" },
        "author_verified": { "type": "boolean" },
        "author_contact_attempted": { "type": "boolean" },
        "models_published": { "type": "integer", "minimum": 0 },
        "community_followers": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "DerivativeWorkAssessment": {
      "type": "object",
      "properties": {
        "is_original_work_claim": { "type": "boolean" },
        "is_fan_derivative": { "type": "boolean" },
        "is_licensed_derivative": { "type": "boolean" },
        "franchise_references": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intellectual_property_owners": {
          "type": "array",
          "items": { "type": "string" }
        },
        "license_holder_permission_obtained": { "type": "boolean" },
        "creator_permission_to_use": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  }
}
