2849	            RectTransform overlayRt = overlay.GetComponent<RectTransform>();
2850	            overlayRt.anchorMin = Vector2.zero;
2851	            overlayRt.anchorMax = Vector2.one;
2852	            overlayRt.offsetMin = Vector2.zero;
2853	            overlayRt.offsetMax = Vector2.zero;
2854	
2855	            // Dimmed backdrop
2856	            Image backdrop = overlay.AddComponent<Image>();
2857	            backdrop.color = new Color(0f, 0f, 0f, 0.72f);
2858	            backdrop.raycastTarget = true;
2859	
2860	            // Dialog box
2861	            GameObject dialog = UiBuilder.MakePanel(overlay.transform, "DialogBox",
2862	                UiBuilder.BgSurface, new Vector2(380f, 200f));
2863	            RectTransform dialogRt = dialog.GetComponent<RectTransform>();
2864	            dialogRt.anchorMin = new Vector2(0.5f, 0.5f);
2865	            dialogRt.anchorMax = new Vector2(0.5f, 0.5f);
2866	            dialogRt.pivot = new Vector2(0.5f, 0.5f);
2867	            dialogRt.anchoredPosition = Vector2.zero;
2868	
2869	            VerticalLayoutGroup vlg = dialog.AddComponent<VerticalLayoutGroup>();
2870	            vlg.spacing = 10f;
2871	            vlg.padding = new RectOffset(16, 16, 14, 14);
2872	            vlg.childForceExpandWidth = true;
2873	            vlg.childForceExpandHeight = false;
2874	
2875	            // Title
2876	            Text titleText = UiBuilder.MakeText(dialog.transform, "DialogTitle",
2877	                "DINOForge — Mod Reload", 14, UiBuilder.Accent, bold: true);
2878	            LayoutElement titleLe = titleText.gameObject.AddComponent<LayoutElement>();
2879	            titleLe.preferredHeight = 20f;
2880	
2881	            // Body
2882	            Text bodyText = UiBuilder.MakeText(dialog.transform, "DialogBody", message,
2883	                12, UiBuilder.TextPrimary);
2884	            bodyText.horizontalOverflow = HorizontalWrapMode.Wrap;
2885	            bodyText.verticalOverflow = VerticalWrapMode.Overflow;
2886	            LayoutElement bodyLe = bodyText.gameObject.AddComponent<LayoutElement>();
2887	            bodyLe.preferredHeight = 90f;
2888	            bodyLe.flexibleHeight = 1f;
2889	
2890	            // Button row
2891	            GameObject btnRow = new GameObject("BtnRow", typeof(RectTransform));
2892	            btnRow.transform.SetParent(dialog.transform, false);
2893	            HorizontalLayoutGroup btnHlg = btnRow.AddComponent<HorizontalLayoutGroup>();
2894	            btnHlg.spacing = 10f;
2895	            btnHlg.childForceExpandHeight = false;
2896	            btnHlg.childForceExpandWidth = false;
2897	            btnHlg.childAlignment = TextAnchor.MiddleRight;
2898	            LayoutElement btnRowLe = btnRow.AddComponent<LayoutElement>();
2899	            btnRowLe.preferredHeight = 34f;
2900	            btnRowLe.flexibleWidth = 1f;
2901	
2902	            // Spacer pushes buttons to the right
2903	            GameObject spacer = new GameObject("Spacer", typeof(RectTransform));
2904	            spacer.transform.SetParent(btnRow.transform, false);
2905	            LayoutElement spacerLe = spacer.AddComponent<LayoutElement>();
2906	            spacerLe.flexibleWidth = 1f;
2907	
2908	            Button cancelBtn = UiBuilder.MakeButton(
2909	                btnRow.transform, "CancelBtn", "No — keep playing",
2910	                UiBuilder.BgDeep, UiBuilder.TextSecondary,
2911	                () =>
2912	                {
2913	                    Destroy(overlay);
2914	                    onCancel?.Invoke();
2915	                });
2916	            LayoutElement cancelLe = cancelBtn.gameObject.AddComponent<LayoutElement>();
2917	            cancelLe.preferredWidth = 130f;
2918	            cancelLe.preferredHeight = 30f;
2919	
2920	            Button confirmBtn = UiBuilder.MakeButton(
2921	                btnRow.transform, "ConfirmBtn", "Yes — reload",
2922	                UiBuilder.Accent, Color.black,
2923	                () =>
2924	                {
2925	                    Destroy(overlay);
2926	                    onConfirm?.Invoke();
2927	                });
2928	            LayoutElement confirmLe = confirmBtn.gameObject.AddComponent<LayoutElement>();
2929	            confirmLe.preferredWidth = 110f;
2930	            confirmLe.preferredHeight = 30f;
2931	
2932	            // Ensure panel is visible so user sees the dialog.
2933	            if (!IsVisible) Show();
2934	        }
