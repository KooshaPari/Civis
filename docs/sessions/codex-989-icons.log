2226	        /// <summary>
2227	        /// Reads pack.yaml for the given pack ID and returns a preview string (first 120 lines).
2228	        /// Falls back to an error notice if the file cannot be read.
2229	        /// </summary>
2230	        private string LoadPackYamlPreview(string packId, string overlapSummary)
2231	        {
2232	            if (string.IsNullOrEmpty(_packsDirectory)) return "(packs directory not set)";
2233	            string yamlPath = Path.Combine(_packsDirectory, packId, "pack.yaml");
2234	            try
2235	            {
2236	                if (!File.Exists(yamlPath)) return "(pack.yaml not found for " + packId + ")";
2237	                string yaml = File.ReadAllText(yamlPath, System.Text.Encoding.UTF8);
2238	                string[] lines = yaml.Split('\n');
2239	                int lineLimit = System.Math.Min(lines.Length, 120); // threshold-ok: modal line display limit
2240	                System.Text.StringBuilder sb = new System.Text.StringBuilder(2048);
2241	                sb.Append("=== ").Append(packId).Append(" / pack.yaml ===\n");
2242	                sb.Append("(overlap: ").Append(overlapSummary).Append(")\n\n");
2243	                for (int i = 0; i < lineLimit; i++)
2244	                {
2245	                    sb.Append(lines[i]);
2246	                    sb.Append('\n');
2247	                }
2248	                if (lines.Length > lineLimit)
2249	                    sb.Append("\n... (").Append(lines.Length - lineLimit).Append(" more lines)");
2250	                return sb.ToString();
2251	            }
2252	            catch (Exception ex)
2253	            {
2254	                // safe-swallow: diff preview is best-effort UI decoration
2255	                System.Diagnostics.Debug.WriteLine($"ModMenuPanel pack.yaml preview failed for {packId}: {ex.Message}");
2256	                return "(error reading pack.yaml for " + packId + ")";
2257	            }
2258	        }
