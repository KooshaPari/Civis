89:        private int ReskinCanvas(Canvas canvas)
90:        {
91:            int hits = 0;
92:
93:            // Selectables: buttons, sliders, toggles, dropdowns, scrollbars, input fields.
94:            foreach (Selectable sel in canvas.GetComponentsInChildren<Selectable>(true))
95:            {
96:                if (sel == null) continue;
97:                if (IsExcluded(sel.gameObject)) continue;
98:                if (sel.GetComponent<ReskinMarker>() != null) continue;
99:                try
100:                {
101:                    ColorBlock colors = sel.colors;
102:                    // Keep the native frame visible (normal stays near-white so the art reads),
103:                    // drive highlight/press/selected from the pack theme so hover/press match
104:                    // the themed MainMenu chrome.
105:                    colors.highlightedColor = WithAlpha(_theme.Primary, 0.90f);
106:                    colors.pressedColor = WithAlpha(_theme.Accent, 1.0f);
107:                    colors.selectedColor = WithAlpha(_theme.Primary, 0.75f);
108:                    sel.colors = colors;
109:
110:                    // Tint the immediate label/foreground graphic toward the theme text color
111:                    // for non-Image targetGraphics is risky; only tint sub-Texts below.
112:                    sel.gameObject.AddComponent<ReskinMarker>();
113:                    hits++;
114:                }
115:                catch { /* safe-swallow: per-selectable restyle is best-effort */ }
116:            }
117:
118:            // Legacy UGUI Text labels.
119:            foreach (Text t in canvas.GetComponentsInChildren<Text>(true))
120:            {
121:                if (t == null) continue;
122:                if (IsExcluded(t.gameObject)) continue;
123:                if (t.GetComponent<ReskinMarker>() != null) continue;
124:                try
125:                {
126:                    t.color = _theme.Text;
127:                    t.gameObject.AddComponent<ReskinMarker>();
128:                    hits++;
129:                }
130:                catch { /* safe-swallow */ }
131:            }
132:
133:            // TMP_Text labels (reflection — Runtime has no compile-time TMPro reference).
134:            foreach (Component c in canvas.GetComponentsInChildren<Component>(true))
135:            {
136:                if (c == null) continue;
137:                if (!(c.GetType().FullName ?? string.Empty).StartsWith("TMPro.", StringComparison.Ordinal)) continue;
138:                if (IsExcluded(c.gameObject)) continue;
139:                if (c.GetComponent<ReskinMarker>() != null) continue;
140:                try
141:                {
142:                    System.Reflection.PropertyInfo? colorProp = c.GetType().GetProperty("color");
143:                    if (colorProp != null && colorProp.CanWrite)
144:                    {
145:                        colorProp.SetValue(c, _theme.Text);
146:                        c.gameObject.AddComponent<ReskinMarker>();
147:                        hits++;
148:                    }
149:                }
150:                catch { /* safe-swallow */ }
151:            }
152:
153:            return hits;
154:        }
155:
156:        private static bool IsExcluded(GameObject go)
157:        {
158:            string n = go.name;
159:            return n.IndexOf("DINOForge", StringComparison.Ordinal) >= 0
160:                || n.IndexOf("Mods_Button", StringComparison.Ordinal) >= 0;
161:        }
162:
163:        private static Color WithAlpha(Color c, float a) => new Color(c.r, c.g, c.b, a);
164:    }
165:}

