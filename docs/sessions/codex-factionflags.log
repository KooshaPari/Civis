                            Directory.Move(packPath, disabledPath);
                            temporarilyDisabledDirs.Add(packPath);
                            _log.LogInfo($"[ModPlatform] Temporarily disabled pack: {packId}");
                        }
                        catch (Exception ex)
                        {
