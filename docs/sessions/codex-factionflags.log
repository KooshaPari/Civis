                Bridge.KeyInputSystem.OnPackReloadRequested = () =>
                {
                    try
                    {
                        DebugLog.Write("Plugin", "[RuntimeDriver] Pack reload requested (via OnPackReloadRequested)");
                        RequestPackReload("OnPackReloadRequested");
                    }
