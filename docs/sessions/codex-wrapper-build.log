+fn queue(jobs_file: String, concurrency: usize, default_model: String) -> io::Result<()> {
+    let queue = jobs_dir();
+    let _ = queue;
+    let mut requests: VecDeque<QueueRequest> = QueueRequest::for_path(&jobs_file)
+        .into_iter()
+        .map(|mut req| {
