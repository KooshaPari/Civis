+fn update_state(path: &Path, mut job: Job) -> io::Result<()> {
+    job.updated_at = now_ts();
+    state_file_write(path, &job)
+}
+
+fn fallback_models() -> Vec<String> {
+    vec![
+        "codex-spark".to_string(),
+        "mini".to_string(),
+        "5.5".to_string(),
+    ]
+}
