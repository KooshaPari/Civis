+            bool bestIsLego = Path.GetFileName(bestMatch).Contains("_lego", StringComparison.OrdinalIgnoreCase);
+            bool candidateIsLego = dirName.Contains("_lego", StringComparison.OrdinalIgnoreCase);
+            if (bestIsLego && !candidateIsLego)
+                bestMatch = candidate;
+        }
+
+        return bestMatch;
+    }
