449:fn dispatch(prompt: String, model: String, cwd: Option<String>, id: Option<String>, max_attempts: Option<u32>, hang_seconds: Option<u64>) -> io::Result<Job> {
450:    let job_id = id.unwrap_or_else(|| Uuid::new_v4().to_string());
451:    let root = jobs_dir();
452:    let output = root.join(format!("{}.log", job_id));
453:    let now_ts = now();
454:    let job = Job {
455:        id: job_id,
456:        model: model.clone(),
457:        cwd: cwd.unwrap_or_else(|| ".".to_string()),
458:        prompt,
459:        attempts: 0,
460:        state: State::Queued,
461:        last_output_offset: 0,
462:        cli: if is_composer(&model) { "composer".into() } else { "codex".into() },
463:        output_path: output.display().to_string(),
464:        last_error: None,
465:        created_at: now_ts,
466:        updated_at: now_ts,
467:    };
468:    write_job(&job_path(&job.id), &job)?;
469:    let result = run_with_retry(
470:        job,
471:        model,
472:        max_attempts.unwrap_or(DEFAULT_MAX_ATTEMPTS),
473:        hang_seconds.unwrap_or(DEFAULT_HANG_SECONDS),
474:        None,
475:    )?;
476:    println!("READY id={} state={:?}", result.id, result.state);
477:    Ok(result)
478:}
479:
480:fn status(id: &str, tail: usize) -> io::Result<()> {
481:    let job = read_job(&job_path(id))?;
482:    println!(
483:        "id={} model={} state={:?} attempts={} cli={} last_output_offset={}",
484:        job.id, job.model, job.state, job.attempts, job.cli, job.last_output_offset
485:    );
486:    if let Some(err) = job.last_error.as_ref() {
487:        println!("last_error={err}");
488:    }
489:    println!("--- output tail ({tail} lines) ---");
490:    let data = fs::read_to_string(&job.output_path).unwrap_or_default();
491:    let lines: Vec<&str> = data.lines().collect();
492:    let start = lines.len().saturating_sub(tail);
493:    for line in &lines[start..] {
494:        println!("{line}");
495:    }
496:    Ok(())
497:}
498:
499:fn resume(id: String) -> io::Result<()> {
500:    let job = read_job(&job_path(&id))?;
501:    let model = job.model.clone();
502:    let result = run_with_retry(
503:        job,
504:        model,
505:        DEFAULT_MAX_ATTEMPTS,
506:        DEFAULT_HANG_SECONDS,
507:        None,
508:    )?;
509:    println!("READY id={} state={:?}", result.id, result.state);
510:    Ok(())
511:}
512:
513:fn queue(jobs_file: String, concurrency: usize, default_model: String) -> io::Result<()> {
514:    let queue = jobs_dir();
515:    let _ = queue;
516:    let requests: VecDeque<QueueRequest> = QueueRequest::for_path(&jobs_file)
517:        .into_iter()
518:        .map(|mut req| {
519:            if req.model.is_none() {
520:                req.model = Some(default_model.clone());
521:            }
522:            if req.cwd.is_none() {
523:                req.cwd = Some(".".to_string());
524:            }
525:            req
526:        })
527:        .collect();
528:
529:    let queue_state = Arc::new(Mutex::new(requests));
530:    let cooldown = Arc::new(Mutex::new(HashMap::<String, Instant>::new()));
531:    let mut workers = Vec::new();
532:    let worker_count = concurrency.max(1);
533:    println!("queue ranking: {:?}", ranked_models());
534:
535:    for _ in 0..worker_count {
536:        let state = queue_state.clone();
537:        let c = cooldown.clone();
538:        let w = thread::spawn(move || {
539:            loop {
540:                let req = {
541:                    let mut lock = state.lock().unwrap_or_else(|e| e.into_inner());
542:                    lock.pop_front()
543:                };
544:                match req {
545:                    Some(item) => {
546:                        let id = item.id.unwrap_or_else(|| Uuid::new_v4().to_string());
547:                        let model = item.model.unwrap_or_else(|| "composer-2.5".to_string());
548:                        let root = runner_root().join("jobs");
549:                        let output = root.join(format!("{}.log", id));
550:                        let job = Job {
551:                            id,
552:                            model: model.clone(),
553:                            cwd: item.cwd.unwrap_or_else(|| ".".to_string()),
554:                            prompt: item.prompt,
555:                            attempts: 0,
556:                            state: State::Queued,
557:                            last_output_offset: 0,
558:                            cli: if is_composer(&model) { "composer".into() } else { "codex".into() },
559:                            output_path: output.display().to_string(),
560:                            last_error: None,
561:                            created_at: now(),
562:                            updated_at: now(),
563:                        };
564:                        let _ = write_job(&job_path(&job.id), &job);
565:                        let _ = run_with_retry(
566:                            job,
567:                            model,
568:                            DEFAULT_MAX_ATTEMPTS,
569:                            DEFAULT_HANG_SECONDS,
570:                            Some(c.clone()),
571:                        );
572:                    }
573:                    None => break,
574:                }
575:            }
576:        });
577:        workers.push(w);
578:    }
579:
580:    for w in workers {
581:        let _ = w.join();
582:    }
583:    Ok(())
584:}
585:
586:fn main() {
587:    let cli = Cli::parse();
588:    let code = match cli.command {
589:        Commands::Dispatch {
590:            prompt,
591:            model,
592:            cwd,
593:            id,
594:            max_attempts,
595:            hang_seconds,
596:        } => dispatch(prompt, model, cwd, id, max_attempts, hang_seconds).map(|_| ()),
597:        Commands::Resume { id } => resume(id),
598:        Commands::Status { id, tail } => status(&id, tail),
599:        Commands::Queue {
600:            jobs_file,
601:            concurrency,
602:            default_model,
603:        } => queue(jobs_file, concurrency, default_model),
604:    };
605:
606:    if let Err(err) = code {
607:        eprintln!("error: {err}");
608:        std::process::exit(1);
609:    }
610:}

