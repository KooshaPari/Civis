# Phenotype local-first quality: heavy gates run on the developer machine;
# GitHub Actions only verifies `.ci/quality-manifest.json` (no Rust toolchain on CI).
#
# Setup: lefthook install
# Manual: lefthook run pre-push

pre-commit:
  parallel: true
  commands:
    security-guard:
      run: bash .github/hooks/pre-commit

pre-push:
  piped: true
  commands:
    quality-manifest:
      run: |
        if command -v pwsh >/dev/null 2>&1; then
          pwsh -NoProfile -File scripts/quality/emit-quality-manifest.ps1
        elif command -v powershell >/dev/null 2>&1; then
          powershell -NoProfile -File scripts/quality/emit-quality-manifest.ps1
        else
          bash scripts/quality/emit-quality-manifest.sh
        fi
      stage_fixed: true
