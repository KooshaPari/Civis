2800	        /// <summary>
2801	        /// Displays a transient toast notification at the top of the panel.
2802	        /// Falls back to updating the status line when the HUD strip is unavailable.
2803	        /// Safe to call from any thread — delegates via the Unity main-thread coroutine.
2804	        /// </summary>
2805	        /// <param name="message">Text to show.</param>
2806	        /// <param name="kind">Visual severity (Info / Warning / Error).</param>
2807	        public void ShowToast(string message, HotReload.HmrToastKind kind)
2808	        {
2809	            // Map HmrToastKind to the existing DINOForge ToastType (defined in HudStrip.cs).
2810	            ToastType toastType = kind switch
2811	            {
2812	                HotReload.HmrToastKind.Warning => ToastType.Warning,
2813	                HotReload.HmrToastKind.Error => ToastType.Error,
2814	                _ => ToastType.Info,
2815	            };
2816	
2817	            // Best-effort: set status so the header always reflects the last toast.
2818	            SetStatus(message, kind == HotReload.HmrToastKind.Error ? 1 : 0);
2819	
2820	            // Propagate to the DFCanvas HudStrip toast if we can reach it.
2821	            try
2822	            {
2823	                DFCanvas? canvas = GetComponentInParent<DFCanvas>();
2824	                canvas?.ShowToast(message, toastType);
2825	            }
2826	            catch { } // safe-swallow: toast fallback is best-effort UI only
2827	        }
