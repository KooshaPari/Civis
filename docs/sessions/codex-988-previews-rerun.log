            // with readonly mesh/material data ŌĆö the legacy FieldInfo.SetValue path doesn't
            // apply. Bail out gracefully until HRV2 mesh-swap is implemented (separate task).
            if (IsHrv2Type(_renderMeshVariantName))
            {
