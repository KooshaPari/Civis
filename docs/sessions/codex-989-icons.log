950	        // Clusters 3+4: Clone + register name + enforce text
951	        // ------------------------------------------------------------------ //
952	
953	        /// <summary>
954	        /// Clone the source button, register the clone's GameObject name with the Harmony
955	        /// text-intercept patch, sync visual style, and enforce "Mods" text on all legacy
956	        /// Text + TMPro children. Returns null on clone failure (caller MUST early-return
957	        /// without touching downstream state).
958	        /// </summary>
959	        private Button? CloneAndRegisterModsButton(Button cloneSource, long attemptId)
960	        {
961	            Button? modsButton = NativeUiHelper.CloneButton(cloneSource, "Mods");
962	
963	            if (modsButton == null)
964	            {
965	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   ⚠ STEP 1 FAILED: CloneButton returned null! ABORT.");
966	                return null;
967	            }
968	
969	            // Register cloned button name with Harmony text-intercept patch
970	            RepurposedModsButtonGoName = modsButton.gameObject.name;
971	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 1 OK: Cloned button '{modsButton.name}', registered for text intercept.");
972	            SyncButtonVisualStyle(modsButton, cloneSource, attemptId);
973	
974	            // STEP 1.5: Enforce text — cloned button inherits source text ("Options"), must override
975	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 1.5: Enforcing 'Mods' text on all text components...");
976	            foreach (UnityEngine.UI.Text legacyText in modsButton.GetComponentsInChildren<UnityEngine.UI.Text>(true))
977	            {
978	                legacyText.text = "Mods";
979	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Set Text '{legacyText.name}' to 'Mods'");
980	            }
981	            // TMPro via reflection to avoid hard compile dependency
982	            System.Type? tmpType2 = System.Type.GetType("TMPro.TMP_Text, Unity.TextMeshPro");
983	            if (tmpType2 != null)
984	            {
985	                foreach (Component c in modsButton.GetComponentsInChildren(tmpType2, true))
986	                {
987	                    tmpType2.GetProperty("text")?.SetValue(c, "Mods");
988	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - Set TMP_Text '{c.name}' to 'Mods'");
989	                }
990	            }
991	
992	            return modsButton;
993	        }
