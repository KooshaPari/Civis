995	        // ------------------------------------------------------------------ //
996	        // Cluster 5: Positioning + layout rebuild
997	        // ------------------------------------------------------------------ //
998	
999	        /// <summary>
1000	        /// Position Mods button: AFTER last Options button when multiple exist (via
1001	        /// positionAfterSibling), BEFORE Settings button when only one or zero exists.
1002	        /// Then force layout rebuild on parent + grandparent + Canvas.ForceUpdateCanvases.
1003	        /// </summary>
1004	        private void PositionAndRebuildLayout(Button modsButton, Button settingsButton, Button? positionAfterSibling, long attemptId)
1005	        {
1006	            // Position Mods button: AFTER last Options button when multiple exist,
1007	            // BEFORE Settings button when only one exists.
1008	            RectTransform modsRect = modsButton.GetComponent<RectTransform>();
1009	            RectTransform settingsRect = settingsButton.GetComponent<RectTransform>();
1010	            RectTransform? siblingRef = null;
1011	            if (modsRect != null)
1012	            {
1013	                if (positionAfterSibling != null)
1014	                {
1015	                    // 2+ Options buttons: place Mods AFTER the last Options button.
1016	                    RectTransform? lastOptionsRect = positionAfterSibling.GetComponent<RectTransform>();
1017	                    if (lastOptionsRect != null)
1018	                    {
1019	                        NativeUiHelper.PositionAfterSibling(modsRect, lastOptionsRect);
1020	                        siblingRef = lastOptionsRect;
1021	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 2 OK: Positioned AFTER last Options (sibling index: {modsButton.transform.GetSiblingIndex()})");
1022	                    }
1023	                    else
1024	                    {
1025	                        LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 2: lastOptionsRect is null, falling back to before Settings");
1026	                        NativeUiHelper.PositionBeforeSibling(modsRect, settingsRect);
1027	                        siblingRef = settingsRect;
1028	                    }
1029	                }
1030	                else
1031	                {
1032	                    // 1 or 0 Options buttons: place Mods BEFORE Settings button.
1033	                    NativeUiHelper.PositionBeforeSibling(modsRect, settingsRect);
1034	                    siblingRef = settingsRect;
1035	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 2 OK: Positioned BEFORE Settings (sibling index: {modsButton.transform.GetSiblingIndex()})");
1036	                }
1037	            }
1038	
1039	            // Force layout rebuild so VerticalLayoutGroup/ContentSizeFitter includes the new button.
1040	            if (siblingRef != null)
1041	            {
1042	                Transform layoutParent = siblingRef.parent;
1043	                if (layoutParent != null)
1044	                {
1045	                    var layoutRt = layoutParent.GetComponent<RectTransform>();
1046	                    if (layoutRt != null)
1047	                    {
1048	                        UnityEngine.UI.LayoutRebuilder.ForceRebuildLayoutImmediate(layoutRt);
1049	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 2 LAYOUT: Forced rebuild on '{layoutParent.name}'");
1050	                    }
1051	                    if (layoutParent.parent != null)
1052	                    {
1053	                        var gpRt = layoutParent.parent.GetComponent<RectTransform>();
1054	                        if (gpRt != null)
1055	                        {
1056	                            UnityEngine.UI.LayoutRebuilder.ForceRebuildLayoutImmediate(gpRt);
1057	                            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 2 LAYOUT: Forced rebuild on grandparent '{layoutParent.parent.name}'");
1058	                        }
1059	                    }
1060	                    UnityEngine.Canvas.ForceUpdateCanvases();
1061	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 2 LAYOUT: Canvas.ForceUpdateCanvases() called");
1062	                }
1063	            }
1064	            else
1065	            {
1066	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   ⚠ STEP 2 WARN: Could not get RectTransform for modsButton");
1067	            }
1068	        }
