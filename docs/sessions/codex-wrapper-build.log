+                    let _ = file.flush();
+                }
+                job.last_output_offset = job.last_output_offset.saturating_add(chunk.len() as u64);
+                last_output = Instant::now();
+                if is_capacity(&chunk) {
+                    saw_capacity = true;
+                }
+                if is_connection(&chunk) {
+                    saw_connection = true;
+                }
+            }
+            Err(_) => {
+                match child.try_wait() {
+                    Ok(Some(status)) => {
+                        let code = status.code();
+                        if code == Some(0) && !saw_capacity && !saw_connection {
+                            return Attempt {
+                                success: true,
+                                exit_code: code,
+                                error: None,
+                                capacity_error: false,
+                                connection_error: false,
+                                stdin_hang: false,
+                            };
+                        }
+                        if is_connection(&format!("{status}")) || saw_connection {
+                            return Attempt {
+                                success: false,
+                                exit_code: code,
+                                error: Some(format!("connection error: {status}")),
+                                capacity_error: false,
+                                connection_error: true,
+                                stdin_hang: false,
+                            };
+                        }
+                        return Attempt {
+                            success: false,
+                            exit_code: code,
+                            error: Some(if saw_capacity {
+                                "Selected model is at capacity".to_string()
+                            } else {
+                                format!("exit!=0: {code:?}")
+                            }),
+                            capacity_error: saw_capacity,
+                            connection_error: false,
+                            stdin_hang: false,
+                        };
+                    }
+                    Ok(None) => {
+                        if last_output.elapsed() >= Duration::from_secs(hang_seconds) {
+                            let _ = child.kill();
+                            return Attempt {
+                                success: false,
+                                exit_code: None,
+                                error: Some("Reading additional input from stdin (no output growth)".to_string()),
+                                capacity_error: false,
+                                connection_error: false,
+                                stdin_hang: true,
+                            };
+                        }
+                    }
+                    Err(e) => {
+                        return Attempt {
+                            success: false,
+                            exit_code: None,
+                            error: Some(format!("process wait failed: {e}")),
+                            capacity_error: false,
+                            connection_error: is_connection(&e.to_string()),
+                            stdin_hang: false,
+                        };
+                    }
+                }
+            }
+        }
+    }
+}
+
+fn codex_fallback_models() -> Vec<String> {
+    vec!["codex-spark".to_string(), "mini".to_string(), "5.5".to_string()]
+}
+
+fn ranked_models() -> Vec<String> {
+    vec![
+        "composer-2.5".to_string(),
+        "codex-spark".to_string(),
+        "mini".to_string(),
+        "5.5".to_string(),
+    ]
+}
+
+fn run_with_retry(
+    mut job: Job,
+    initial_model: String,
+    max_attempts: u32,
+    hang_seconds: u64,
+    cooldown: Option<Arc<Mutex<HashMap<String, Instant>>>>,
+) -> io::Result<Job> {
+    let ranking = if is_composer(&initial_model) {
+        vec![initial_model]
+    } else {
+        codex_fallback_models()
+    };
+    let mut attempts = 0;
+    let mut ladder_index = 0;
+    let mut cooldown_map = cooldown;
+
+    while attempts < max_attempts {
+        if ladder_index >= ranking.len() {
+            ladder_index = 0;
+        }
+        let model = ranking[ladder_index % ranking.len()].clone();
+        ladder_index += 1;
+        if ladder_index > ranking.len() * 2 {
+            ladder_index = ranking.len();
+        }
+
+        if let Some(c) = cooldown_map.as_ref() {
+            let wait_needed = {
+                let guard = c.lock().unwrap_or_else(|e| e.into_inner());
+                if let Some(available_at) = guard.get(&model) {
+                    let now = Instant::now();
+                    if *available_at > now {
+                        Some(*available_at - now)
+                    } else {
+                        None
+                    }
+                } else {
+                    None
+                }
+            };
+            if let Some(wait_for) = wait_needed {
+                thread::sleep(wait_for);
+            }
+        }
+
+        job.model = model.clone();
+        job.cli = if is_composer(&model) { "composer".into() } else { "codex".into() };
+        job.state = State::Running;
+        job.updated_at = now();
+        write_job(&job_path(&job.id), &job)?;
+
+        let attempt = run_attempt(&mut job, hang_seconds);
+        attempts += 1;
+        job.attempts += 1;
+
+        if attempt.success {
+            job.state = State::Success;
+            job.last_error = None;
+            write_job(&job_path(&job.id), &job)?;
+            return Ok(job);
+        }
+
+        job.last_error = Some(format!(
+            "attempt {} model {} failed: {}",
+            attempts,
+            job.model,
+            attempt.error.unwrap_or_else(|| "unknown failure".to_string())
+        ));
+
+        if is_composer(&model) {
+            job.last_error = Some(format!(
+                "{} | composer config-bug marker",
+                job.last_error.clone().unwrap_or_default()
+            ));
+            job.state = State::Failed;
+            write_job(&job_path(&job.id), &job)?;
+            return Ok(job);
+        }
+
+        if attempt.capacity_error || attempt.connection_error || attempt.stdin_hang || attempt.exit_code.unwrap_or(-1) != 0 {
+            job.state = State::Retry;
+            if attempt.capacity_error {
+                if let Some(c) = cooldown_map.as_mut() {
+                    let mut guard = c.lock().unwrap_or_else(|e| e.into_inner());
+                    let release = Instant::now() + Duration::from_secs(DEFAULT_COOLDOWN_SECONDS);
+                    guard.insert(model.clone(), release);
+                }
+            }
+            continue;
+        }
+    }
+
+    job.state = State::Failed;
+    write_job(&job_path(&job.id), &job)?;
+    Ok(job)
+}
+
+fn dispatch(prompt: String, model: String, cwd: Option<String>, id: Option<String>, max_attempts: Option<u32>, hang_seconds: Option<u64>) -> io::Result<Job> {
+    let job_id = id.unwrap_or_else(|| Uuid::new_v4().to_string());
+    let root = jobs_dir();
+    let output = root.join(format!("{}.log", job_id));
+    let now_ts = now();
+    let mut job = Job {
+        id: job_id,
+        model: model.clone(),
+        cwd: cwd.unwrap_or_else(|| ".".to_string()),
+        prompt,
+        attempts: 0,
+        state: State::Queued,
+        last_output_offset: 0,
+        cli: if is_composer(&model) { "composer".into() } else { "codex".into() },
+        output_path: output.display().to_string(),
+        last_error: None,
+        created_at: now_ts,
+        updated_at: now_ts,
+    };
+    write_job(&job_path(&job.id), &job)?;
+    let result = run_with_retry(
+        job,
+        model,
+        max_attempts.unwrap_or(DEFAULT_MAX_ATTEMPTS),
+        hang_seconds.unwrap_or(DEFAULT_HANG_SECONDS),
+        None,
+    )?;
+    println!("READY id={} state={:?}", result.id, result.state);
+    Ok(result)
+}
+
+fn status(id: &str, tail: usize) -> io::Result<()> {
+    let job = read_job(&job_path(id))?;
+    println!(
+        "id={} model={} state={:?} attempts={} cli={} last_output_offset={}",
+        job.id, job.model, job.state, job.attempts, job.cli, job.last_output_offset
+    );
+    if let Some(err) = job.last_error.as_ref() {
+        println!("last_error={err}");
+    }
+    println!("--- output tail ({tail} lines) ---");
+    let data = fs::read_to_string(&job.output_path).unwrap_or_default();
+    let lines: Vec<&str> = data.lines().collect();
+    let start = lines.len().saturating_sub(tail);
+    for line in &lines[start..] {
+        println!("{line}");
+    }
+    Ok(())
+}
+
+fn resume(id: String) -> io::Result<()> {
+    let job = read_job(&job_path(&id))?;
+    let model = job.model.clone();
+    let result = run_with_retry(
+        job,
+        model,
+        DEFAULT_MAX_ATTEMPTS,
+        DEFAULT_HANG_SECONDS,
+        None,
+    )?;
+    println!("READY id={} state={:?}", result.id, result.state);
+    Ok(())
+}
+
+fn queue(jobs_file: String, concurrency: usize, default_model: String) -> io::Result<()> {
+    let queue = jobs_dir();
+    let _ = queue;
+    let requests: VecDeque<QueueRequest> = QueueRequest::for_path(&jobs_file)
+        .into_iter()
+        .map(|mut req| {
+            if req.model.is_none() {
+                req.model = Some(default_model.clone());
+            }
+            if req.cwd.is_none() {
+                req.cwd = Some(".".to_string());
+            }
+            req
+        })
+        .collect();
+
+    let queue_state = Arc::new(Mutex::new(requests));
+    let cooldown = Arc::new(Mutex::new(HashMap::<String, Instant>::new()));
+    let mut workers = Vec::new();
+    let worker_count = concurrency.max(1);
+    println!("queue ranking: {:?}", ranked_models());
+
+    for _ in 0..worker_count {
+        let state = queue_state.clone();
+        let c = cooldown.clone();
+        let w = thread::spawn(move || {
+            loop {
+                let req = {
+                    let mut lock = state.lock().unwrap_or_else(|e| e.into_inner());
+                    lock.pop_front()
+                };
+                match req {
+                    Some(item) => {
+                        let id = item.id.unwrap_or_else(|| Uuid::new_v4().to_string());
+                        let model = item.model.unwrap_or_else(|| "composer-2.5".to_string());
+                        let root = runner_root().join("jobs");
+                        let output = root.join(format!("{}.log", id));
+                        let mut job = Job {
+                            id,
+                            model: model.clone(),
+                            cwd: item.cwd.unwrap_or_else(|| ".".to_string()),
+                            prompt: item.prompt,
+                            attempts: 0,
+                            state: State::Queued,
+                            last_output_offset: 0,
+                            cli: if is_composer(&model) { "composer".into() } else { "codex".into() },
+                            output_path: output.display().to_string(),
+                            last_error: None,
+                            created_at: now(),
+                            updated_at: now(),
+                        };
+                        let _ = write_job(&job_path(&job.id), &job);
+                        let _ = run_with_retry(
+                            job,
+                            model,
+                            DEFAULT_MAX_ATTEMPTS,
+                            DEFAULT_HANG_SECONDS,
+                            Some(c.clone()),
+                        );
+                    }
+                    None => break,
+                }
+            }
+        });
+        workers.push(w);
+    }
+
+    for w in workers {
+        let _ = w.join();
+    }
+    Ok(())
+}
+
 fn main() {
-    println!("Hello, world!");
