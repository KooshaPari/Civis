1422	        /// <summary>
1423	        /// Attempts to show the NativeModsPage inside the MainMenu canvas.
1424	        /// Finds the MainMenu canvas, locates its primary content container,
1425	        /// creates or reuses the NativeModsPage component, populates it with
1426	        /// pack data, and shows it.
1427	        /// Returns false if the MainMenu canvas cannot be found.
1428	        /// </summary>
1429	        private bool TryShowNativeModsPage(long clickId)
1430	        {
1431	            try
1432	            {
1433	                // Find the MainMenu canvas (same approach as FindSettingsButton)
1434	                Canvas? mainMenuCanvas = null;
1435	                Canvas[] allCanvases = Resources.FindObjectsOfTypeAll<Canvas>();
1436	                foreach (Canvas c in allCanvases)
1437	                {
1438	                    if (c == null || !c.gameObject.activeInHierarchy) continue;
1439	                    if (c.name != null && c.name.IndexOf("MainMenu", StringComparison.OrdinalIgnoreCase) >= 0)
1440	                    {
1441	                        mainMenuCanvas = c;
1442	                        break;
1443	                    }
1444	                }
1445	
1446	                // Fallback: use the injected button's parent canvas
1447	                if (mainMenuCanvas == null && _injectedButton != null)
1448	                {
1449	                    mainMenuCanvas = _injectedButton.GetComponentInParent<Canvas>();
1450	                }
1451	
1452	                if (mainMenuCanvas == null)
1453	                {
1454	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} Cannot find MainMenu canvas for native page");
1455	                    return false;
1456	                }
1457	
1458	                // Find the main content container to hide.
1459	                // Strategy: look for the first active child with a VerticalLayoutGroup or
1460	                // a child that contains the menu buttons (the injected button's grandparent).
1461	                GameObject? mainMenuContent = FindMainMenuContent(mainMenuCanvas);
1462	
1463	                // Create or reuse the NativeModsPage
1464	                if (_nativeModsPage == null)
1465	                {
1466	                    GameObject pageGo = new GameObject("DINOForge_NativeModsPage_Host");
1467	                    pageGo.transform.SetParent(mainMenuCanvas.transform, false);
1468	                    _nativeModsPage = pageGo.AddComponent<NativeModsPage>();
1469	                    if (_log != null) _nativeModsPage.SetLogger(_log);
1470	                    _nativeModsPage.OnBackClicked = () =>
1471	                    {
1472	                        LogInfo($"[NativeMenuInjector::{_sessionId}] NativeModsPage Back pressed");
1473	                    };
1474	                    _nativeModsPage.OnPackToggled = (packId, isEnabled) =>
1475	                    {
1476	                        LogInfo($"[NativeMenuInjector::{_sessionId}] NativeModsPage pack toggled: {packId} = {isEnabled}");
1477	                        OnNativePackToggled?.Invoke(packId, isEnabled);
1478	                    };
1479	                    _nativeModsPage.OnReloadRequested = () =>
1480	                    {
1481	                        LogInfo($"[NativeMenuInjector::{_sessionId}] NativeModsPage reload requested");
1482	                        OnNativeReloadRequested?.Invoke();
1483	                    };
1484	                }
1485	
1486	                // Populate pack data
1487	                if (PackDataProvider != null)
1488	                {
1489	                    System.Collections.Generic.IReadOnlyList<PackDisplayInfo> packs = PackDataProvider();
1490	                    _nativeModsPage.SetPacks(packs);
1491	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} Loaded {packs.Count} packs into NativeModsPage");
1492	                }
1493	
1494	                _nativeModsPage.Show(mainMenuCanvas, mainMenuContent);
1495	                return true;
1496	            }
1497	            catch (Exception ex)
1498	            {
1499	                LogWarning($"[NativeMenuInjector::{_sessionId}] Click#{clickId} TryShowNativeModsPage exception: {ex}");
1500	                return false;
1501	            }
1502	        }
1503	
1504	        /// <summary>
1505	        /// Finds the main menu's primary content container (the object to hide when
1506	        /// showing the mods page). Looks for the injected button's ancestor layout
1507	        /// group or falls back to the first active child with multiple children.
1508	        /// </summary>
1509	        private GameObject? FindMainMenuContent(Canvas canvas)
1510	        {
1511	            try
1512	            {
1513	                // Strategy 1: walk up from the injected button to find the layout group parent
1514	                if (_injectedButton != null)
1515	                {
1516	                    Transform? current = _injectedButton.transform.parent;
1517	                    while (current != null && current != canvas.transform)
1518	                    {
1519	                        // The content container is typically the child of the canvas root
1520	                        // that holds the button layout group
1521	                        if (current.parent == canvas.transform || current.parent?.parent == canvas.transform)
1522	                        {
1523	                            LogInfo($"[NativeMenuInjector] FindMainMenuContent: found via button ancestor '{current.name}'");
1524	                            return current.gameObject;
1525	                        }
1526	                        current = current.parent;
1527	                    }
1528	                }
1529	
1530	                // Strategy 2: first active child of canvas with multiple children
1531	                for (int i = 0; i < canvas.transform.childCount; i++)
1532	                {
1533	                    Transform child = canvas.transform.GetChild(i);
1534	                    if (child.gameObject.activeSelf && child.childCount > 0
1535	                        && child.name.IndexOf("DINOForge", StringComparison.OrdinalIgnoreCase) < 0)
1536	                    {
1537	                        LogInfo($"[NativeMenuInjector] FindMainMenuContent: fallback to first active child '{child.name}'");
1538	                        return child.gameObject;
1539	                    }
1540	                }
1541	            }
1542	            catch (Exception ex)
1543	            {
1544	                LogWarning($"[NativeMenuInjector] FindMainMenuContent exception: {ex}");
1545	            }
1546	
1547	            return null;
1548	        }
1549	
1550	        /// <summary>
1551	        /// Replaces ALL click handlers — both runtime-registered AND serialized persistent callbacks —
1552	        /// on the Mods button with only the DINOForge toggle.
1553	        ///
1554	        /// Fix #944/D1: RemoveAllListeners() only strips runtime (non-persistent) listeners.
1555	        /// Cloned Options/Settings buttons carry DINO's own serialized persistent onClick
1556	        /// (e.g. hide-menu, navigation calls) that RemoveAllListeners() cannot strip.
1557	        /// Those persistent callbacks execute AFTER our listener, hide the menu, and make
1558	        /// the Mods page invisible. We clear them via reflection on the UnityEvent's
1559	        /// m_PersistentCalls backing field before wiring our own handler.
1560	        /// </summary>
1561	        private void RewireModsButtonClick(Button modsButton, long attemptId)
1562	        {
1563	            int persistentBefore = modsButton.onClick.GetPersistentEventCount();
1564	            // Clear persistent (serialized) listeners via reflection — the only reliable way
1565	            // since Unity provides no public API to remove them at runtime.
1566	            try
1567	            {
1568	                System.Reflection.FieldInfo? fi = typeof(UnityEngine.Events.UnityEventBase)
1569	                    .GetField("m_PersistentCalls",
1570	                        System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance);
1571	                if (fi != null)
1572	                {
1573	                    object? persistentCalls = fi.GetValue(modsButton.onClick);
1574	                    if (persistentCalls != null)
1575	                    {
1576	                        System.Reflection.MethodInfo? clearMethod = persistentCalls.GetType()
1577	                            .GetMethod("Clear",
1578	                                System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance);
1579	                        clearMethod?.Invoke(persistentCalls, null);
1580	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Cleared {persistentBefore} persistent onClick callbacks via reflection");
1581	                    }
1582	                }
1583	                else
1584	                {
1585	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     m_PersistentCalls field not found — persistent listeners may remain");
1586	                }
1587	            }
1588	            catch (Exception ex)
1589	            {
1590	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Persistent clear via reflection failed (non-fatal): {ex.Message}");
1591	            }
1592	            modsButton.onClick.RemoveAllListeners();
1593	            LogInfo($"[NativeMenuInjector.probe] WIRING onClick listener — button name={modsButton.name}, persistentBefore={persistentBefore}, now={modsButton.onClick.GetPersistentEventCount()}");
1594	            modsButton.onClick.AddListener(OnModsButtonClicked);
1595	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Click handler replaced with DINOForge toggle only (persistent cleared)");
1596	        }
