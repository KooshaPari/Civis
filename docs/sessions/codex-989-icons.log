265:        /// Resolves the donor Selectable's <c>targetGraphic</c> to the equivalent graphic on the
266:        /// freshly-cloned button by matching the relative transform path. Returns null when the
267:        /// donor has no targetGraphic or no matching child exists on the clone.
268:        /// </summary>
269:        private static Graphic? ResolveClonedTargetGraphic(Button target, Selectable donor)
270:        {
271:            if (donor.targetGraphic == null) return null;
272:            try
273:            {
274:                string path = GetRelativePath(donor.targetGraphic.transform, donor.transform);
275:                Transform? matching = string.IsNullOrEmpty(path) ? target.transform : target.transform.Find(path);
