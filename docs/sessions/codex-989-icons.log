1979	        /// <summary>Populates the screenshot gallery strip; lazy-loads PNG/JPG textures via coroutine.</summary>
1980	        private void RefreshGallery(PackDisplayInfo p)
1981	        {
1982	            if (_detailGalleryRow == null) return;
1983	
1984	            // Clear old thumbnails
1985	            _galleryThumbs.Clear();
1986	            Transform galleryScroll = _detailGalleryRow.Find("GalleryScroll");
1987	            if (galleryScroll != null)
1988	            {
1989	                Transform content = galleryScroll.Find("Content");
