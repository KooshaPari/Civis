262:    private static Shader GetUrpShader()
263:    {
264:        string[] preferred =
265:        {
266:            "Universal Render Pipeline/Lit",
267:            "Universal Render Pipeline/Simple Lit",
268:            "Universal Render Pipeline/Particles/Lit",
269:            "Universal Render Pipeline/Particles/Unlit"
270:        };
271:
272:        foreach (var preferredName in preferred)
273:        {
274:            Shader shader = Shader.Find(preferredName);
275:            if (shader != null)
276:            {
277:                Debug.Log($"[SwBuildings] Using shader {preferredName}");
278:                return shader;
279:            }
280:        }
281:
282:        var urpShaders = UnityEngine.Resources.FindObjectsOfTypeAll<Shader>();
283:        foreach (var s in urpShaders)
284:        {
285:            if (s == null)
286:                continue;
287:
288:            string name = s.name;
289:            if (name.Contains("Universal Render Pipeline", StringComparison.Ordinal) ||
290:                name.Contains("Universal RP", StringComparison.Ordinal) ||
291:                name.Contains("URP", StringComparison.Ordinal))
292:            {
293:                Debug.LogWarning($"[SwBuildings] Preferred URP shaders unavailable. Using closest URP-like shader: {name}");
294:                return s;
295:            }
296:        }
297:
298:        Shader fallback = Shader.Find("Unlit/Color") ?? Shader.Find("Sprites/Default");
299:        if (fallback != null)
300:        {
301:            Debug.LogWarning($"[SwBuildings] No URP shader family found in project. Falling back to non-URP shader: {fallback.name}");
302:            return fallback;
303:        }
304:
305:        throw new InvalidOperationException("No suitable shader found for bundle build.");
306:    }
