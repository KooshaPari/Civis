1234	        // Cluster 8 (FINAL): Atomic state commit + success log
1235	        // ------------------------------------------------------------------ //
1236	
1237	        /// <summary>
1238	        /// Final button state verification dump, then atomic commit of (_injectedButton + _injected)
1239	        /// together. MUST be the LAST helper called by <see cref="InjectButton"/> — splitting the
1240	        /// state mutation across earlier helpers would let <c>Update()</c> observe partial injection
1241	        /// state and trigger a re-scan loop (behavior #7 atomicity).
