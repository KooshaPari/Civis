2454	        /// <summary>Builds a single setting control row (label + input) and attaches save handlers.</summary>
2455	        private void BuildSettingControl(RectTransform parent, string packId,
2456	            SDK.Models.PackSetting setting, Settings.PackSettingsStore settingsStore)
2457	        {
2458	            // Container for this setting
2459	            GameObject row = new GameObject($"Setting_{setting.Key}", typeof(RectTransform));
2460	            row.transform.SetParent(parent, false);
2461	            VerticalLayoutGroup rowVlg = row.AddComponent<VerticalLayoutGroup>();
2462	            rowVlg.spacing = 4f;
2463	            rowVlg.childForceExpandWidth = true;
2464	            rowVlg.childForceExpandHeight = false;
2465	            LayoutElement rowLe = row.AddComponent<LayoutElement>();
2466	            rowLe.flexibleWidth = 1f;
2467	
2468	            // Label
2469	            Text label = UiBuilder.MakeText(row.transform, "Label", setting.DisplayName, 11,
2470	                UiBuilder.TextPrimary);
2471	            label.gameObject.AddComponent<LayoutElement>().preferredHeight = 16f;
2472	
2473	            // Control based on type
2474	            object currentValue = setting.DefaultValue ?? GetDefaultForType(setting.Type);
2475	            currentValue = settingsStore.Get(packId, setting.Key, currentValue);
2476	
2477	            if (setting.Type == "bool")
2478	            {
2479	                BuildBoolControl(row.transform, packId, setting, currentValue, settingsStore);
2480	            }
2481	            else if (setting.Type == "int" || setting.Type == "float")
2482	            {
2483	                BuildSliderControl(row.transform, packId, setting, currentValue, settingsStore);
2484	            }
2485	            else if (setting.Type == "enum")
2486	            {
2487	                BuildEnumControl(row.transform, packId, setting, currentValue, settingsStore);
2488	            }
2489	            else if (setting.Type == "string")
2490	            {
2491	                BuildStringControl(row.transform, packId, setting, currentValue, settingsStore);
2492	            }
2493	
2494	            // Optional description
2495	            if (!string.IsNullOrEmpty(setting.Description))
2496	            {
2497	                Text desc = UiBuilder.MakeText(row.transform, "Description",
2498	                    setting.Description, 9, UiBuilder.TextSecondary);
2499	                desc.verticalOverflow = VerticalWrapMode.Overflow;
2500	                desc.horizontalOverflow = HorizontalWrapMode.Wrap;
2501	                LayoutElement descLe = desc.gameObject.AddComponent<LayoutElement>();
2502	                descLe.flexibleWidth = 1f;
2503	                descLe.preferredHeight = 20f;
2504	            }
2505	        }
