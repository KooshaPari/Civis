352:fn run_with_retry(
353:    mut job: Job,
354:    initial_model: String,
355:    max_attempts: u32,
356:    hang_seconds: u64,
357:    cooldown: Option<Arc<Mutex<HashMap<String, Instant>>>>,
358:) -> io::Result<Job> {
359:    let ranking = if is_composer(&initial_model) {
360:        vec![initial_model]
361:    } else {
362:        codex_fallback_models()
363:    };
364:    let mut attempts = 0;
365:    let mut ladder_index = 0;
366:    let mut cooldown_map = cooldown;
367:
368:    while attempts < max_attempts {
369:        if ladder_index >= ranking.len() {
370:            ladder_index = 0;
371:        }
372:        let model = ranking[ladder_index % ranking.len()].clone();
373:        ladder_index += 1;
374:        if ladder_index > ranking.len() * 2 {
375:            ladder_index = ranking.len();
376:        }
377:
378:        if let Some(c) = cooldown_map.as_ref() {
379:            let wait_needed = {
380:                let guard = c.lock().unwrap_or_else(|e| e.into_inner());
381:                if let Some(available_at) = guard.get(&model) {
382:                    let now = Instant::now();
383:                    if *available_at > now {
384:                        Some(*available_at - now)
385:                    } else {
386:                        None
387:                    }
388:                } else {
389:                    None
390:                }
391:            };
392:            if let Some(wait_for) = wait_needed {
393:                thread::sleep(wait_for);
394:            }
395:        }
396:
397:        job.model = model.clone();
398:        job.cli = if is_composer(&model) { "composer".into() } else { "codex".into() };
399:        job.state = State::Running;
400:        job.updated_at = now();
401:        write_job(&job_path(&job.id), &job)?;
402:
403:        let attempt = run_attempt(&mut job, hang_seconds);
404:        attempts += 1;
405:        job.attempts += 1;
406:
407:        if attempt.success {
408:            job.state = State::Success;
409:            job.last_error = None;
410:            write_job(&job_path(&job.id), &job)?;
411:            return Ok(job);
412:        }
413:
414:        job.last_error = Some(format!(
415:            "attempt {} model {} failed: {}",
416:            attempts,
417:            job.model,
418:            attempt.error.unwrap_or_else(|| "unknown failure".to_string())
419:        ));
420:
421:        if is_composer(&model) {
422:            job.last_error = Some(format!(
423:                "{} | composer config-bug marker",
424:                job.last_error.clone().unwrap_or_default()
425:            ));
426:            job.state = State::Failed;
427:            write_job(&job_path(&job.id), &job)?;
428:            return Ok(job);
429:        }
430:
431:        if attempt.capacity_error || attempt.connection_error || attempt.stdin_hang || attempt.exit_code.unwrap_or(-1) != 0 {
432:            job.state = State::Retry;
433:            if attempt.capacity_error {
434:                if let Some(c) = cooldown_map.as_mut() {
435:                    let mut guard = c.lock().unwrap_or_else(|e| e.into_inner());
436:                    let release = Instant::now() + Duration::from_secs(DEFAULT_COOLDOWN_SECONDS);
437:                    guard.insert(model.clone(), release);
438:                }
439:            }
440:            continue;
441:        }
442:    }
443:
444:    job.state = State::Failed;
445:    write_job(&job_path(&job.id), &job)?;
446:    Ok(job)
447:}
