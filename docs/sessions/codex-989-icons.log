982	        /// <summary>Builds a horizontal-only scroll view (no vertical scroll).</summary>
983	        private static (ScrollRect scrollRect, RectTransform content) BuildHorizontalScrollView(Transform parent, string name)
984	        {
985	            GameObject go = new GameObject(name, typeof(RectTransform), typeof(Image), typeof(ScrollRect), typeof(Mask));
986	            go.transform.SetParent(parent, false);
987	
988	            Image bgImg = go.GetComponent<Image>();
989	            bgImg.color = new Color(0f, 0f, 0f, 0f);
990	            bgImg.raycastTarget = true;
991	
992	            Mask mask = go.GetComponent<Mask>();
993	            mask.showMaskGraphic = false;
994	
995	            GameObject content = new GameObject("Content", typeof(RectTransform));
996	            content.transform.SetParent(go.transform, false);
997	            RectTransform contentRt = content.GetComponent<RectTransform>();
998	            contentRt.anchorMin = new Vector2(0f, 0f);
999	            contentRt.anchorMax = new Vector2(0f, 1f);
1000	            contentRt.pivot = new Vector2(0f, 0.5f);
1001	            contentRt.offsetMin = Vector2.zero;
1002	            contentRt.offsetMax = Vector2.zero;
1003	
1004	            ContentSizeFitter csf = content.AddComponent<ContentSizeFitter>();
1005	            csf.horizontalFit = ContentSizeFitter.FitMode.PreferredSize;
1006	
1007	            HorizontalLayoutGroup hlg = content.AddComponent<HorizontalLayoutGroup>();
1008	            hlg.childForceExpandWidth = false;
1009	            hlg.childForceExpandHeight = true;
1010	            hlg.spacing = 6f;
1011	            hlg.padding = new RectOffset(4, 4, 4, 4);
1012	
1013	            ScrollRect scrollRect = go.GetComponent<ScrollRect>();
1014	            scrollRect.content = contentRt;
1015	            scrollRect.horizontal = true;
1016	            scrollRect.vertical = false;
1017	            scrollRect.scrollSensitivity = 20f;
1018	            scrollRect.movementType = ScrollRect.MovementType.Clamped;
1019	            scrollRect.viewport = go.GetComponent<RectTransform>();
1020	
1021	            return (scrollRect, contentRt);
1022	        }
