182:fn spawn_reader<R: Read + Send + 'static>(label: &'static str, mut reader: R, tx: Sender<String>) {
183:    let _ = thread::spawn(move || {
184:        let mut buf = [0u8; 4096];
185:        loop {
186:            match reader.read(&mut buf) {
187:                Ok(0) => break,
188:                Ok(n) => {
189:                    let chunk = String::from_utf8_lossy(&buf[..n]).to_string();
190:                    let _ = tx.send(format!("[{}] {}", label, chunk));
191:                }
192:                Err(_) => break,
193:            }
194:        }
195:    });
196:}
