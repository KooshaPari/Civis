            _log.LogInfo($"[RuntimeDriver] F9/F10 key handlers registered on {gameObject.name}.");

            // ── Step 6.5: Create themed loading screen (EPIC-027) ───────────────────
            // Full-screen branded loading takeover during the ~30-45s mod-init phase.
