<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <RunConfiguration>
    <TargetPlatform>x64</TargetPlatform>
  </RunConfiguration>
  <!-- Binding redirects for cross-framework compatibility -->
  <RunConfiguration>
    <AppDomain>Multiple</AppDomain>
    <MaxCpuCount>4</MaxCpuCount>
  </RunConfiguration>
</RunSettings>
