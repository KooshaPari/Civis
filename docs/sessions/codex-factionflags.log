                        _modPlatform?.RebuildCatalogAndApplyStats(catalogWorld);
                    }
                    catch (Exception ex)
                    {
                        _log?.LogWarning($"[RuntimeDriver] Catalog rebuild failed: {ex.Message}");
                    }
                }

