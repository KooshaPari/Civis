1837	        /// <summary>
1838	        /// Rebuilds the badge row for the selected pack (#928-935).
1839	        /// Destroys any previous row, then delegates to <see cref="DINOForge.Runtime.UI.Badges.BadgeRenderer"/>
1840	        /// to create the new one.  The row is inserted as the first child of the detail scroll content
1841	        /// so badges appear at the very top of the detail pane.
1842	        /// </summary>
1843	        private void RefreshBadgesRow(PackDisplayInfo p)
1844	        {
1845	            // Destroy previous dynamic row
1846	            if (_detailBadgesRow != null)
1847	            {
1848	                Destroy(_detailBadgesRow);
1849	                _detailBadgesRow = null;
1850	            }
1851	
1852	            if (p.Badges.Count == 0) return;
1853	
1854	            // Find the detail scroll content (parent of _detailName)
1855	            Transform? contentParent = _detailName?.transform.parent;
1856	            if (contentParent == null) return;
1857	
1858	            _detailBadgesRow = DINOForge.Runtime.UI.Badges.BadgeRenderer.BuildBadgeRow(contentParent, p.Badges);
1859	
1860	            // Move to just before the pack name (index 0) so badges appear at the top
1861	            _detailBadgesRow.transform.SetSiblingIndex(0);
1862	        }
