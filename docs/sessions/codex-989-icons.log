2024	                thumbLe.minWidth = 200f;
2025	                thumbLe.preferredHeight = 150f;
2026	                thumbLe.minHeight = 150f;
2027	
2028	                // The image placeholder (starts grey, filled by coroutine)
2029	                Image thumbImg = thumbCard.GetComponent<Image>();
2030	                thumbImg.preserveAspect = true;
2031	                _galleryThumbs.Add(thumbImg);
