        tail: usize,
    },
}

#[derive(Debug, Clone, Serialize, Deserialize)]
enum State {
    Queued,
    Running,
    Retry,
    Success,
    Failed,
}

#[derive(Debug, Serialize, Deserialize, Clone)]
struct Job {
    id: String,
    model: String,
    cwd: String,
    prompt: String,
    attempts: u32,
    state: State,
    last_output_offset: u64,
    cli: String,
    output_path: String,
    last_error: Option<String>,
    created_at: u64,
    updated_at: u64,
}

#[derive(Debug, Clone)]
enum Backend {
    Codex,
    Composer,
}

#[derive(Debug, Clone)]
struct Attempt {
    success: bool,
    exit_code: Option<i32>,
    error: Option<String>,
    capacity_error: bool,
    connection_error: bool,
    stdin_hang: bool,
    output_delta: u64,
}

#[derive(Debug, Clone)]
struct CooldownState {
    available_after: std::time::SystemTime,
}

#[derive(Debug, Clone)]
struct QueueRequest {
    id: Option<String>,
