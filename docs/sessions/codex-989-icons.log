3419	        /// <summary>
3420	        /// Builds the telemetry section appended at the bottom of the detail pane's scroll content.
3421	        /// Displays <see cref="MetricsCollector.Instance.DumpMarkdown()"/> as monospace plain text;
3422	        /// auto-refreshes every 2 seconds via coroutine; "Copy to Clipboard" button for sharing.
3423	        /// </summary>
3424	        private void BuildTelemetrySection(Transform parent)
3425	        {
3426	            UiBuilder.MakeHorizontalSeparator(parent, UiBuilder.Border);
3427	
3428	            // Section header row
3429	            GameObject headerRow = new GameObject("TelemetryHeader", typeof(RectTransform));
3430	            headerRow.transform.SetParent(parent, false);
3431	            HorizontalLayoutGroup hHlg = headerRow.AddComponent<HorizontalLayoutGroup>();
3432	            hHlg.spacing = 6f;
3433	            hHlg.childForceExpandHeight = false;
3434	            hHlg.childForceExpandWidth = false;
3435	            hHlg.padding = new RectOffset(0, 0, 4, 2);
3436	            headerRow.AddComponent<LayoutElement>().preferredHeight = 24f;
3437	
3438	            Text sectionTitle = UiBuilder.MakeText(headerRow.transform, "TelemetryTitle",
3439	                "TELEMETRY", 11, UiBuilder.Accent, bold: true);
3440	            sectionTitle.gameObject.AddComponent<LayoutElement>().flexibleWidth = 1f;
3441	
3442	            // "Copy to Clipboard" button
3443	            Button copyBtn = UiBuilder.MakeButton(
3444	                headerRow.transform, "CopyMetricsBtn", "Copy",
3445	                UiBuilder.BgSurface, UiBuilder.TextSecondary,
3446	                OnCopyMetricsToClipboard);
3447	            LayoutElement copyLe = copyBtn.gameObject.AddComponent<LayoutElement>();
3448	            copyLe.preferredWidth = 48f;
3449	            copyLe.preferredHeight = 20f;
3450	
3451	            // "Refresh" button (manual trigger)
3452	            Button refreshBtn = UiBuilder.MakeButton(
3453	                headerRow.transform, "RefreshMetricsBtn", "↺",
3454	                UiBuilder.BgSurface, UiBuilder.TextSecondary,
3455	                RefreshTelemetryText);
3456	            LayoutElement refreshLe = refreshBtn.gameObject.AddComponent<LayoutElement>();
3457	            refreshLe.preferredWidth = 24f;
3458	            refreshLe.preferredHeight = 20f;
3459	
3460	            // Text area for metrics dump
3461	            _telemetryText = UiBuilder.MakeText(parent, "TelemetryText",
3462	                "(no metrics yet)", 10, new Color(0.65f, 0.75f, 0.65f, 1f));
3463	            LayoutElement textLe = _telemetryText.gameObject.AddComponent<LayoutElement>();
3464	            textLe.preferredHeight = 120f;
3465	            textLe.flexibleWidth = 1f;
3466	            _telemetryText.verticalOverflow = VerticalWrapMode.Overflow;
3467	            _telemetryText.alignment = TextAnchor.UpperLeft;
3468	
3469	            // Populate immediately
3470	            RefreshTelemetryText();
3471	
3472	            // Start the 2-second auto-refresh coroutine
3473	            if (_telemetryRefreshCoroutine != null)
3474	                StopCoroutine(_telemetryRefreshCoroutine);
3475	            _telemetryRefreshCoroutine = StartCoroutine(TelemetryAutoRefreshCoroutine());
3476	        }
3477	
3478	        /// <summary>Updates the telemetry text with the latest <see cref="MetricsCollector.Instance.DumpMarkdown"/> output.</summary>
3479	        private void RefreshTelemetryText()
3480	        {
3481	            if (_telemetryText == null) return;
3482	            try
3483	            {
3484	                string md = MetricsCollector.Instance.DumpMarkdown();
3485	                _telemetryText.text = string.IsNullOrWhiteSpace(md) ? "(no metrics recorded yet)" : md;
3486	            }
3487	            catch (Exception ex)
3488	            {
3489	                // best-effort: telemetry display must never crash the UI
3490	                if (_telemetryText != null)
3491	                    _telemetryText.text = $"(metrics error: {ex.Message})";
3492	            }
3493	        }
3494	
3495	        /// <summary>Copies the current metrics dump to the system clipboard.</summary>
3496	        private void OnCopyMetricsToClipboard()
3497	        {
3498	            try
3499	            {
3500	                string md = MetricsCollector.Instance.DumpMarkdown();
3501	                GUIUtility.systemCopyBuffer = string.IsNullOrWhiteSpace(md) ? "(no metrics)" : md;
3502	            }
3503	            catch (Exception ex)
3504	            {
3505	                // best-effort
3506	                System.Diagnostics.Debug.WriteLine($"ModMenuPanel metrics clipboard copy failed: {ex.Message}");
3507	            }
3508	        }
3509	
3510	        /// <summary>Coroutine: refreshes the telemetry text every <see cref="TelemetryRefreshIntervalSec"/> seconds.</summary>
3511	        private IEnumerator TelemetryAutoRefreshCoroutine()
3512	        {
3513	            while (true)
3514	            {
3515	                yield return new WaitForSeconds(TelemetryRefreshIntervalSec);
3516	                RefreshTelemetryText();
3517	            }
3518	        }
