2214	        /// <summary>Opens the diff modal populated with pack.yaml content for both packs.</summary>
2215	        private void OpenDiffModal(string selfPackId, string otherPackId, string overlapSummary)
2216	        {
2217	            if (_diffModal == null || _diffModalTitle == null ||
2218	                _diffLeftText == null || _diffRightText == null) return;
2219	
2220	            _diffModalTitle.text = "Diff: " + selfPackId + "  vs  " + otherPackId;
2221	            _diffLeftText.text = LoadPackYamlPreview(selfPackId, overlapSummary);
