237:                if (resolvedTargetGraphic == null)
238:                {
239:                    // Fallback: prefer the native painterly background image from the clone.
240:                    resolvedTargetGraphic = FindPreferredButtonGraphic(target.transform);
241:                }
242:
243:                if (resolvedTargetGraphic is Image resolvedImage && donor.targetGraphic is Image donorImage)
244:                {
245:                    resolvedImage.sprite = donorImage.sprite;
246:                    resolvedImage.type = donorImage.type;
247:                    resolvedImage.color = donorImage.color;
248:                    resolvedImage.material = donorImage.material;
249:                    // #970b: carry the custom-shader frame's PPU + aspect so a sliced native
250:                    // frame renders identically on the clone.
251:                    resolvedImage.pixelsPerUnitMultiplier = donorImage.pixelsPerUnitMultiplier;
252:                    resolvedImage.preserveAspect = donorImage.preserveAspect;
253:                    resolvedImage.raycastTarget = true;
254:                }
