+    println!("output_tail:");
+    let data = fs::read_to_string(&job.output_path).unwrap_or_else(|_| String::new());
+    let lines: Vec<&str> = data.lines().collect();
+    let start = lines.len().saturating_sub(tail);
+    for line in &lines[start..] {
+        println!("{}", line);
+    }
