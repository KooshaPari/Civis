2682	        private void OnToggleSelected()
2683	        {
2684	            int index = _presenter.SelectedIndex;
2685	            if (!_presenter.IsValidIndex(index)) return;
2686	
2687	            PackDisplayInfo current = _presenter.Packs[index];
2688	
2689	            // Only prompt when the user is enabling (not disabling) a pack.
2690	            if (!current.IsEnabled)
2691	            {
2692	                List<string> missingDeps = CollectMissingDeps(current);
2693	                if (missingDeps.Count > 0 && _canvasRoot != null)
2694	                {
2695	                    // Show the dependency dialog; defer the actual enable until the user confirms.
2696	                    DepEnableDialog.Show(
2697	                        _canvasRoot,
2698	                        current.Name,
2699	                        missingDeps,
2700	                        onEnableAll: () =>
2701	                        {
2702	                            // Enable each missing dependency first, then the target pack.
2703	                            foreach (string depId in missingDeps)
2704	                            {
2705	                                int depIdx = FindPackIndexById(depId);
2706	                                if (depIdx < 0) continue;
2707	                                if (!_presenter.TryToggleEnabled(depIdx, out PackDisplayInfo depUpdated)) continue;
2708	                                OnPackToggled?.Invoke(depUpdated.Id, depUpdated.IsEnabled);
2709	                            }
2710	
2711	                            // Now enable the originally-selected pack.
2712	                            if (_presenter.TryToggleEnabled(index, out PackDisplayInfo updated))
2713	                            {
2714	                                ClearCurrentSelection();
2715	                                OnPackToggled?.Invoke(updated.Id, updated.IsEnabled);
2716	                                QueueListRefresh();
2717	                            }
2718	                        },
2719	                        onCancel: () =>
2720	                        {
2721	                            // Nothing to do — toggle was not applied.
2722	                            _log?.LogInfo($"[ModMenuPanel] Dependency prompt cancelled for pack '{current.Id}'.");
2723	                        });
2724	                    return; // Dialog is showing; do not proceed with the toggle now.
2725	                }
2726	            }
2727	
2728	            // No missing deps (or disabling) — apply the toggle immediately.
2729	            if (!_presenter.TryToggleEnabled(index, out PackDisplayInfo immediateUpdated)) return;
2730	
2731	            ClearCurrentSelection();
2732	            OnPackToggled?.Invoke(immediateUpdated.Id, immediateUpdated.IsEnabled);
2733	            QueueListRefresh();
2734	        }
2735	
2736	        /// <summary>
2737	        /// Returns the IDs of dependencies that are declared by <paramref name="pack"/>
2738	        /// but are currently disabled (or not present) in the presenter pack list.
2739	        /// </summary>
2740	        private List<string> CollectMissingDeps(PackDisplayInfo pack)
2741	        {
2742	            List<string> missing = new List<string>();
2743	            foreach (string depId in pack.Dependencies)
2744	            {
2745	                bool depEnabled = false;
2746	                foreach (PackDisplayInfo p in _presenter.Packs)
2747	                {
2748	                    if (string.Equals(p.Id, depId, StringComparison.Ordinal) && p.IsEnabled)
2749	                    {
2750	                        depEnabled = true;
2751	                        break;
2752	                    }
2753	                }
2754	                if (!depEnabled) missing.Add(depId);
2755	            }
2756	            return missing;
2757	        }
2758	
2759	        /// <summary>Returns the presenter index of the pack with <paramref name="packId"/>, or -1.</summary>
2760	        private int FindPackIndexById(string packId)
2761	        {
2762	            for (int i = 0; i < _presenter.Packs.Count; i++)
2763	            {
2764	                if (string.Equals(_presenter.Packs[i].Id, packId, StringComparison.Ordinal))
2765	                    return i;
2766	            }
2767	            return -1;
2768	        }
