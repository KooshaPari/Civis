282:        /// Picks the most plausible background graphic from a cloned button hierarchy:
283:        /// a child Image named "*background*" if present, else the first Image that has a sprite.
284:        /// </summary>
285:        private static Image? FindPreferredButtonGraphic(Transform root)
286:        {
287:            if (root == null) return null;
