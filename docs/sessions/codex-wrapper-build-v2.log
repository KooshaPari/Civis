198:fn run_attempt(job: &mut Job, hang_seconds: u64) -> Attempt {
199:    let cwd = std::path::Path::new(&job.cwd).to_path_buf();
200:    let mut cmd = if is_composer(&job.model) {
201:        let mut c = Command::new("composer");
202:        c.arg("--model")
203:            .arg(&job.model)
204:            .arg(&job.prompt)
205:            .current_dir(cwd);
206:        c
207:    } else {
208:        let mut c = Command::new("codex");
209:        c.arg("-m").arg(&job.model).arg(&job.prompt).current_dir(cwd);
210:        c.stdin(Stdio::null());
211:        c
212:    };
213:    cmd.stdout(Stdio::piped());
214:    cmd.stderr(Stdio::piped());
