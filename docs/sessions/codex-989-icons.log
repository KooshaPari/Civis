653	        private void BuildListPane(Transform parent)
654	        {
655	            _log?.LogInfo("[ModMenuPanel.BuildListPane] Starting pack list pane construction...");
656	
657	            GameObject pane = new GameObject("ListPane", typeof(RectTransform));
658	            pane.transform.SetParent(parent, false);
659	
660	            LayoutElement paneLe = pane.AddComponent<LayoutElement>();
661	            paneLe.preferredWidth = ListWidth;
662	            paneLe.minWidth = ListWidth;
663	            paneLe.flexibleHeight = 1f;  // CRITICAL: Allow ListPane to expand to fill parent height!
664	
665	            VerticalLayoutGroup paneLayout = pane.AddComponent<VerticalLayoutGroup>();
666	            paneLayout.childForceExpandWidth = true;
667	            paneLayout.childForceExpandHeight = false;
668	            paneLayout.childControlWidth = true;
669	            // Fix (iter-149): must control child height so the pack-list scroll's
670	            // LayoutElement.flexibleHeight=1 is honored. With childControlHeight=false the
671	            // scroll got zero allocated height → the pack rows rendered off-viewport
672	            // (list appeared empty even though "N of M" counter was correct).
673	            paneLayout.childControlHeight = true;
674	            paneLayout.childAlignment = TextAnchor.UpperLeft;
675	            paneLayout.spacing = 0f;
676	            paneLayout.padding = new RectOffset(0, 0, 0, 0);
677	
678	            // List header
679	            GameObject listHeader = UiBuilder.MakePanel(pane.transform, "ListHeader",
680	                UiBuilder.BgSurface, new Vector2(ListWidth, 32f));
681	            RectTransform lhRt = listHeader.GetComponent<RectTransform>();
682	            lhRt.anchorMin = new Vector2(0f, 1f);
683	            lhRt.anchorMax = new Vector2(1f, 1f);
684	            lhRt.pivot = new Vector2(0.5f, 1f);
685	            lhRt.sizeDelta = new Vector2(0f, 32f);
686	
687	            UiBuilder.AddHorizontalLayout(listHeader, 4f, new RectOffset(8, 8, 6, 6));
688	            Text lhTitle = UiBuilder.MakeText(listHeader.transform, "ListTitle",
689	                "Loaded Packs", 12, UiBuilder.TextSecondary, bold: false);
690	            LayoutElement lhTitleLe = lhTitle.gameObject.AddComponent<LayoutElement>();
691	            lhTitleLe.flexibleWidth = 1f;
692	            LayoutElement listHeaderLe = listHeader.AddComponent<LayoutElement>();
693	            listHeaderLe.preferredWidth = ListWidth;
694	            listHeaderLe.minWidth = ListWidth;
695	            listHeaderLe.preferredHeight = 32f;
696	
697	            // Build filter controls
698	            BuildListFilters(pane.transform);
699	
700	            // Scroll view for pack items
701	            _log?.LogInfo("[ModMenuPanel.BuildListPane] Creating scroll view...");
702	            (ScrollRect scrollRect, RectTransform content) = UiBuilder.MakeScrollView(
703	                pane.transform, "PackListScroll",
704	                new Vector2(ListWidth, 0f));
705	
706	            // Validate the result
707	            if (content == null || scrollRect == null)
708	            {
709	                _log?.LogError("[ModMenuPanel.BuildListPane] CRITICAL: MakeScrollView failed! " +
710	                    $"scrollRect={scrollRect != null}, content={content != null}. " +
711	                    "Pack list will not render. Check UiBuilder.MakeScrollView for exceptions.");
712	                _listContent = null;
713	                return;
714	            }
715	
716	            // Fix #944/B1: Do NOT override offsetMin/Max with absolute values here.
717	            // The ListPane uses a VerticalLayoutGroup (header 32px + FilterContainer ~240px +
718	            // scroll). Manually setting offsetMax to -32px collapses the scroll rect behind the
719	            // filter bar. Let the LayoutGroup manage positions via LayoutElement.flexibleHeight.
720	            RectTransform scrollRt = scrollRect.GetComponent<RectTransform>();
721	            LayoutElement scrollLe = scrollRect.gameObject.AddComponent<LayoutElement>();
722	            scrollLe.preferredWidth = ListWidth;
723	            scrollLe.minWidth = ListWidth;
724	            scrollLe.flexibleHeight = 1f;  // fills remaining space below filter container
725	
726	            content.SetSizeWithCurrentAnchors(RectTransform.Axis.Horizontal, ListWidth);
727	            content.sizeDelta = new Vector2(ListWidth, content.sizeDelta.y);
728	
729	            _listContent = content;
730	            _listScrollRect = scrollRect;
731	            _log?.LogInfo($"[ModMenuPanel.BuildListPane] Scroll view initialized successfully.");
732	            _log?.LogInfo($"  scrollRt.rect.size={scrollRt.rect.size} (viewport visible area)");
733	            _log?.LogInfo($"  scrollRt.sizeDelta={scrollRt.sizeDelta}, anchorMin={scrollRt.anchorMin}, anchorMax={scrollRt.anchorMax}");
734	            _log?.LogInfo($"  content.name={content.name}");
735	            _log?.LogInfo($"  content.active={content.gameObject.activeSelf}");
736	            _log?.LogInfo($"  content.anchorMin={content.anchorMin}, anchorMax={content.anchorMax}");
737	            _log?.LogInfo($"  content.sizeDelta={content.sizeDelta}");
738	            _log?.LogInfo($"  content.anchoredPosition={content.anchoredPosition}");
739	            _log?.LogInfo($"  ScrollRect component on: {scrollRect.name}");
740	            _log?.LogInfo($"  ScrollRect.content set to: {scrollRect.content?.name ?? "NULL"}");
741	            _log?.LogInfo($"  ScrollRect.vertical={scrollRect.vertical}");
742	            _log?.LogInfo($"  ScrollRect.enabled={scrollRect.enabled}");
743	            Image viewportImage = scrollRect.GetComponent<Image>();
744	            _log?.LogInfo($"  Viewport Image: exists={viewportImage != null}, raycastTarget={viewportImage?.raycastTarget}");
745	
746	            // Verify components on content
747	            ContentSizeFitter csf = content.GetComponent<ContentSizeFitter>();
748	            VerticalLayoutGroup vlg = content.GetComponent<VerticalLayoutGroup>();
749	            _log?.LogInfo($"  content has ContentSizeFitter: {csf != null} (verticalFit={csf?.verticalFit})");
750	            _log?.LogInfo($"  content has VerticalLayoutGroup: {vlg != null} (childForceExpandHeight={vlg?.childForceExpandHeight}, spacing={vlg?.spacing})");
751	        }
