1598:        /// <summary>
1599:        /// Mirrors source button selectable and label style onto the injected Mods button.
1600:        /// Keeps hover/pressed visuals aligned with the native menu skin.
1601:        /// </summary>
1602:        private void SyncButtonVisualStyle(Button target, Button source, long attemptId)
1603:        {
1604:            target.transition = source.transition;
1605:            target.colors = source.colors;
1606:            target.spriteState = source.spriteState;
1607:            target.animationTriggers = source.animationTriggers;
1608:
1609:            Image? sourceImage = source.targetGraphic as Image;
1610:            Graphic? resolvedTargetGraphic = null;
1611:            if (source.targetGraphic != null)
1612:            {
1613:                string path = GetRelativePath(source.targetGraphic.transform, source.transform);
1614:                Transform? matching = string.IsNullOrEmpty(path) ? target.transform : target.transform.Find(path);
1615:                resolvedTargetGraphic = matching?.GetComponent(source.targetGraphic.GetType()) as Graphic;
1616:            }
1617:
1618:            // Fallback: prefer the native painterly background image from the clone hierarchy.
1619:            if (resolvedTargetGraphic == null)
1620:            {
1621:                resolvedTargetGraphic = FindPreferredButtonGraphic(target.transform);
1622:                if (resolvedTargetGraphic != null)
1623:                {
1624:                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Applied targetGraphic fallback to '{resolvedTargetGraphic.name}'");
1625:                }
1626:            }
1627:
1628:            if (resolvedTargetGraphic is Image resolvedImage && sourceImage != null)
1629:            {
1630:                CopyImageVisualStyle(resolvedImage, sourceImage);
1631:            }
1632:
1633:            target.targetGraphic = resolvedTargetGraphic;
1634:            if (target.targetGraphic is Image tgImg) tgImg.raycastTarget = true;
1635:
1636:            // #1 fix: copying source.transition above can re-apply Transition.None (DINO defers
1637:            // hover/press to its custom MainMenuButton script). Guarantee the injected button
1638:            // still renders interaction state by forcing a visible ColorTint transition when the
1639:            // copied transition was None. No-op when the donor had a real ColorTint/SpriteSwap.
1640:            NativeUiHelper.EnsureVisibleTransition(target);
1641:            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Visual transition after sync: {target.transition} (targetGraphic={(target.targetGraphic != null ? target.targetGraphic.name : "NULL")})");
1642:
1643:            Text? sourceText = source.GetComponentInChildren<Text>(includeInactive: true);
1644:            Text? targetText = target.GetComponentInChildren<Text>(includeInactive: true);
1645:            if (sourceText != null && targetText != null)
1646:            {
1647:                targetText.font = sourceText.font;
1648:                targetText.fontStyle = sourceText.fontStyle;
1649:                targetText.fontSize = sourceText.fontSize;
1650:                targetText.color = sourceText.color;
1651:                targetText.alignment = sourceText.alignment;
1652:                targetText.material = sourceText.material;
1653:            }
1654:
1655:            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Synced native button visual style");
1656:        }
1657:
1658:        private static Image? FindPreferredButtonGraphic(Transform root)
1659:        {
1660:            if (root == null)
1661:            {
1662:                return null;
1663:            }
1664:
1665:            Image? firstSpriteImage = null;
1666:            Image[] images = root.GetComponentsInChildren<Image>(includeInactive: true);
1667:            foreach (Image image in images)
1668:            {
1669:                if (image == null)
1670:                {
1671:                    continue;
1672:                }
1673:
1674:                if (image.sprite != null && firstSpriteImage == null)
1675:                {
1676:                    firstSpriteImage = image;
1677:                }
1678:
1679:                string imageName = image.name;
1680:                if (imageName.IndexOf("background", StringComparison.OrdinalIgnoreCase) >= 0)
1681:                {
1682:                    return image;
1683:                }
1684:            }
1685:
1686:            return firstSpriteImage;
1687:        }
1688:
1689:        private static void CopyImageVisualStyle(Image target, Image source)
1690:        {
1691:            if (target == null || source == null)
1692:            {
1693:                return;
1694:            }
1695:
1696:            target.sprite = source.sprite;
1697:            target.type = source.type;
1698:            target.color = source.color;
1699:            // #R1: carry the donor's material so a custom-shader native frame keeps its
1700:            // hover/press shading on the clone (was dropped → button read as non-reactive).
1701:            target.material = source.material;
1702:            target.pixelsPerUnitMultiplier = source.pixelsPerUnitMultiplier;
1703:            target.preserveAspect = source.preserveAspect;
1704:        }
1705:
1706:        private static string GetRelativePath(Transform node, Transform root)
1707:        {
1708:            if (node == root) return string.Empty;
1709:
1710:            System.Collections.Generic.Stack<string> parts = new System.Collections.Generic.Stack<string>();
1711:            Transform? current = node;
1712:            while (current != null && current != root)
1713:            {
1714:                parts.Push(current.name);
1715:                current = current.parent;
1716:            }
1717:
1718:            return string.Join("/", parts.ToArray());
1719:        }
