                catch (Exception ex)
                {
                    _log.LogWarning($"[RuntimeDriver] UiAssets initialization failed: {ex}");
                }
            });
            yield return null;

            RunPhaseWithAbortGuard("ModPlatform.Initialize", () =>
            {
                try
