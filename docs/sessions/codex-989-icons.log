2938	        private string BuildStatusLine()
2939	        {
2940	            string errPart = _presenter.ErrorCount > 0 ? $"  {_presenter.ErrorCount} errors" : "";
2941	            int totalContent = 0;
2942	            int enabledCount = 0;
2943	            foreach (PackDisplayInfo pack in _presenter.Packs)
2944	            {
2945	                if (!pack.IsEnabled) continue;
2946	                enabledCount++;
2947	                foreach (System.Collections.Generic.KeyValuePair<string, int> kv in pack.ContentSummary)
2948	                    totalContent += kv.Value;
2949	            }
2950	            string contentPart = totalContent > 0 ? $"  ({totalContent} content files)" : "";
2951	            return $"{enabledCount}/{_presenter.Packs.Count} packs active{errPart}{contentPart}";
2952	        }
