382	        /// </summary>
383	        /// <param name="btn">Button whose label should be changed.</param>
384	        /// <param name="text">New label text.</param>
385	        public static void SetButtonText(Button btn, string text)
386	        {
387	            if (btn == null) return;
388	
389	            // Try legacy UnityEngine.UI.Text first
390	            UnityEngine.UI.Text? legacyText = btn.GetComponentInChildren<UnityEngine.UI.Text>();
391	            if (legacyText != null)
392	            {
393	                legacyText.text = text;
394	                return;
395	            }
396	
397	            // Try TMPro via reflection (avoids a hard dependency on the TMPro assembly)
398	            TrySetTmpText(btn.gameObject, text);
399	        }
400	
401	        /// <summary>
402	        /// Returns the visible label text from a button, preferring TMPro over legacy Text.
403	        /// Returns an empty string if no text component is found.
404	        /// </summary>
405	        /// <param name="btn">Button to read the label from.</param>
406	        public static string GetButtonText(Button btn)
407	        {
408	            if (btn == null) return string.Empty;
409	
410	            UnityEngine.UI.Text? legacyText = btn.GetComponentInChildren<UnityEngine.UI.Text>();
411	            if (legacyText != null) return legacyText.text ?? string.Empty;
412	
413	            return TryGetTmpText(btn.gameObject) ?? string.Empty;
414	        }
415	
416	        // ------------------------------------------------------------------ //
417	        // TMPro helpers — done via reflection so we don't hard-depend on TMPro.
418	        // ------------------------------------------------------------------ //
419	
420	        private static void TrySetTmpText(GameObject root, string text)
421	        {
422	            try
423	            {
424	                // TMP_Text is the base class for both TextMeshPro and TextMeshProUGUI
425	                Type? tmpType = Type.GetType("TMPro.TMP_Text, Unity.TextMeshPro")
426	                             ?? Type.GetType("TMPro.TMP_Text, Assembly-CSharp");
427	
428	                if (tmpType == null) return;
429	
430	                Component? tmp = root.GetComponentInChildren(tmpType);
431	                if (tmp == null) return;
432	
433	                System.Reflection.PropertyInfo? prop = tmpType.GetProperty("text");
434	                prop?.SetValue(tmp, text);
435	            }
436	            catch { /* safe-swallow: TMPro reflection is optional and best-effort */ }
437	        }
438	
439	        private static string? TryGetTmpText(GameObject root)
440	        {
441	            try
442	            {
443	                Type? tmpType = Type.GetType("TMPro.TMP_Text, Unity.TextMeshPro")
444	                             ?? Type.GetType("TMPro.TMP_Text, Assembly-CSharp");
445	
446	                if (tmpType == null) return null;
447	
448	                Component? tmp = root.GetComponentInChildren(tmpType);
449	                if (tmp == null) return null;
450	
451	                System.Reflection.PropertyInfo? prop = tmpType.GetProperty("text");
452	                return prop?.GetValue(tmp) as string;
453	            }
454	            catch (System.Reflection.TargetInvocationException ex)
455	            {
456	                // Pattern #104 (Task #302): narrow catch to expected reflection failures only.
457	                // PropertyInfo.GetValue wraps the underlying exception in TargetInvocationException;
458	                // TypeLoadException/MissingMethodException occur when TMPro is wrong version.
459	                // Unexpected exceptions now propagate so caller can diagnose.
460	                System.Diagnostics.Debug.WriteLine($"[NativeUiHelper] TryGetTmpText reflection failed: {ex.InnerException ?? (Exception)ex}");
461	                return null;
462	            }
463	            catch (TypeLoadException ex)
464	            {
465	                System.Diagnostics.Debug.WriteLine($"[NativeUiHelper] TryGetTmpText TMPro type load failed: {ex}");
466	                return null;
467	            }
468	            catch (MissingMethodException ex)
469	            {
470	                System.Diagnostics.Debug.WriteLine($"[NativeUiHelper] TryGetTmpText TMPro API mismatch: {ex}");
471	                return null;
472	            }
473	        }
474	    }
475	}

