1421	        /// <summary>Applies all filters and sorts the pack list, rebuilding the UI.</summary>
1422	        private void ApplyFilters()
1423	        {
1424	            _filteredIndices.Clear();
1425	
1426	            // Fix #944/B3: use dropdown VALUE (index) to compare filters, NOT localized option text.
1427	            // Comparing against "All"/"Engine Extension"/etc. breaks once i18n renames the labels
1428	            // (e.g. "All Tiers" in some locales). Index 0 always means "no filter" regardless of locale.
1429	            int tierIndex = _tierDropdown != null ? _tierDropdown.value : 0;
1430	            int stateIndex = _stateDropdown != null ? _stateDropdown.value : 0;
1431	
1432	            for (int i = 0; i < _presenter.Packs.Count; i++)
1433	            {
1434	                PackDisplayInfo pack = _presenter.Packs[i];
1435	
1436	                // Search filter
1437	                if (!string.IsNullOrWhiteSpace(_searchText))
1438	                {
1439	                    string searchLower = _searchText.ToLowerInvariant();
1440	                    if (!pack.Name.ToLowerInvariant().Contains(searchLower) &&
1441	                        !pack.Id.ToLowerInvariant().Contains(searchLower))
1442	                    {
1443	                        continue;
1444	                    }
1445	                }
1446	
1447	                // Tier filter (index 0 = All; 1 = Engine Extension, 2 = Content, 3 = Total Conversion, 4 = Baseline)
1448	                if (tierIndex != 0)
1449	                {
1450	                    bool matches = false;
1451	                    if (tierIndex == 1 && pack.Classification == "engine_extension") matches = true;
1452	                    if (tierIndex == 2 && pack.Classification == "content") matches = true;
1453	                    if (tierIndex == 3 && pack.Classification == "total_conversion") matches = true;
1454	                    if (tierIndex == 4 && pack.Classification == "baseline") matches = true;
1455	                    if (!matches) continue;
1456	                }
1457	
1458	                // State filter (index 0 = All; 1 = Enabled, 2 = Disabled, 3 = Has Errors)
1459	                if (stateIndex != 0)
1460	                {
1461	                    bool matches = false;
1462	                    if (stateIndex == 1 && pack.IsEnabled) matches = true;
1463	                    if (stateIndex == 2 && !pack.IsEnabled) matches = true;
1464	                    if (stateIndex == 3 && pack.Errors.Count > 0) matches = true;
1465	                    if (!matches) continue;
1466	                }
1467	
1468	                _filteredIndices.Add(i);
1469	            }
1470	
1471	            // Apply sorting
1472	            ApplySorting();
1473	
1474	            // Update counter
1475	            if (_listCounterText != null)
1476	            {
1477	                _listCounterText.text = $"{_filteredIndices.Count} of {_presenter.Packs.Count}";
1478	            }
1479	
1480	            // Rebuild the filtered list
1481	            RebuildFilteredPackList();
1482	        }
1483	
1484	        /// <summary>Sorts the filtered pack indices according to the current sort selection.</summary>
1485	        private void ApplySorting()
1486	        {
1487	            if (_sortBy == "Type")
1488	            {
1489	                _filteredIndices.Sort((a, b) =>
1490	                    _presenter.Packs[a].Type.CompareTo(_presenter.Packs[b].Type));
1491	            }
1492	            else if (_sortBy == "Version")
1493	            {
1494	                // Simple string version sort (not semver)
1495	                _filteredIndices.Sort((a, b) =>
1496	                    _presenter.Packs[a].Version.CompareTo(_presenter.Packs[b].Version));
1497	            }
1498	            else // Name (default)
1499	            {
1500	                _filteredIndices.Sort((a, b) =>
1501	                    _presenter.Packs[a].Name.CompareTo(_presenter.Packs[b].Name));
1502	            }
1503	        }
1504	
1505	        /// <summary>Renders only the filtered packs into the scroll list.</summary>
1506	        private void RebuildFilteredPackList()
1507	        {
1508	            if (_listContent == null) return;
1509	
1510	            // Clear existing items
1511	            for (int i = _listContent.childCount - 1; i >= 0; i--)
1512	            {
1513	                Transform child = _listContent.GetChild(i);
1514	                child.SetParent(null, false);
1515	                Destroy(child.gameObject);
1516	            }
1517	
1518	            // Render filtered items
1519	            for (int displayIndex = 0; displayIndex < _filteredIndices.Count; displayIndex++)
1520	            {
1521	                int realIndex = _filteredIndices[displayIndex];
1522	                BuildPackListItem(_presenter.Packs[realIndex], realIndex);
1523	            }
1524	
1525	            // Update content height
1526	            float padding_top = 4f, padding_bottom = 4f, spacing = 2f, itemHeight = 40f;
1527	            float calculatedHeight = padding_top + (_filteredIndices.Count * itemHeight) +
1528	                                      (Mathf.Max(0, _filteredIndices.Count - 1) * spacing) + padding_bottom;
1529	            _listContent.sizeDelta = new Vector2(_listContent.sizeDelta.x, calculatedHeight);
1530	
1531	            UnityEngine.UI.LayoutRebuilder.ForceRebuildLayoutImmediate(_listContent);
1532	
1533	            // Fix (iter-149): DINO never runs ScrollRect.LateUpdate, so pin the freshly
1534	            // built list back to the top of the viewport (otherwise a stale clamp can leave
1535	            // the rows scrolled out of view).
1536	            if (_listScrollRect != null)
1537	                _listScrollRect.verticalNormalizedPosition = 1f;
1538	        }
1539	
1540	        private void BuildPackListItem(PackDisplayInfo pack, int index)
1541	        {
1542	            if (_listContent == null)
1543	            {
1544	                _log?.LogWarning($"[ModMenuPanel.BuildPackListItem] _listContent is NULL for pack '{pack.Id}' — item {index} skipped.");
1545	                return;
1546	            }
1547	
1548	            _log?.LogInfo($"[ModMenuPanel.BuildPackListItem] Starting item {index}: '{pack.Name}' (enabled={pack.IsEnabled}, selected={index == _presenter.SelectedIndex})");
1549	
1550	            bool isSelected = index == _presenter.SelectedIndex;
1551	            bool hasErrors = pack.Errors.Count > 0;
1552	            bool hasConflicts = pack.Conflicts.Count > 0;
1553	
1554	            // Zebra striping: alternate row colors
1555	            // Even rows (#1A1F2E) / Odd rows (#1F2536)
1556	            bool isEvenRow = index % 2 == 0;
1557	            Color bgColor = isSelected ? UiBuilder.BgSurface : (isEvenRow ? HexColor("#1A1F2E") : HexColor("#1F2536"));
1558	            Color alpha = pack.IsEnabled ? Color.white : new Color(1f, 1f, 1f, 0.6f);
1559	
1560	            GameObject card = UiBuilder.MakePanel(_listContent, $"PackItem_{pack.Id}", bgColor, new Vector2(0f, ItemHeight));
1561	            RectTransform cardRt = card.GetComponent<RectTransform>();
1562	            cardRt.SetSizeWithCurrentAnchors(RectTransform.Axis.Horizontal, ListWidth - 8f);
1563	            cardRt.sizeDelta = new Vector2(ListWidth - 8f, ItemHeight);
1564	            _log?.LogInfo($"[ModMenuPanel.BuildPackListItem] Item {index} card created: sizeDelta={cardRt.sizeDelta}, active={card.activeSelf}");
1565	
1566	            LayoutElement cardLe = card.AddComponent<LayoutElement>();
1567	            cardLe.minWidth = ListWidth - 8f;
1568	            cardLe.preferredWidth = ListWidth - 8f;
1569	            cardLe.minHeight = ItemHeight;
1570	            cardLe.preferredHeight = ItemHeight;
1571	            cardLe.flexibleWidth = 1f;
1572	            _log?.LogInfo($"[ModMenuPanel.BuildPackListItem] Item {index} LayoutElement set: minHeight={cardLe.minHeight}, preferredHeight={cardLe.preferredHeight}");
1573	
1574	            // Content layout with improved spacing (8px padding, 4px rows)
1575	            HorizontalLayoutGroup hlg = card.AddComponent<HorizontalLayoutGroup>();
1576	            hlg.spacing = 6f;
1577	            hlg.padding = new RectOffset(8, 8, 4, 4);
1578	            hlg.childForceExpandWidth = false;
1579	            hlg.childForceExpandHeight = true;
1580	            hlg.childControlWidth = true;
1581	            hlg.childControlHeight = true;
1582	
1583	            // Status indicator dot (green=enabled, red=error, yellow=conflict)
1584	            Color dotColor = hasErrors ? UiBuilder.Error : (hasConflicts ? UiBuilder.Warning : (pack.IsEnabled ? UiBuilder.Success : new Color(0.5f, 0.5f, 0.5f, 1f)));
1585	            GameObject dotGo = UiBuilder.MakePanel(card.transform, "StatusDot", dotColor, new Vector2(8f, 8f));
1586	            RectTransform dotRt = dotGo.GetComponent<RectTransform>();
1587	            LayoutElement dotLe = dotGo.AddComponent<LayoutElement>();
1588	            dotLe.preferredWidth = 8f;
1589	            dotLe.preferredHeight = 8f;
1590	            dotLe.minWidth = 8f;
1591	            dotLe.minHeight = 8f;
1592	
1593	            // Pack name
1594	            Color nameColor = pack.IsEnabled ? UiBuilder.TextPrimary : UiBuilder.TextSecondary;
1595	            Text nameText = UiBuilder.MakeText(card.transform, "PackName", pack.Name, 13,
1596	                nameColor, bold: isSelected);
1597	            RectTransform nameTextRt = nameText.GetComponent<RectTransform>();
1598	            _log?.LogInfo($"[ModMenuPanel.BuildPackListItem] Item {index} nameText created: text='{pack.Name}', fontSize={nameText.fontSize}, color={nameColor}, sizeDelta={nameTextRt.sizeDelta}, font={nameText.font?.name}");
1599	
1600	            if (!pack.IsEnabled)
1601	            {
1602	                nameText.color = new Color(nameColor.r, nameColor.g, nameColor.b, 0.6f);
1603	            }
1604	            LayoutElement nameLe = nameText.gameObject.AddComponent<LayoutElement>();
1605	            nameLe.minWidth = 100f;
1606	            nameLe.flexibleWidth = 1f;
1607	            nameLe.minHeight = 16f;
1608	            nameLe.preferredHeight = ItemHeight - 8f;
1609	            _log?.LogInfo($"[ModMenuPanel.BuildPackListItem] Item {index} nameText LayoutElement: minWidth={nameLe.minWidth}, flexibleWidth={nameLe.flexibleWidth}, minHeight={nameLe.minHeight}");
1610	
1611	            // Error / Conflict badge
1612	            if (hasErrors)
1613	            {
1614	                GameObject badge = UiBuilder.MakePanel(card.transform, "ErrorBadge",
1615	                    UiBuilder.Error, new Vector2(32f, 18f));
1616	                LayoutElement badgeLe = badge.AddComponent<LayoutElement>();
1617	                badgeLe.preferredWidth = 32f;
1618	                badgeLe.preferredHeight = 18f;
1619	
1620	                Text badgeText = UiBuilder.MakeText(badge.transform, "BadgeText", "ERR",
1621	                    10, Color.white, bold: true, TextAnchor.MiddleCenter);
1622	                UiBuilder.FillParent(badgeText.GetComponent<RectTransform>());
1623	            }
1624	            else if (hasConflicts)
1625	            {
1626	                GameObject badge = UiBuilder.MakePanel(card.transform, "ConflictBadge",
1627	                    UiBuilder.Warning, new Vector2(40f, 18f));
1628	                LayoutElement badgeLe = badge.AddComponent<LayoutElement>();
1629	                badgeLe.preferredWidth = 40f;
1630	                badgeLe.preferredHeight = 18f;
1631	
1632	                Text badgeText = UiBuilder.MakeText(badge.transform, "BadgeText", "CONF",
1633	                    10, Color.black, bold: true, TextAnchor.MiddleCenter);
1634	                UiBuilder.FillParent(badgeText.GetComponent<RectTransform>());
1635	            }
1636	
1637	            // Version label
1638	            Text versionText = UiBuilder.MakeText(card.transform, "Version",
1639	                $"v{pack.Version}", 11, UiBuilder.TextSecondary);
1640	            LayoutElement verLe = versionText.gameObject.AddComponent<LayoutElement>();
1641	            verLe.preferredWidth = 50f;
1642	            verLe.minWidth = 40f;
1643	            verLe.minHeight = 16f;
1644	
1645	            // Click to select
1646	            int capturedIndex = index;
1647	            Button btn = card.AddComponent<Button>();
1648	            ColorBlock cb = btn.colors;
1649	            cb.normalColor = bgColor;
1650	            // Hover: lighten by ~10%
1651	            cb.highlightedColor = Color.Lerp(bgColor, Color.white, 0.1f);
1652	            cb.pressedColor = Color.Lerp(bgColor, Color.black, 0.15f);
1653	            cb.selectedColor = bgColor;
1654	            cb.colorMultiplier = 1f;
1655	            cb.fadeDuration = 0.05f;
1656	            btn.colors = cb;
1657	            btn.targetGraphic = card.GetComponent<Image>();
1658	            btn.onClick.AddListener(() => SelectPack(capturedIndex));
1659	        }
