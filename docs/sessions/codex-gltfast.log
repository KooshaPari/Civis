+        if (string.IsNullOrWhiteSpace(modelName))
+            return null;
+
+        foreach (string existing in AssetDatabase.FindAssets($"{modelName} t:Model", new[] { "Assets/Models" }))
+        {
+            string path = AssetDatabase.GUIDToAssetPath(existing);
