1668	        private void RefreshDetail()
1669	        {
1670	            PackDisplayInfo? selected = _presenter.SelectedPack;
1671	            if (selected == null)
1672	            {
1673	                if (_detailName != null) _detailName.text = "Select a pack";
1674	                if (_detailMeta != null) _detailMeta.text = "";
1675	                if (_detailLicense != null) _detailLicense.text = "";
1676	                if (_detailDesc != null) _detailDesc.text = "";
1677	                if (_detailDeps != null) _detailDeps.text = "Dependencies: none";
1678	                if (_detailConflicts != null) _detailConflicts.text = "Conflicts: none";
1679	                if (_detailLoadOrder != null) _detailLoadOrder.text = "Load Order: —";
1680	                if (_detailContent != null) _detailContent.text = "Content: (none)";
1681	                if (_detailDetectedConflicts != null) _detailDetectedConflicts.text = "";
1682	                if (_detailTagsRow != null) _detailTagsRow.gameObject.SetActive(false);
1683	                if (_detailLinksRow != null) _detailLinksRow.gameObject.SetActive(false);
1684	                if (_detailGalleryRow != null) _detailGalleryRow.gameObject.SetActive(false);
1685	                if (_detailBadgesRow != null) { UnityEngine.Object.Destroy(_detailBadgesRow); _detailBadgesRow = null; }
1686	                return;
1687	            }
1688	
1689	            PackDisplayInfo p = selected;
1690	
1691	            // ── Name ──────────────────────────────────────────────────────────
1692	            if (_detailName != null) _detailName.text = p.Name;
1693	
1694	            // ── Badges row (#928-935) — rendered above meta for visibility ─────
1695	            RefreshBadgesRow(p);
1696	
1697	            // ── Meta + license badge ──────────────────────────────────────────
1698	            if (_detailMeta != null) _detailMeta.text = $"by {p.Author}  ·  {p.Type}  ·  v{p.Version}";
1699	            if (_detailLicense != null)
1700	            {
1701	                if (!string.IsNullOrEmpty(p.License))
1702	                {
1703	                    _detailLicense.text = $"[{p.License}]";
1704	                    _detailLicense.gameObject.SetActive(true);
1705	                }
1706	                else
1707	                {
1708	                    _detailLicense.text = "";
1709	                    _detailLicense.gameObject.SetActive(false);
1710	                }
1711	            }
1712	
1713	            // ── Tags row ──────────────────────────────────────────────────────
1714	            RefreshTagsRow(p);
1715	
1716	            // ── Description ───────────────────────────────────────────────────
1717	            if (_detailDesc != null)
1718	            {
1719	                string descText = string.IsNullOrEmpty(p.Description)
1720	                    ? "(no description)"
1721	                    : p.Description!;
1722	
1723	                if (p.Errors.Count > 0)
1724	                {
1725	                    descText = descText + "\n\n<color=#e05252>Errors:</color>\n"
1726	                        + string.Join("\n", p.Errors);
1727	                }
1728	
1729	                _detailDesc.text = descText;
1730	            }
1731	
1732	            // ── External links row ────────────────────────────────────────────
1733	            RefreshLinksRow(p);
1734	
1735	            // ── Deps / Conflicts / Load order ─────────────────────────────────
1736	            if (_detailDeps != null)
1737	            {
1738	                _detailDeps.text = p.Dependencies.Count == 0
1739	                    ? "Dependencies: none"
1740	                    : "Dependencies: " + string.Join(", ", p.Dependencies);
1741	            }
1742	
1743	            if (_detailConflicts != null)
1744	            {
1745	                _detailConflicts.text = p.Conflicts.Count == 0
1746	                    ? "Conflicts: none"
1747	                    : "<color=#e8a020>Conflicts: " + string.Join(", ", p.Conflicts) + "</color>";
1748	            }
1749	
1750	            if (_detailLoadOrder != null)
1751	            {
1752	                _detailLoadOrder.text = $"Load Order: {p.LoadOrder}";
1753	            }
1754	
1755	            // ── Rich content section ──────────────────────────────────────────
1756	            if (_detailRichContent != null)
1757	            {
1758	                System.Text.StringBuilder sb = new System.Text.StringBuilder(512);
1759	                if (p.ContentSummary.Count == 0)
1760	                {
1761	                    sb.Append(L10n.T("menu.detail.content", "Content: (none declared)"));
1762	                }
1763	                else
1764	                {
1765	                    sb.Append("<color=#88dd88>Content:</color>\n");
1766	                    foreach (System.Collections.Generic.KeyValuePair<string, int> kv in p.ContentSummary)
1767	                    {
1768	                        string label = kv.Key.Replace('_', ' ');
1769	                        sb.Append($"  {kv.Value} {label}\n");
1770	                    }
1771	
1772	                    // Show first N unit / building / faction names as previews
1773	                    if (p.UnitNames.Count > 0)
1774	                    {
1775	                        int shown = System.Math.Min(5, p.UnitNames.Count);
1776	                        string preview = string.Join(", ", SubList(p.UnitNames, shown));
1777	                        string more = p.UnitNames.Count > shown ? $" and {p.UnitNames.Count - shown} more" : "";
1778	                        sb.Append($"\n<color=#aaddaa>Units: </color>{preview}{more}\n");
1779	                    }
1780	                    if (p.BuildingNames.Count > 0)
1781	                    {
1782	                        int shown = System.Math.Min(3, p.BuildingNames.Count);
1783	                        string preview = string.Join(", ", SubList(p.BuildingNames, shown));
1784	                        string more = p.BuildingNames.Count > shown ? $" and {p.BuildingNames.Count - shown} more" : "";
1785	                        sb.Append($"<color=#aaddaa>Buildings: </color>{preview}{more}\n");
1786	                    }
1787	                    if (p.FactionNames.Count > 0)
1788	                    {
1789	                        string factionList = string.Join(", ", p.FactionNames);
1790	                        sb.Append($"<color=#aaddaa>Factions: </color>{factionList}\n");
1791	                    }
1792	                }
1793	
1794	                _detailRichContent.text = sb.ToString().TrimEnd('\n');
1795	            }
1796	
1797	            // ── Detected conflicts ────────────────────────────────────────────
1798	            if (_detailDetectedConflicts != null)
1799	            {
1800	                if (p.DetectedConflicts.Count == 0)
1801	                {
1802	                    _detailDetectedConflicts.text = "";
1803	                }
1804	                else
1805	                {
1806	                    _detailDetectedConflicts.text = "<color=#e8a020>Content Overlaps:</color>\n"
1807	                        + string.Join("\n", p.DetectedConflicts);
1808	                }
1809	            }
1810	
1811	            // ── Screenshot gallery (lazy-load textures via coroutine) ─────────
1812	            RefreshGallery(p);
1813	
1814	            // ── Conflict resolution buttons (#903) ────────────────────────────
1815	            RefreshConflictButtons(p);
1816	
1817	            // ── Per-pack runtime settings (#925) ───────────────────────────────
1818	            RefreshSettings(p);
1819	
1820	            // ── Toggle button label ───────────────────────────────────────────
1821	            if (_detailPane != null)
1822	            {
1823	                Transform btnRow = _detailPane.transform.Find("ActionButtons");
1824	                if (btnRow != null)
1825	                {
1826	                    Transform toggleBtnT = btnRow.Find("ToggleBtn");
1827	                    if (toggleBtnT != null)
1828	                    {
1829	                        Text? btnLabel = toggleBtnT.Find("Label")?.GetComponent<Text>();
1830	                        if (btnLabel != null)
1831	                            btnLabel.text = p.IsEnabled ? "Disable" : "Enable";
1832	                    }
1833	                }
1834	            }
1835	        }
