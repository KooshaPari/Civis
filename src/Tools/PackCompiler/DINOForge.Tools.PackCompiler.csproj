<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net11.0</TargetFramework>
    <AssemblyName>DINOForge.Tools.PackCompiler</AssemblyName>
    <RootNamespace>DINOForge.Tools.PackCompiler</RootNamespace>
    <Description>CLI tool for validating and bundling DINOForge content packs</Description>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <!-- CS1591: missing XML doc on internal tool types — not a public library API -->
    <!-- CS8892: async Main with System.CommandLine generates AutoGeneratedProgram.Main (expected behavior) -->
    <NoWarn>$(NoWarn);CS1591;CS8892</NoWarn>
    <!-- [#649] Microsoft.NET.Test.Sdk auto-injects an AutoGeneratedProgram.Main that
         redirects to testhost, silently hijacking our Program.Main and producing zero
         stdout for help/version. Setting GenerateProgramFile=false keeps our async
         Task<int> Main as the entry point while still allowing dotnet test to discover
         xUnit fixtures via reflection. -->
    <GenerateProgramFile>false</GenerateProgramFile>
    <IsTestProject>false</IsTestProject>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishTrimmed>true</PublishTrimmed>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifiers>win-x64;linux-x64;linux-arm64;osx-x64;osx-arm64</RuntimeIdentifiers>
  </PropertyGroup>

  <!-- Wrapped dependencies (ADR-008) -->
  <ItemGroup>
    <!-- Pin ILLink to global.json SDK band; avoids NU1004 when CI rollForward resolves a newer SDK. -->
    <PackageReference Include="Microsoft.NET.ILLink.Tasks" Version="11.0.0-preview.2.26159.112" />
    <PackageReference Include="Spectre.Console" Version="0.*" />
    <PackageReference Include="System.CommandLine" Version="2.0.3" />
    <!-- Asset Pipeline -->
    <PackageReference Include="AssimpNet" Version="4.1.0" />
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.11" />
  </ItemGroup>

  <!-- Test dependencies -->
  <ItemGroup>
    <PackageReference Include="xunit" Version="2.7.0" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.5.4">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.9.0" />
    <PackageReference Include="FluentAssertions" Version="6.12.0" />
  </ItemGroup>

  <!-- SDK reference -->
  <ItemGroup>
    <ProjectReference Include="../../SDK/DINOForge.SDK.csproj" />
  </ItemGroup>

</Project>
