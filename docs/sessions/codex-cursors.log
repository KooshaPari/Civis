+                Texture2D tex = new Texture2D(2, 2, TextureFormat.ARGB32, mipChain: false)
+                {
+                    filterMode = FilterMode.Point,
+                    wrapMode = TextureWrapMode.Clamp
+                };
+
+                if (!tex.LoadImage(bytes))
+                {
+                    return null;
