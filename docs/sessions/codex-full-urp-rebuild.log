        ("sw-cis-hangar-bay",         "CIS",      CisDark,       CisGrey,       PrimitiveType.Cube),
        ("sw-cis-ion-cannon",         "CIS",      CisGrey,       CisDark,       PrimitiveType.Cylinder),
