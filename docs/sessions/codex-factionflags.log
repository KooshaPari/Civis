    Deploy badge PNG placeholders to BepInEx/plugins/dinoforge-ui-assets/badges/.
    BadgeRenderer.LoadBadgeSprite() looks for badges/{name}.png under the same asset root
    as Kenney sprites.  Placeholder PNGs live at assets/badges/ in the repo root and are
    generated once by scripts/generate-badge-placeholders.ps1.
  -->
  <Target Name="DeployBadgeAssets" AfterTargets="Build"
          Condition="'$(GameInstalled)' == 'true' and '$(DeployToGame)' == 'true' and '$(TargetFramework)' == 'netstandard2.0'">
    <ItemGroup>
      <BadgePngFiles Include="$(MSBuildThisFileDirectory)..\..\..\assets\badges\*.png" />
    </ItemGroup>
    <MakeDir Directories="$(BepInExDir)\plugins\dinoforge-ui-assets\badges"
             Condition="'@(BadgePngFiles)' != '' And !Exists('$(BepInExDir)\plugins\dinoforge-ui-assets\badges')" />
    <Copy SourceFiles="@(BadgePngFiles)"
          DestinationFolder="$(BepInExDir)\plugins\dinoforge-ui-assets\badges"
          SkipUnchangedFiles="true"
          Condition="'@(BadgePngFiles)' != ''" />
    <Message Text="[DeployBadgeAssets] Deployed $(BadgePngFiles->Count()) badge PNGs to $(BepInExDir)\plugins\dinoforge-ui-assets\badges"
             Importance="normal"
             Condition="'@(BadgePngFiles)' != ''" />
    <Message Text="[DeployBadgeAssets] No badge PNGs found at assets/badges/ — run scripts/generate-badge-placeholders.ps1 first."
             Importance="normal"
             Condition="'@(BadgePngFiles)' == ''" />
  </Target>

  <!--
    [#steam-relaunch] Provision steam_appid.txt beside the game exe on every deploy.

    Without a steam_appid.txt containing the AppID (1272320) next to the exe, DINO
    re-launches itself through Steam on startup and that Steam relaunch KILLS the
    BepInEx-injected process — so no MODS button / F9 / F10 (live-verified iter-149).
    Steam "Verify Integrity of Game Files" can delete this file, so DeployToGame
    re-creates it idempotently on every deploy.

    The file MUST be UTF-8 with NO BOM and NO trailing newline (exactly 7 bytes).
    WriteLinesToFile would append a CRLF, so we use PowerShell's File.WriteAllText
    (no-BOM UTF8 encoding) which writes the literal bytes with no terminator.
  -->
  <Target Name="DeploySteamAppId" AfterTargets="Build"
          Condition="'$(GameInstalled)' == 'true' and '$(DeployToGame)' == 'true' and '$(TargetFramework)' == 'netstandard2.0'">
    <Exec Command="powershell -NoProfile -NonInteractive -Command &quot;[System.IO.File]::WriteAllText('$(GameInstallPath)\steam_appid.txt', '1272320', (New-Object System.Text.UTF8Encoding $false))&quot;" />
    <Message Text="[DeploySteamAppId] Wrote steam_appid.txt (1272320) to $(GameInstallPath) — prevents DINO Steam self-relaunch from dropping BepInEx." Importance="high" />
  </Target>

  <!-- Deploy packs from repo to game directory -->
  <Target Name="DeployPacks" AfterTargets="Build" Condition="'$(DeployToGame)' == 'true' and Exists('$(BepInExDir)') and '$(TargetFramework)' == 'netstandard2.0'">
    <ItemGroup>
      <PackFiles Include="$(MSBuildThisFileDirectory)..\..\packs\**\*"
                  Exclude="$(MSBuildThisFileDirectory)..\..\packs\test-*;
                           $(MSBuildThisFileDirectory)..\..\packs\test-*\**\*;
                           $(MSBuildThisFileDirectory)..\..\packs\**\*.disabled\**\*;
                           $(MSBuildThisFileDirectory)..\..\packs\**\*.disabled" />
    </ItemGroup>
    <MakeDir Directories="$(BepInExDir)\dinoforge_packs" Condition="!Exists('$(BepInExDir)\dinoforge_packs')" />
    <Copy SourceFiles="@(PackFiles)"
          DestinationFolder="$(BepInExDir)\dinoforge_packs\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
    <Message Text="Deployed packs to $(BepInExDir)\dinoforge_packs" Importance="high" />
  </Target>

  <!--
    [Pattern #530] Guardrail: warn when DeployToGame=true is used without an explicit
    TargetFramework=netstandard2.0. The Deploy* targets above are conditioned on the
    netstandard2.0 TFM (the only BepInEx-loadable output per Pattern #233 / iter-97).
    Without this guardrail, a default `dotnet build -p:DeployToGame=true` invocation
    silently builds net8.0 only and skips all deploy targets, masking deploy failures.

    The warning fires only on the non-netstandard2.0 leaf so it surfaces exactly once
    per multi-target build invocation (and not at all when -p:TargetFramework is set
    explicitly to netstandard2.0).
  -->
  <Target Name="WarnDeployWrongTFM" AfterTargets="Build" Condition="'$(DeployToGame)' == 'true' and '$(TargetFramework)' != 'netstandard2.0' and '$(TargetFramework)' != ''">
    <Warning Text="[#530] DeployToGame=true was set but TargetFramework is '$(TargetFramework)', not netstandard2.0. Deploy* targets (DeployUiAssets, DeployPacks, plugin DLL copy) will NOT fire for this TFM. Add -p:TargetFramework=netstandard2.0 to your build command to deploy to the BepInEx-compatible output." Code="DF0530" />
  </Target>

</Project>

