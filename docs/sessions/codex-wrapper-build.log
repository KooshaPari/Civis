+fn load_requests(path: &str, default_model: &str) -> Vec<QueueRequest> {
+    let mut requests = parse_queue(path);
+    for req in requests.iter_mut() {
+        if req.model.is_none() {
+            req.model = Some(default_model.to_string());
+        }
+        if req.cwd.is_none() {
