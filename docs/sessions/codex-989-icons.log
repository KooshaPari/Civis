1574:                    if (persistentCalls != null)
1575:                    {
1576:                        System.Reflection.MethodInfo? clearMethod = persistentCalls.GetType()
1577:                            .GetMethod("Clear",
1578:                                System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance);
1579:                        clearMethod?.Invoke(persistentCalls, null);
1580:                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Cleared {persistentBefore} persistent onClick callbacks via reflection");
