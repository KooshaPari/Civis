1510:        {
1511:            try
1512:            {
1513:                // Strategy 1: walk up from the injected button to find the layout group parent
1514:                if (_injectedButton != null)
1515:                {
1516:                    Transform? current = _injectedButton.transform.parent;
1517:                    while (current != null && current != canvas.transform)
1518:                    {
1519:                        // The content container is typically the child of the canvas root
1520:                        // that holds the button layout group
1521:                        if (current.parent == canvas.transform || current.parent?.parent == canvas.transform)
1522:                        {
1523:                            LogInfo($"[NativeMenuInjector] FindMainMenuContent: found via button ancestor '{current.name}'");
1524:                            return current.gameObject;
1525:                        }
1526:                        current = current.parent;
1527:                    }
1528:                }
1529:
1530:                // Strategy 2: first active child of canvas with multiple children
1531:                for (int i = 0; i < canvas.transform.childCount; i++)
1532:                {
1533:                    Transform child = canvas.transform.GetChild(i);
1534:                    if (child.gameObject.activeSelf && child.childCount > 0
1535:                        && child.name.IndexOf("DINOForge", StringComparison.OrdinalIgnoreCase) < 0)
