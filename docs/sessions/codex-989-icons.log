510	        /// <summary>
511	        /// Refreshes the visual focus indicator on the pack list rows.
512	        /// Applies a colored border highlight to the focused row.
513	        /// </summary>
514	        private void RefreshPackListFocusIndicator()
515	        {
516	            if (_listContent == null)
517	                return;
518	
519	            // Clear all focus borders
520	            for (int i = 0; i < _listContent.childCount; i++)
521	            {
522	                Transform child = _listContent.GetChild(i);
523	                Outline outline = child.GetComponent<Outline>();
524	                if (outline != null)
525	                    Destroy(outline);
526	            }
527	
528	            // Apply focus border to the focused row
529	            if (_keyboardFocusedRowIndex >= 0 && _keyboardFocusedRowIndex < _listContent.childCount)
530	            {
531	                Transform focusedRow = _listContent.GetChild(_keyboardFocusedRowIndex);
532	                Outline outline = focusedRow.gameObject.AddComponent<Outline>();
533	                outline.effectColor = UiBuilder.Accent;
534	                outline.effectDistance = new Vector2(2f, 2f);
535	            }
536	        }
