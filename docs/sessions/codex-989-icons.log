2008	
2009	            if (galleryScroll == null) return;
2010	            Transform galleryContent = galleryScroll.Find("Content");
2011	            if (galleryContent == null) return;
2012	
2013	            // Spawn placeholder cards and kick off the texture load coroutine
2014	            for (int i = 0; i < p.ScreenshotPaths.Count; i++)
2015	            {
