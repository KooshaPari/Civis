{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://civlab.dev/schemas/mod-manifest/v1",
  "title": "CivLab Mod Manifest",
  "description": "JSON Schema for CivLab mod manifests (CIV-0700 §4). On disk manifests use TOML with the same field layout; filename is manifest.toml (MVP) or mod.toml (full bundles).",
  "type": "object",
  "required": ["mod", "dependencies"],
  "additionalProperties": false,
  "properties": {
    "mod": {
      "type": "object",
      "description": "Core mod metadata ([mod] table in TOML).",
      "required": [
        "id",
        "name",
        "version",
        "api_version",
        "mod_type",
        "author",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{0,63}$",
          "description": "Unique mod identifier (reverse-domain style recommended)."
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "description": "Semver mod version."
        },
        "api_version": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "CivLab API major version (integer as string in TOML)."
        },
        "mod_type": {
          "type": "string",
          "enum": ["policy", "economic", "event", "scenario"]
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "maxLength": 256
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier."
        }
      }
    },
    "dependencies": {
      "type": "object",
      "required": ["civlab-api"],
      "additionalProperties": true,
      "properties": {
        "civlab-api": {
          "type": "string",
          "description": "Semver range for the CivLab host API (e.g. \">=1.0.0, <2.0.0\")."
        },
        "mods": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "description": "Optional peer mod dependencies (mod id -> semver range)."
        }
      }
    },
    "permissions": {
      "type": "object",
      "description": "Declared read/write capabilities ([permissions] table).",
      "additionalProperties": false,
      "properties": {
        "read_economy": { "type": "boolean" },
        "read_climate": { "type": "boolean" },
        "read_military": { "type": "boolean" },
        "read_diplomacy": { "type": "boolean" },
        "read_citizens": { "type": "boolean" },
        "write_policy": { "type": "boolean" },
        "write_economy": { "type": "boolean" },
        "write_events": { "type": "boolean" },
        "write_scenario": { "type": "boolean" },
        "transfer_funds": { "type": "boolean" }
      }
    },
    "runtime": {
      "type": "object",
      "description": "Optional runtime limit overrides ([runtime] table).",
      "additionalProperties": false,
      "properties": {
        "memory_mb": {
          "type": "integer",
          "minimum": 1,
          "maximum": 64
        },
        "cpu_us": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "description": "Per-callback CPU budget in microseconds."
        }
      }
    }
  }
}
