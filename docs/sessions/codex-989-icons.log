384	        /// <summary>
385	        /// Handles keyboard input for the mod menu panel.
386	        ///
387	        /// Keymap:
388	        ///   - Arrow Up/Down: Navigate pack list (keyboard focus only)
389	        ///   - Enter/Space: Toggle enable/disable on the focused pack
390	        ///   - Tab: Cycle focus between sections (search → pack list)
391	        ///   - Esc: Close the menu
392	        ///   - '/': Focus the search input field
393	        ///   - Ctrl+R: Reload packs
394	        ///   - Ctrl+S: Reserved for future profile save feature
395	        ///
396	        /// Guards: Only processes input when the panel is visible.
397	        /// </summary>
398	        private void KeyboardUpdate()
399	        {
400	            if (!IsVisible)
401	                return;
402	
403	            // Esc always closes, even if input is focused
404	            if (Input.GetKeyDown(KeyCode.Escape))
405	            {
406	                ClearCurrentSelection();
407	                Hide();
408	                return;
409	            }
410	
411	            // Check if an InputField currently has focus (e.g., search box)
412	            bool inputFieldFocused = EventSystem.current?.currentSelectedGameObject?.GetComponent<InputField>() != null;
413	
414	            // Arrow keys + Enter/Space only work when no input field is focused
415	            if (!inputFieldFocused)
416	            {
417	                // Arrow Up: Move focus up in the pack list
418	                if (Input.GetKeyDown(KeyCode.UpArrow))
419	                {
420	                    if (_filteredIndices.Count > 0)
421	                    {
422	                        if (_keyboardFocusedRowIndex <= 0)
423	                            _keyboardFocusedRowIndex = _filteredIndices.Count - 1;
424	                        else
425	                            _keyboardFocusedRowIndex--;
426	                        RefreshPackListFocusIndicator();
427	                    }
428	                    return;
429	                }
430	
431	                // Arrow Down: Move focus down in the pack list
432	                if (Input.GetKeyDown(KeyCode.DownArrow))
433	                {
434	                    if (_filteredIndices.Count > 0)
435	                    {
436	                        _keyboardFocusedRowIndex++;
437	                        if (_keyboardFocusedRowIndex >= _filteredIndices.Count)
438	                            _keyboardFocusedRowIndex = 0;
439	                        RefreshPackListFocusIndicator();
440	                    }
441	                    return;
442	                }
443	
444	                // Enter/Space: Toggle the focused pack
445	                if (Input.GetKeyDown(KeyCode.Return) || Input.GetKeyDown(KeyCode.Space))
446	                {
447	                    if (_keyboardFocusedRowIndex >= 0 && _keyboardFocusedRowIndex < _filteredIndices.Count)
448	                    {
449	                        int realIndex = _filteredIndices[_keyboardFocusedRowIndex];
450	                        SelectPack(realIndex);
451	                        OnToggleSelected();
452	                    }
453	                    return;
454	                }
455	            }
456	
457	            // Tab: Cycle focus between UI sections (works even with input focused)
458	            if (Input.GetKeyDown(KeyCode.Tab))
459	            {
460	                if (inputFieldFocused)
461	                {
462	                    // If search input is focused, move to pack list
463	                    _keyboardFocusedRowIndex = 0;
464	                    RefreshPackListFocusIndicator();
465	                }
466	                else if (_keyboardFocusedRowIndex >= 0)
467	                {
468	                    // If pack list is focused, move back to search input
469	                    if (_searchInput != null)
470	                    {
471	                        EventSystem.current?.SetSelectedGameObject(_searchInput.gameObject);
472	                        _keyboardFocusedRowIndex = -1;
473	                        RefreshPackListFocusIndicator();
474	                    }
475	                }
476	                return;
477	            }
478	
479	            // '/': Focus the search input (vim-style command prefix)
480	            if (Input.GetKeyDown(KeyCode.Slash))
481	            {
482	                if (_searchInput != null)
483	                {
484	                    EventSystem.current?.SetSelectedGameObject(_searchInput.gameObject);
485	                    _keyboardFocusedRowIndex = -1;
486	                    RefreshPackListFocusIndicator();
487	                }
488	                return;
489	            }
490	
491	            // Ctrl+R: Reload packs
492	            if (Input.GetKey(KeyCode.LeftControl) || Input.GetKey(KeyCode.RightControl))
493	            {
494	                if (Input.GetKeyDown(KeyCode.R))
495	                {
496	                    ClearCurrentSelection();
497	                    OnReloadRequested?.Invoke();
498	                    return;
499	                }
500	
501	                // Ctrl+S: Reserved for profile save (placeholder)
502	                if (Input.GetKeyDown(KeyCode.S))
503	                {
504	                    // Future: implement profile save
505	                    return;
506	                }
507	            }
508	        }
