id: warfare-starwars
name: "Star Wars: The Clone Wars"
version: 0.1.0
type: total_conversion
author: DINOForge Agents
theme: star-wars
description: "Replaces all factions with Star Wars Clone Wars equivalents. Republic vs CIS vs Separatist forces."
framework_version: ">=0.5.0 <1.0.0"
singleton: true

replaces_vanilla:
  player: galactic-republic
  enemy_classic: confederacy-of-independent-systems
  enemy_guerrilla: separatist-extremists

factions:
  - id: galactic-republic
    replaces: player
    name: "Galactic Republic"
    theme: star-wars-republic
    archetype: order
    units:
      - rep_clone_militia
      - rep_clone_trooper
      - rep_clone_heavy
      - rep_arc_trooper
      - rep_atte_crew
      - rep_barc_speeder
      - rep_v19_torrent
    buildings:
      - rep_command_center
      - rep_clone_facility
      - rep_weapons_factory
      - rep_vehicle_bay
      - rep_guard_tower
      - rep_shield_generator
      - rep_skyshield_generator

  - id: confederacy-of-independent-systems
    replaces: enemy_classic
    name: "Confederacy of Independent Systems"
    theme: star-wars-cis
    archetype: industrial_swarm
    units:
      - cis_b1_droid
      - cis_b2_droid
      - cis_droideka
      - cis_commando_droid
      - cis_hailfire_droid
      - cis_tri_fighter
    buildings:
      - cis_droid_factory
      - cis_command_hub
      - cis_tactical_center
      - cis_vulture_nest
      - cis_shield_projector

  - id: separatist-extremists
    replaces: enemy_guerrilla
    name: "Separatist Extremists"
    theme: star-wars-cis-guerrilla
    archetype: asymmetric
    units:
      - cis_commando_droid
      - cis_magnaguard
    buildings:
      - cis_droid_factory

asset_replacements:
  textures:
    "textures/ui/faction_icon_player": "assets/textures/republic_icon.png"
    "textures/ui/faction_icon_enemy": "assets/textures/cis_icon.png"
  audio:
    "audio/music/battle_theme": "assets/audio/clone_wars_theme.ogg"

conflicts_with:
  - warfare-modern
  - warfare-guerrilla

codex
