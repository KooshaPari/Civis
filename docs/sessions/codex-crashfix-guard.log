 1280:                 }
 1281:                 else
 1282:                 {
 1283:                     MeshFilter? mf = prefab.GetComponentInChildren<MeshFilter>(true);
 1284:                     if (mf != null && mf.sharedMesh != null)
 1285:                         mesh = mf.sharedMesh;
 1286: 
 1287:                     MeshRenderer? mr = prefab.GetComponentInChildren<MeshRenderer>(true);
 1288:                     if (mr != null && mr.sharedMaterials != null && mr.sharedMaterials.Length > 0)
 1289:                         material = mr.sharedMaterials[0];
 1290:                 }
 1291: 
 1292:                 if (mesh != null || material != null)
 1293:                 {
 1294:                     DebugLog.Write("AssetSwap",
 1295:                         $"ResolveReplacementAssets: extracted mesh='{mesh?.name ?? "<null>"}' " +
 1296:                         $"material='{material?.name ?? "<null>"}' from prefab '{prefab.name}'");
 1297:                     return (mesh, material);
 1298:                 }
 1299:             }
 1300: 
 1301:             // 3. Fall back to the first bare Mesh / Material asset in the bundle.
 1302:             Mesh[] meshes = bundle.LoadAllAssets<Mesh>();
 1303:             if (meshes.Length > 0) mesh = meshes[0];
 1304: 
 1305:             Material[] materials = bundle.LoadAllAssets<Material>();
 1306:             if (materials.Length > 0) material = materials[0];
