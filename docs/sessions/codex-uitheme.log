                    _nativeMenuInjector.PackDataProvider = () =>
                        _modPlatform?.GetLoadedPackDisplayInfos()
                        ?? (System.Collections.Generic.IReadOnlyList<PackDisplayInfo>)System.Array.Empty<PackDisplayInfo>();
