  <!--
    [Pattern #530 / #885] Explicit DLL deploy target.
    Copies DINOForge.Runtime.dll from the standard netstandard2.0 bin output
    (bin/Release/netstandard2.0/) to BepInEx/plugins/ so that:
      (a) bin/Release/netstandard2.0/DINOForge.Runtime.dll always exists for verification
      (b) BepInEx/plugins/DINOForge.Runtime.dll is an exact copy of the built artifact
    This replaces the earlier OutputPath-redirect approach which emptied bin/ and broke:
      $bHash = (Get-FileHash 'bin\Release\netstandard2.0\DINOForge.Runtime.dll').Hash
      Write-Host "Match: $($dHash -eq $bHash)"
  -->
  <Target Name="DeployDll" AfterTargets="Build"
          Condition="'$(GameInstalled)' == 'true' and '$(DeployToGame)' == 'true' and '$(TargetFramework)' == 'netstandard2.0'">
    <!-- Always deploy the Runtime DLL itself -->
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll"
          DestinationFolder="$(BepInExDir)\plugins"
          SkipUnchangedFiles="false"
          OverwriteReadOnlyFiles="true" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).pdb"
          DestinationFolder="$(BepInExDir)\plugins"
          SkipUnchangedFiles="false"
          OverwriteReadOnlyFiles="true"
          Condition="Exists('$(OutputPath)$(AssemblyName).pdb')" />
    <!--
      [#942] Deploy all first-party DINOForge.*.dll companions (SDK, Bridge.Protocol, Domains, etc.)
      so a stale deployed DLL can never cause TypeLoadException when SDK/Protocol types change.
      Only DINOForge.*.dll are copied — Unity, BepInEx, and third-party DLLs are intentionally
      excluded (the game provides those at runtime).
    -->
    <ItemGroup>
      <DinoForgeDeployDlls Include="$(OutputPath)DINOForge.*.dll"
                            Exclude="$(OutputPath)$(AssemblyName).dll" />
    </ItemGroup>
    <Copy SourceFiles="@(DinoForgeDeployDlls)"
          DestinationFolder="$(BepInExDir)\plugins"
          SkipUnchangedFiles="false"
          OverwriteReadOnlyFiles="true" />
    <Message Text="[DeployDll] Deployed $(AssemblyName).dll to $(BepInExDir)\plugins" Importance="high" />
    <Message Text="[DeployDll] Also deployed companion DLLs: @(DinoForgeDeployDlls->'%(Filename)%(Extension)', ', ')" Importance="high" Condition="'@(DinoForgeDeployDlls)' != ''" />
  </Target>

  <!--
