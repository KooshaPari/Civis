1101	        // ------------------------------------------------------------------ //
1102	        // Cluster 6b: Raycast diagnostics + EventSystem navigation isolation
1103	        // ------------------------------------------------------------------ //
1104	
1105	        /// <summary>
1106	        /// Run raycast diagnostics on Mods button + parent CanvasGroups + parent Canvas
1107	        /// GraphicRaycaster, then isolate the button's Navigation (Mode.None) so it doesn't
1108	        /// couple into native submit/nav flows. STEP 7 is exception-isolated per fixture 6.
1109	        /// </summary>
1110	        private void ValidateRaycastAndEventSystem(Button modsButton, Button settingsButton, long attemptId)
1111	        {
1112	            // ===== STEP 5: RAYCAST DIAGNOSTICS =====
1113	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 5: Raycast diagnostics...");
1114	
1115	            // Check button's own raycast target
1116	            Image? btnImage = modsButton.targetGraphic as Image;
1117	            if (btnImage != null)
1118	            {
1119	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     - targetGraphic raycastTarget: {btnImage.raycastTarget}");
1120	                if (!btnImage.raycastTarget)
1121	                {
1122	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ raycastTarget is FALSE - ENABLING");
1123	                    btnImage.raycastTarget = true;
1124	                }
1125	            }
1126	            else
1127	            {
1128	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ targetGraphic is not an Image or is null");
1129	            }
1130	
1131	            // Check all parent CanvasGroups
1132	            CanvasGroup[] parentCGs = modsButton.GetComponentsInParent<CanvasGroup>();
1133	            if (parentCGs.Length > 0)
1134	            {
1135	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Found {parentCGs.Length} parent CanvasGroup(s):");
1136	                foreach (var parentCg in parentCGs)
1137	                {
1138	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}       - CanvasGroup '{parentCg.gameObject.name}': blocksRaycasts={parentCg.blocksRaycasts}, interactable={parentCg.interactable}");
1139	                    if (!parentCg.blocksRaycasts)
1140	                    {
1141	                        LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}       ⚠ CanvasGroup '{parentCg.gameObject.name}' has blocksRaycasts=FALSE - may block raycasts");
1142	                    }
1143	                }
1144	            }
1145	            else
1146	            {
1147	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     No parent CanvasGroups found");
1148	            }
1149	
1150	            // Check sorting order
1151	            Canvas? canvas = modsButton.GetComponentInParent<Canvas>();
1152	            if (canvas != null)
1153	            {
1154	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     Canvas '{canvas.name}': sortingOrder={canvas.sortingOrder}, renderMode={canvas.renderMode}");
1155	            }
1156	            else
1157	            {
1158	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ No parent Canvas found");
1159	            }
1160	
1161	            // Check for GraphicRaycaster on parent canvas
1162	            if (canvas != null)
1163	            {
1164	                GraphicRaycaster? raycaster = canvas.GetComponent<GraphicRaycaster>();
1165	                if (raycaster != null)
1166	                {
1167	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     GraphicRaycaster on canvas: enabled={raycaster.enabled}");
1168	                    if (!raycaster.enabled)
1169	                    {
1170	                        LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ GraphicRaycaster is disabled - ENABLING");
1171	                        raycaster.enabled = true;
1172	                    }
1173	                }
1174	                else
1175	                {
1176	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ No GraphicRaycaster on canvas - raycasts may not work");
1177	                }
1178	            }
1179	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 5 OK: Raycast diagnostics complete");
1180	            // ===== END RAYCAST DIAGNOSTICS =====
1181	
1182	            // STEP 7: Fix EventSystem navigation conflict
1183	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 7: Configuring EventSystem selection...");
1184	            try
1185	            {
1186	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     [7.1] Getting EventSystem.current...");
1187	                // Pattern #235: Call EnsureEventSystemAlive eagerly (idempotent) BEFORE
1188	                // reading EventSystem.current — handles Unity fake-null case (stale
1189	                // current after scene transition destroys vanilla EventSystem).
1190	                Plugin.EnsureEventSystemAlive();
1191	                EventSystem es = EventSystem.current;
1192	                if (es == null)
1193	                {
1194	                    // #551 race break: Plugin.OnActiveSceneChanged may not have fired yet for the
1195	                    // current scene (per-frame poll runs ahead of the scene event on first MainMenu).
1196	                    // Re-read after the eager EnsureEventSystemAlive() above.
1197	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ EventSystem.current NULL — re-reading after eager ensure.");
1198	                    es = EventSystem.current;
1199	                }
1200	                if (es != null)
1201	                {
1202	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     [7.2] EventSystem found, getting current selection...");
1203	                    GameObject? currentSelected = es.currentSelectedGameObject;
1204	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     [7.3] Current selection = {currentSelected?.name ?? "NULL"}");
1205	
1206	                    // Do not force-select the injected button. Taking focus here can couple it
1207	                    // into native submit/navigation flows and trigger non-DINO handlers.
1208	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     [7.4] Leaving EventSystem selection unchanged for native-menu safety.");
1209	
1210	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     [7.7] Setting navigation mode to None...");
1211	                    Navigation modsNav = modsButton.navigation;
1212	                    modsNav.mode = Navigation.Mode.None;
1213	                    modsButton.navigation = modsNav;
1214	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     [7.8] Mods button navigation mode: {modsNav.mode} (ISOLATED)");
1215	
1216	                    Navigation settingsNav = settingsButton.navigation;
1217	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     [7.9] Settings button navigation mode: {settingsNav.mode}");
1218	                }
1219	                else
1220	                {
1221	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ EventSystem.current is NULL!");
1222	                }
1223	            }
1224	            catch (Exception exEs)
1225	            {
1226	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ EventSystem fix exception TYPE: {exEs.GetType().Name}");
1227	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ Message: '{exEs.Message}'");
1228	                LogWarning($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}     ⚠ StackTrace: {exEs.StackTrace}");
1229	            }
1230	            LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 7 OK: EventSystem configuration complete");
1231	        }
