{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-mcp.ps1 -Action start -Detached"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-mcp.ps1 -Action start -Detached"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/hooks/block-git-stash.ps1"
          },
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/hooks/guard-git-worktree.ps1"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && dotnet format src/DINOForge.sln --include \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
