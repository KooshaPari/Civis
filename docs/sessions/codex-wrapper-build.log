}

fn project_root() -> PathBuf {
    let exe = std::env::current_exe().unwrap_or_else(|_| PathBuf::from("."));
    exe.parent()
        .unwrap_or_else(|| Path::new("."))
        .to_path_buf()
}

fn jobs_dir() -> PathBuf {
    let dir = project_root().join("jobs");
    if !dir.exists() {
        fs::create_dir_all(&dir).ok();
    }
    dir
}

fn now_ts() -> u64 {
    SystemTime::now()
        .duration_since(UNIX_EPOCH)
        .map(|d| d.as_secs())
        .unwrap_or_default()
}

fn job_file(id: &str) -> PathBuf {
    jobs_dir().join(format!("{}.json", id))
}

fn state_file_read(path: &Path) -> io::Result<Job> {
    let data = fs::read_to_string(path)?;
    let mut job: Job = serde_json::from_str(&data)
        .map_err(|e| io::Error::new(io::ErrorKind::InvalidData, e.to_string()))?;
    Ok(job)
}

fn state_file_write(path: &Path, job: &Job) -> io::Result<()> {
    let data = serde_json::to_string_pretty(job)
        .map_err(|e| io::Error::new(io::ErrorKind::InvalidData, e.to_string()))?;
    fs::write(path, data)
}

fn pick_backend(model: &str) -> Backend {
    if model.starts_with("composer") {
        Backend::Composer
    } else {
        Backend::Codex
    }
}

fn cmd_for_model(model: &str, prompt: &str, cwd: &Path) -> io::Result<std::process::Child> {
    let backend = pick_backend(model);
    let mut child = match backend {
        Backend::Codex => {
            let mut command = Command::new("codex");
            command.arg("-m").arg(model).arg(prompt);
            command.current_dir(cwd);
            command.stdin(Stdio::null());
            command.stdout(Stdio::piped());
            command.stderr(Stdio::piped());
            command.spawn()?
        }
        Backend::Composer => {
            let mut command = Command::new("composer");
            command.arg("--model").arg(model).arg(prompt);
            command.current_dir(cwd);
            command.stdout(Stdio::piped());
            command.stderr(Stdio::piped());
            command.spawn()?
        }
    };
    Ok(child)
}

fn is_capacity_error(text: &str) -> bool {
    text.contains("Selected model is at capacity")
        || text.contains("capacity")
        || text.contains("rate limit")
}

fn is_connection_error(text: &str) -> bool {
    let t = text.to_lowercase();
    t.contains("socket")
        || t.contains("connection")
        || t.contains("connection failed")
        || t.contains("connection refused")
        || t.contains("econnreset")
        || t.contains("reset by peer")
}

fn spawn_reader<R: Read + Send + 'static>(
    stream_name: &'static str,
    mut stream: R,
    tx: Sender<String>,
) {
    let _ = thread::spawn(move || {
        let mut buf = [0u8; 4096];
        loop {
            match stream.read(&mut buf) {
                Ok(0) => break,
                Ok(n) => {
                    let chunk = String::from_utf8_lossy(&buf[..n]).to_string();
                    let _ = tx.send(format!("[{}] {}", stream_name, chunk));
                }
                Err(_) => break,
            }
        }
    });
}

fn run_attempt(model: &str, prompt: &str, cwd: &Path, job: &mut Job, hang_seconds: u64) -> Attempt {
    let output_path = PathBuf::from(&job.output_path);
    let mut file = match fs::OpenOptions::new()
        .create(true)
        .append(true)
        .open(&output_path)
    {
        Ok(f) => f,
        Err(err) => {
            return Attempt {
                success: false,
                exit_code: None,
                error: Some(format!("failed open output file: {err}")),
                capacity_error: false,
                connection_error: false,
                stdin_hang: false,
                output_delta: 0,
            };
        }
    };

    let mut child = match cmd_for_model(model, prompt, cwd) {
        Ok(child) => child,
        Err(err) => {
            return Attempt {
                success: false,
                exit_code: None,
                error: Some(format!("spawn failure: {err}")),
                capacity_error: false,
                connection_error: is_connection_error(&err.to_string()),
                stdin_hang: false,
                output_delta: 0,
            };
        }
    };

    let mut stdout = child.stdout.take().expect("stdout piped");
    let mut stderr = child.stderr.take().expect("stderr piped");
    let (tx, rx): (Sender<String>, Receiver<String>) = mpsc::channel();

    spawn_reader("stdout", stdout.read_to_end(&mut Vec::new()).unwrap_or_else(|_| Vec::new()));
    spawn_reader("stderr", stderr.read_to_end(&mut Vec::new()).unwrap_or_else(|_| Vec::new()));
    let _ = &tx;
    let _ = &rx;

    let mut stdout_offset: u64 = job.last_output_offset;
    let mut now = Instant::now();
    let mut last_output = Instant::now();
    let mut saw_output = false;
    let mut capacity = false;
    let mut conn = false;
    let mut collected = String::new();

    loop {
        let timed_out = now.elapsed() >= Duration::from_secs(hang_seconds);
        match rx.recv_timeout(Duration::from_millis(250)) {
            Ok(chunk) => {
                let _ = file.write_all(chunk.as_bytes());
                let _ = file.flush();
                stdout_offset = stdout_offset.saturating_add(chunk.len() as u64);
                job.last_output_offset = stdout_offset;
                collected.push_str(&chunk);
                last_output = Instant::now();
                saw_output = true;
                if is_capacity_error(&chunk) {
                    capacity = true;
                }
                if is_connection_error(&chunk) {
                    conn = true;
                }
            }
            Err(_) => {
                match child.try_wait() {
                    Ok(Some(status)) => {
                        let exit = status.code();
                        if exit == Some(0) && capacity == false && conn == false {
                            return Attempt {
                                success: true,
                                exit_code: exit,
                                error: None,
                                capacity_error: false,
                                connection_error: false,
                                stdin_hang: false,
                                output_delta: job.last_output_offset.saturating_sub(stdout_offset),
                            };
                        }

                        if timed_out && !saw_output {
                            let _ = child.kill();
                            return Attempt {
                                success: false,
                                exit_code: exit,
                                error: Some("Reading additional input from stdin (hang timeout)".to_string()),
                                capacity_error: false,
                                connection_error: conn,
                                stdin_hang: true,
                                output_delta: job.last_output_offset.saturating_sub(stdout_offset),
                            };
                        }
                        return Attempt {
                            success: false,
                            exit_code: exit,
                            error: Some(
                                format!(
                                    "exit {}: {}",
                                    exit.unwrap_or(-1),
                                    if capacity {
                                        "capacity"
                                    } else if conn {
                                        "connection"
                                    } else {
                                        "exit!=0"
                                    }
                                ),
                            ),
                            capacity_error: capacity,
                            connection_error: conn,
                            stdin_hang: false,
                            output_delta: job.last_output_offset.saturating_sub(stdout_offset),
                        };
                    }
                    Ok(None) => {
                        if timed_out && last_output.elapsed() >= Duration::from_secs(hang_seconds) {
                            let _ = child.kill();
                            return Attempt {
                                success: false,
                                exit_code: None,
                                error: Some("Reading additional input from stdin (hang timeout)".to_string()),
                                capacity_error: false,
                                connection_error: false,
                                stdin_hang: true,
                                output_delta: job.last_output_offset.saturating_sub(stdout_offset),
                            };
                        }
                        now = Instant::now();
                        continue;
                    }
                    Err(err) => {
                        let _ = child.kill();
                        return Attempt {
                            success: false,
                            exit_code: None,
                            error: Some(format!("process monitor failed: {err}")),
                            capacity_error: false,
                            connection_error: is_connection_error(&err.to_string()),
                            stdin_hang: false,
                            output_delta: job.last_output_offset.saturating_sub(stdout_offset),
                        };
                    }
                }
            }
        }
    }
}

fn update_state(path: &Path, mut job: Job) -> io::Result<()> {
    job.updated_at = now_ts();
    state_file_write(path, &job)
}

fn fallback_models() -> Vec<String> {
    vec![
        "codex-spark".to_string(),
        "mini".to_string(),
        "5.5".to_string(),
    ]
}

fn ranking_models() -> Vec<String> {
    vec![
        "composer-2.5".to_string(),
        "codex-spark".to_string(),
        "mini".to_string(),
        "5.5".to_string(),
    ]
}

fn parse_queue(path: &str) -> Vec<QueueRequest> {
    let contents = fs::read_to_string(path).unwrap_or_default();
    if let Ok(list) = serde_json::from_str::<Vec<QueueRequest>>(&contents) {
        return list;
    }
    contents
        .lines()
        .filter(|line| !line.trim().is_empty())
        .map(|line| QueueRequest {
            id: None,
            prompt: line.to_string(),
            model: None,
            cwd: None,
        })
        .collect()
}

fn run_with_ladder(
    mut job: Job,
    requested_model: Option<String>,
    hang_seconds: u64,
    max_attempts: u32,
    cooldown: Option<Arc<Mutex<HashMap<String, CooldownState>>>,
) -> io::Result<Job> {
    let mut attempts_left = max_attempts;
    let initial_models = if requested_model.is_some() {
        vec![requested_model.clone().unwrap()]
    } else {
        fallback_models()
    };

    let mut ladder: Vec<String> = if let Some(m) = requested_model {
        vec![m]
    } else {
        initial_models
    };
    if ladder.is_empty() {
        ladder = fallback_models();
    }

    while attempts_left > 0 {
        let now = Instant::now();
        let mut attempted = false;
        for model in ladder.clone() {
            let is_ready = cooldown
                .as_ref()
                .and_then(|c| c.lock().ok())
                .and_then(|guard| guard.get(&model).cloned())
                .map(|cd| now >= cd.available_after)
                .unwrap_or(true);
            if !is_ready {
                continue;
            }
            attempted = true;
            job.model = model.clone();
            job.cli = if pick_backend(&model) == Backend::Composer {
                "composer".to_string()
            } else {
                "codex".to_string()
            };
            job.state = State::Running;
            let state_path = job_file(&job.id);
            let _ = update_state(&state_path, job.clone());
            let cwd = PathBuf::from(&job.cwd);
            let attempt = run_attempt(&model, &job.prompt, &cwd, &mut job, hang_seconds);
            job.attempts = job.attempts.saturating_add(1);
            attempts_left = attempts_left.saturating_sub(1);

            if let Some(err) = attempt.error.clone() {
                job.last_error = Some(format!(
                    "attempt {} model {}: {}",
                    job.attempts, model, err
                ));
            } else {
                job.last_error = None;
            }

            if pick_backend(&model) == Backend::Composer {
                job.last_error = Some(format!(
                    "{} (composer config-bug marker)",
                    job.last_error.clone().unwrap_or_else(|| "failed".to_string())
                ));
            }

            if attempt.success {
                job.state = State::Success;
                update_state(&job_file(&job.id), &job)?;
                return Ok(job);
            }

            if attempt.capacity_error {
                if let Some(lock) = cooldown.as_ref() {
                    if let Ok(mut map) = lock.lock() {
                        map.insert(
                            model.clone(),
                            CooldownState {
                                available_after: SystemTime::now() + Duration::from_secs(DEFAULT_COOLDOWN_SECONDS),
                            },
                        );
                    }
                }
                job.state = State::Retry;
                continue;
            }
            if attempt.connection_error || attempt.stdin_hang || attempt.exit_code.unwrap_or(-1) != 0 {
                job.state = State::Retry;
                continue;
            }
        }
        if !attempted {
            thread::sleep(Duration::from_secs(1));
        } else {
            break;
        }
    }
    job.state = State::Failed;
    update_state(&job_file(&job.id), &job)?;
    Ok(job)
}

fn execute_dispatch(prompt: String, model: String, cwd: Option<String>, id: Option<String>, max_attempts: Option<u32>, hang_seconds: Option<u64>) -> io::Result<Job> {
    let workdir = cwd.unwrap_or_else(|| ".".to_string());
    let attempts = max_attempts.unwrap_or(DEFAULT_MAX_ATTEMPTS);
    let hang = hang_seconds.unwrap_or(DEFAULT_HANG_SECONDS);

    let id = id.unwrap_or_else(|| Uuid::new_v4().to_string());
    let output_path = project_root().join("jobs").join(format!("{}.log", id));
    let now = now_ts();
    let mut job = Job {
        id: id.clone(),
        model: model.clone(),
        cwd: workdir.clone(),
        prompt: prompt.clone(),
        attempts: 0,
        state: State::Queued,
        last_output_offset: 0,
        cli: if pick_backend(&model) == Backend::Composer { "composer".into() } else { "codex".into() },
        output_path: output_path.display().to_string(),
        last_error: None,
        created_at: now,
        updated_at: now,
    };
    update_state(&job_file(&id), &job)?;
    let mut final_job = run_with_ladder(
        job.clone(),
        Some(model),
        hang,
        attempts,
        None,
    )?;
    final_job.updated_at = now_ts();
    update_state(&job_file(&id), &final_job)?;
    println!("READY id={} state={:?}", final_job.id, final_job.state);
    Ok(final_job)
}

fn command_status(id: &str, tail: usize) -> io::Result<()> {
    let path = job_file(id);
    let job = state_file_read(&path)?;
    println!(
        "id={} model={} state={:?} attempts={} cwd={} last_error={:?}",
        job.id, job.model, job.state, job.attempts, job.cwd, job.last_error
    );
    println!("output_tail:");
    let data = fs::read_to_string(&job.output_path).unwrap_or_else(|_| String::new());
    let lines: Vec<&str> = data.lines().collect();
    let start = lines.len().saturating_sub(tail);
    for line in &lines[start..] {
        println!("{}", line);
    }
    Ok(())
}

fn load_requests(path: &str, default_model: &str) -> Vec<QueueRequest> {
    let mut requests = parse_queue(path);
    for req in requests.iter_mut() {
        if req.model.is_none() {
            req.model = Some(default_model.to_string());
        }
        if req.cwd.is_none() {
            req.cwd = Some(".".to_string());
        }
    }
    requests
}

fn run_queue(file: &str, concurrency: usize, default_model: String) -> io::Result<()> {
    let requests = load_requests(file, &default_model);
    let cooldown: Arc<Mutex<HashMap<String, CooldownState>>> = Arc::new(Mutex::new(HashMap::new()));
    let (tx, rx) = mpsc::channel::<QueueRequest>();
    for req in requests {
        tx.send(req).ok();
    }
    drop(tx);

    let mut handles = Vec::new();
    let rc = Arc::new(Mutex::new(rx));
    for worker in 0..concurrency {
        let rxc = rc.clone();
        let cdc = cooldown.clone();
        let handle = thread::spawn(move || loop {
            let next = {
                let guard = rxc.lock();
                match guard {
                    Ok(lock) => lock.recv(),
                    Err(_) => return,
                }
            };
            let req = match next {
                Ok(r) => r,
                Err(_) => return,
            };
            let id = req.id.unwrap_or_else(|| Uuid::new_v4().to_string());
            let model = req.model.unwrap_or_else(|| "composer-2.5".to_string());
            let _ = run_with_ladder(
                Job {
                    id,
                    model: model.clone(),
                    cwd: req.cwd.unwrap_or_else(|| ".".to_string()),
                    prompt: req.prompt,
                    attempts: 0,
                    state: State::Queued,
                    last_output_offset: 0,
                    cli: if pick_backend(&model) == Backend::Composer {
                        "composer".into()
                    } else {
                        "codex".into()
                    },
                    output_path: project_root()
                        .join("jobs")
                        .join(format!("{}.log", id))
                        .display()
                        .to_string(),
                    last_error: None,
                    created_at: now_ts(),
                    updated_at: now_ts(),
                },
                Some(model),
                DEFAULT_HANG_SECONDS,
                DEFAULT_MAX_ATTEMPTS,
                Some(cdc.clone()),
            );
            println!("queue-worker-{} completed {}", worker, id);
        });
        handles.push(handle);
    }

    for handle in handles {
        let _ = handle.join();
    }
    Ok(())
}

fn run_resume(id: String) -> io::Result<()> {
    let path = job_file(&id);
    let mut job = state_file_read(&path)?;
    let maybe_model = Some(job.model.clone());
    let final_job = run_with_ladder(
        job,
        maybe_model,
        DEFAULT_HANG_SECONDS,
        DEFAULT_MAX_ATTEMPTS.saturating_sub(1),
        None,
    )?;
    println!("READY id={} state={:?}", final_job.id, final_job.state);
    Ok(())
}

fn queue_from_model_ranking() -> Vec<String> {
    ranking_models()
}

fn main() {
    let cli = Cli::parse();
    match cli.command {
        Commands::Dispatch {
            prompt,
            model,
            cwd,
            id,
            max_attempts,
            hang_seconds,
        } => {
            if let Err(err) = execute_dispatch(prompt, model, cwd, id, max_attempts, hang_seconds) {
                eprintln!("dispatch failed: {err}");
                std::process::exit(1);
            }
        }
        Commands::Resume { id } => {
            if let Err(err) = run_resume(id) {
                eprintln!("resume failed: {err}");
                std::process::exit(1);
            }
        }
        Commands::Status { id, tail } => {
            if let Err(err) = command_status(&id, tail) {
                eprintln!("status failed: {err}");
                std::process::exit(1);
            }
        }
        Commands::Queue {
            jobs_file,
            concurrency,
            default_model,
        } => {
            // queue respects ranking by dispatching each job through the ladder in run_with_ladder
            let ranking = queue_from_model_ranking();
            println!("queue ranking: {:?}", ranking);
            if let Err(err) = run_queue(&jobs_file, concurrency.max(1), default_model) {
                eprintln!("queue failed: {err}");
                std::path::ExitCode;
            }
        }
    }
}


