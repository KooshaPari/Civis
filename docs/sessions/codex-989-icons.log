1864	        /// <summary>Populates the tags chip row for the selected pack.</summary>
1865	        private void RefreshTagsRow(PackDisplayInfo p)
1866	        {
1867	            if (_detailTagsRow == null) return;
1868	            // Clear existing chips
1869	            for (int i = _detailTagsRow.childCount - 1; i >= 0; i--)
1870	            {
1871	                Transform child = _detailTagsRow.GetChild(i);
1872	                child.SetParent(null, false);
1873	                Destroy(child.gameObject);
1874	            }
1875	
1876	            if (p.Tags.Count == 0)
1877	            {
1878	                _detailTagsRow.gameObject.SetActive(false);
1879	                return;
1880	            }
1881	
1882	            _detailTagsRow.gameObject.SetActive(true);
1883	            // Cycle through a small set of muted accent colours for variety
1884	            Color[] chipColors = new Color[]
1885	            {
