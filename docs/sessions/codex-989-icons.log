1096	        private void RebuildPackList()
1097	        {
1098	            if (_listContent == null)
1099	            {
1100	                _log?.LogWarning("[ModMenuPanel.RebuildPackList] _listContent is NULL — UI not initialized yet. " +
1101	                    "Pack list will render once Build() completes. Ensure DFCanvas.Start() runs before SetPacks() is called.");
1102	                return;
1103	            }
1104	
1105	            // Reset keyboard focus when rebuilding the list
1106	            _keyboardFocusedRowIndex = -1;
1107	
1108	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] START: presenter.Packs.Count={_presenter.Packs.Count}, _listContent={_listContent.name}, active={_listContent.gameObject.activeSelf}");
1109	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] _listContent RectTransform: position={_listContent.anchoredPosition}, sizeDelta={_listContent.sizeDelta}");
1110	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] Clearing {_listContent.childCount} existing items");
1111	
1112	            _listContent.SetSizeWithCurrentAnchors(RectTransform.Axis.Horizontal, ListWidth);
1113	            _listContent.sizeDelta = new Vector2(ListWidth, _listContent.sizeDelta.y);
1114	
1115	            // Remove existing items immediately from the layout tree to avoid
1116	            // same-frame duplicate entries when SetPacks triggers rapid rebuilds.
1117	            for (int i = _listContent.childCount - 1; i >= 0; i--)
1118	            {
1119	                Transform child = _listContent.GetChild(i);
1120	                child.SetParent(null, false);
1121	                Destroy(child.gameObject);
1122	            }
1123	
1124	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] After clear: childCount={_listContent.childCount}. Now rendering {_presenter.Packs.Count} pack(s)...");
1125	
1126	            for (int i = 0; i < _presenter.Packs.Count; i++)
1127	            {
1128	                _log?.LogInfo($"[ModMenuPanel.RebuildPackList] Creating item {i}: '{_presenter.Packs[i].Name}' (ID: {_presenter.Packs[i].Id})");
1129	                BuildPackListItem(_presenter.Packs[i], i);
1130	
1131	                Transform item = _listContent.GetChild(i);
1132	                RectTransform rt = item.GetComponent<RectTransform>();
1133	                _log?.LogInfo($"[ModMenuPanel.probe] item[{i}] name={item.name} childCount={item.transform.childCount} rect=({rt.sizeDelta.x}x{rt.sizeDelta.y}) active={item.gameObject.activeSelf}");
1134	                for (int childIndex = 0; childIndex < item.transform.childCount; childIndex++)
1135	                {
1136	                    Transform child = item.transform.GetChild(childIndex);
1137	                    Text text = child.GetComponent<Text>();
1138	                    if (text != null)
1139	                    {
1140	                        RectTransform textRt = text.GetComponent<RectTransform>();
1141	                        _log?.LogInfo($"[ModMenuPanel.probe] item[{i}].child[{childIndex}] Text color={text.color} text='{text.text}' active={text.gameObject.activeSelf} rect=({textRt.sizeDelta.x}x{textRt.sizeDelta.y})");
1142	                    }
1143	
1144	                    Image image = child.GetComponent<Image>();
1145	                    if (image != null)
1146	                    {
1147	                        _log?.LogInfo($"[ModMenuPanel.probe] item[{i}].child[{childIndex}] Image color={image.color} spriteNull={image.sprite == null} raycastTarget={image.raycastTarget}");
1148	                    }
1149	                }
1150	            }
1151	
1152	            // CRITICAL FIX: Manually set content height since ContentSizeFitter is not calculating correctly
1153	            // Calculate: padding.top + (itemCount * itemHeight) + (itemCount-1 * spacing) + padding.bottom
1154	            float padding_top = 4f, padding_bottom = 4f, spacing = 2f, itemHeight = 40f;
1155	            float calculatedHeight = padding_top + (_presenter.Packs.Count * itemHeight) + (Mathf.Max(0, _presenter.Packs.Count - 1) * spacing) + padding_bottom;
1156	            _listContent.sizeDelta = new Vector2(_listContent.sizeDelta.x, calculatedHeight);
1157	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] MANUAL FIX APPLIED: Set content height to {calculatedHeight} (was {_listContent.sizeDelta.y})");
1158	
1159	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] COMPLETE: childCount={_listContent.childCount}. Listing items:");
1160	            for (int i = 0; i < _listContent.childCount; i++)
1161	            {
1162	                Transform child = _listContent.GetChild(i);
1163	                RectTransform childRt = child.GetComponent<RectTransform>();
1164	                _log?.LogInfo($"  Item {i}: name={child.name}, active={child.gameObject.activeSelf}, sizeDelta={childRt.sizeDelta}, childCount={child.childCount}");
1165	            }
1166	
1167	            // CRITICAL: Log content size AFTER all items are created and VerticalLayoutGroup has calculated
1168	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] FINAL CONTENT SIZE: sizeDelta={_listContent.sizeDelta}, rect.height={_listContent.rect.height}");
1169	            ContentSizeFitter csf = _listContent.GetComponent<ContentSizeFitter>();
1170	            VerticalLayoutGroup vlg = _listContent.GetComponent<VerticalLayoutGroup>();
1171	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] ContentSizeFitter: {(csf != null ? $"enabled={csf.enabled}, verticalFit={csf.verticalFit}" : "NULL")}");
1172	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] VerticalLayoutGroup: {(vlg != null ? $"enabled={vlg.enabled}, spacing={vlg.spacing}, padding={vlg.padding}, preferredHeight={vlg.preferredHeight}" : "NULL")}");
1173	
1174	            // Calculate expected height manually
1175	            float expectedHeight = 0f;
1176	            if (vlg != null)
1177	            {
1178	                expectedHeight = vlg.padding.top + vlg.padding.bottom;
1179	                for (int i = 0; i < _listContent.childCount; i++)
1180	                {
1181	                    Transform child = _listContent.GetChild(i);
1182	                    LayoutElement childLe = child.GetComponent<LayoutElement>();
1183	                    if (childLe != null && childLe.preferredHeight > 0)
1184	                    {
1185	                        expectedHeight = expectedHeight + childLe.preferredHeight;
1186	                        if (i > 0) expectedHeight = expectedHeight + vlg.spacing;
1187	                    }
1188	                }
1189	            }
1190	            _log?.LogInfo($"[ModMenuPanel.RebuildPackList] MANUAL CALCULATION: expected total height={expectedHeight} (padding.top={vlg?.padding.top}, padding.bottom={vlg?.padding.bottom}, spacing={vlg?.spacing}, items={_listContent.childCount})");
1191	
1192	            // Drive layout immediately so the ScrollRect sees the correct content bounds
1193	            // even when the panel is currently hidden.
1194	            UnityEngine.UI.LayoutRebuilder.ForceRebuildLayoutImmediate(_listContent);
1195	        }
