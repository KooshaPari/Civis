+fn run_queue(file: &str, concurrency: usize, default_model: String) -> io::Result<()> {
+    let requests = load_requests(file, &default_model);
+    let cooldown: Arc<Mutex<HashMap<String, CooldownState>>> = Arc::new(Mutex::new(HashMap::new()));
+    let (tx, rx) = mpsc::channel::<QueueRequest>();
+    for req in requests {
+        tx.send(req).ok();
+    }
+    drop(tx);
+
+    let mut handles = Vec::new();
+    let rc = Arc::new(Mutex::new(rx));
+    for worker in 0..concurrency {
+        let rxc = rc.clone();
+        let cdc = cooldown.clone();
+        let handle = thread::spawn(move || loop {
+            let next = {
+                let guard = rxc.lock();
+                match guard {
+                    Ok(lock) => lock.recv(),
+                    Err(_) => return,
+                }
+            };
+            let req = match next {
+                Ok(r) => r,
+                Err(_) => return,
+            };
+            let id = req.id.unwrap_or_else(|| Uuid::new_v4().to_string());
+            let model = req.model.unwrap_or_else(|| "composer-2.5".to_string());
+            let _ = run_with_ladder(
+                Job {
+                    id,
+                    model: model.clone(),
+                    cwd: req.cwd.unwrap_or_else(|| ".".to_string()),
+                    prompt: req.prompt,
+                    attempts: 0,
+                    state: State::Queued,
+                    last_output_offset: 0,
+                    cli: if pick_backend(&model) == Backend::Composer {
+                        "composer".into()
+                    } else {
+                        "codex".into()
+                    },
+                    output_path: project_root()
+                        .join("jobs")
+                        .join(format!("{}.log", id))
+                        .display()
+                        .to_string(),
+                    last_error: None,
+                    created_at: now_ts(),
+                    updated_at: now_ts(),
+                },
+                Some(model),
+                DEFAULT_HANG_SECONDS,
+                DEFAULT_MAX_ATTEMPTS,
+                Some(cdc.clone()),
+            );
+            println!("queue-worker-{} completed {}", worker, id);
+        });
+        handles.push(handle);
+    }
+
+    for handle in handles {
+        let _ = handle.join();
+    }
+    Ok(())
+}
