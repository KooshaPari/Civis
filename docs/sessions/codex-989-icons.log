877	        // ------------------------------------------------------------------ //
878	        // Cluster 1: Clone source resolution
879	        // ------------------------------------------------------------------ //
880	
881	        /// <summary>
882	        /// Decide which button to clone and whether to position the new Mods button
883	        /// AFTER the clone source (when multiple Options buttons exist) or BEFORE the
884	        /// Settings button (when only one or zero Options buttons exist).
885	        /// Returns (cloneSource, positionAfterSibling). When positionAfterSibling is
886	        /// null, the new Mods button is placed BEFORE settingsButton.
887	        /// </summary>
888	        private (Button cloneSource, Button? positionAfterSibling) ResolveCloneSource(Button settingsButton, long attemptId)
889	        {
890	            // Always clone a new button — NEVER repurposes/replaces the original Options button.
891	            // When 2+ Options buttons exist, clone from the last one so the new Mods button
892	            // appears AFTER all Options buttons. When 1 or 0 exist, clone from settingsButton
893	            // and position BEFORE it (original behavior).
894	            Button cloneSource = settingsButton;
895	            Button? positionAfterSibling = null; // null = position before settingsButton
896	
897	            if (_allOptionsButtons != null && _allOptionsButtons.Count >= 1)
898	            {
899	                // Use the last Options button as clone source; position new Mods button AFTER it.
900	                cloneSource = _allOptionsButtons[_allOptionsButtons.Count - 1];
901	                positionAfterSibling = cloneSource;
902	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 1: Cloning from last 'Options' button '{cloneSource.name}' — Mods will appear AFTER Options");
903	            }
904	            else
905	            {
906	                LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 1: Cloning from Settings button '{cloneSource.name}' to create new 'Mods' button");
907	            }
908	
909	            return (cloneSource, positionAfterSibling);
910	        }
911	
912	        // ------------------------------------------------------------------ //
913	        // Cluster 2: Duplicate-prevention guard
914	        // ------------------------------------------------------------------ //
915	
916	        /// <summary>
917	        /// If a DINOForge_ModsButton already exists in the clone source's parent, re-enforce
918	        /// its state and commit the injection atomically (sets _injectedButton + _injected
919	        /// together) before returning true. Returns false if no existing button found.
920	        /// </summary>
921	        private bool TryReEnforceExistingInjection(Button cloneSource, long attemptId)
922	        {
923	            Transform parent = cloneSource.transform.parent;
924	            if (parent == null)
925	            {
926	                return false;
927	            }
928	
929	            for (int i = 0; i < parent.childCount; i++)
930	            {
931	                if (parent.GetChild(i).name.StartsWith("DINOForge_ModsButton", StringComparison.OrdinalIgnoreCase))
932	                {
933	                    Button existing = parent.GetChild(i).GetComponent<Button>();
934	                    if (existing != null && existing.gameObject.activeInHierarchy)
935	                    {
936	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId}   STEP 1R: Mods button already present; re-enforcing state...");
937	                        EnforceModsButtonState(existing, attemptId);
938	                        _injectedButton = existing;
939	                        _injected = true;
940	                        LogInfo($"[NativeMenuInjector::{_sessionId}] Attempt#{attemptId} ✓ Mods button already present; SKIPPING re-inject, using existing.");
941	                        return true;
942	                    }
943	                }
944	            }
945	
946	            return false;
947	        }
948	
