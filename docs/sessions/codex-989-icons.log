2829	        /// <summary>
2830	        /// Shows a blocking-style confirmation dialog overlay inside the mod menu panel.
2831	        /// Presents <paramref name="message"/> with "Yes" and "No" buttons.
2832	        /// Callbacks are invoked on the Unity main thread (inside the dialog button click handlers).
2833	        /// </summary>
2834	        /// <param name="message">Body text of the confirmation prompt.</param>
2835	        /// <param name="onConfirm">Called when the user presses "Yes".</param>
2836	        /// <param name="onCancel">Called when the user presses "No" or dismisses.</param>
2837	        public void ShowConfirmDialog(string message, Action onConfirm, Action onCancel)
2838	        {
2839	            if (_panelRt == null)
2840	            {
2841	                // Panel not yet built — fall back to executing cancel immediately.
2842	                onCancel?.Invoke();
2843	                return;
2844	            }
2845	
2846	            // Build a dimmed overlay that blocks interaction with the pack list beneath it.
2847	            GameObject overlay = new GameObject("HmrConfirmOverlay", typeof(RectTransform));
