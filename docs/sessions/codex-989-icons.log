1266	        /// <summary>
1267	        /// Handles MODS button click on the native menu (main menu / pause menu).
1268	        /// Opens a full-screen native mods page inside the MainMenu canvas,
1269	        /// hiding the main menu content and showing the pack browser.
1270	        ///
1271	        /// Falls back to the IMGUI overlay toggle (F10-style) if the native page
1272	        /// cannot be shown (e.g. MainMenu canvas not found).
1273	        /// </summary>
1274	        private void OnModsButtonClicked()
1275	        {
1276	            LogInfo($"[NativeMenuInjector.probe] OnModsButtonClicked FIRED at {DateTime.UtcNow:HH:mm:ss.fff}");
1277	            LogInfo($"[NativeMenuInjector::{_sessionId}] NativeMenuInjector.OnModsClick fired");
1278	            _buttonClickCount++;
1279	            long clickId = _buttonClickCount;
1280	
1281	            try
1282	            {
1283	                LogInfo($"[NativeMenuInjector::{_sessionId}] ═══ MODS BUTTON CLICKED #{clickId} at {System.DateTime.UtcNow:HH:mm:ss.fff} UTC ═══");
1284	
1285	                float now = Time.unscaledTime;
1286	                if (now - _lastClickTimeUnscaled < ClickDebounceSeconds)
1287	                {
1288	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} ignored by debounce window ({ClickDebounceSeconds:0.00}s).");
1289	                    return;
1290	                }
1291	                _lastClickTimeUnscaled = now;
1292	
1293	                // If the full browser page is already visible, hide it (toggle behavior).
1294	                if (_nativeModsPage != null && _nativeModsPage.IsVisible)
1295	                {
1296	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} NativeModsPage already visible — hiding.");
1297	                    _nativeModsPage.Hide();
1298	                    return;
1299	                }
1300	
1301	                // If the quick panel is already visible, hide it (toggle behavior).
1302	                if (_quickPanel != null && _quickPanel.IsVisible)
1303	                {
1304	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} QuickPanel already visible — hiding.");
1305	                    _quickPanel.Hide();
1306	                    return;
1307	                }
1308	
1309	                // DEFAULT: show the compact NATIVE-STYLE quick panel. The full-screen
1310	                // browser is secondary, reached via the quick panel's "Browse all" button.
1311	                if (TryShowQuickPanel(clickId))
1312	                {
1313	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} ✓ NativeQuickModPanel shown successfully");
1314	                    return;
1315	                }
1316	
1317	                // Fallback chain: full-screen native page, then IMGUI overlay.
1318	                if (TryShowNativeModsPage(clickId))
1319	                {
1320	                    LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} ✓ NativeModsPage shown (quick panel unavailable)");
1321	                    return;
1322	                }
1323	
1324	                // Fallback: toggle the IMGUI overlay
1325	                LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} NativeModsPage unavailable, falling back to overlay toggle");
1326	                if (_menuHost == null)
1327	                {
1328	                    LogWarning($"[NativeMenuInjector::{_sessionId}] Click#{clickId} ⚠ menu host reference is NULL! Cannot toggle menu.");
1329	                    return;
1330	                }
1331	
1332	                LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId}   menuHost.IsVisible BEFORE toggle: {_menuHost.IsVisible}");
1333	                _menuHost.Toggle();
1334	                LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId}   menuHost.IsVisible AFTER toggle: {_menuHost.IsVisible}");
1335	                LogInfo($"[NativeMenuInjector::{_sessionId}] Click#{clickId} ✓ Mods menu TOGGLED (overlay fallback) successfully");
1336	            }
1337	            catch (Exception ex)
1338	            {
1339	                LogWarning($"[NativeMenuInjector::{_sessionId}] Click#{clickId} ⚠ OnModsButtonClicked exception: {ex}");
1340	            }
1341	        }
