1914	        /// <summary>
1915	        /// Returns true only for absolute http/https URLs.
1916	        /// Prevents javascript:, file:, and other dangerous schemes from reaching
1917	        /// <see cref="Application.OpenURL"/>.
1918	        /// </summary>
1919	        private static bool IsSafeWebUrl(string? url)
1920	        {
1921	            if (string.IsNullOrWhiteSpace(url)) return false;
1922	            if (!Uri.TryCreate(url, UriKind.Absolute, out Uri? uri)) return false;
1923	            return uri.Scheme == Uri.UriSchemeHttp || uri.Scheme == Uri.UriSchemeHttps;
1924	        }
