1409	        /// <summary>Finds the first active canvas whose name contains <paramref name="namePart"/>.</summary>
1410	        private static Canvas? FindActiveCanvasByName(string namePart)
1411	        {
1412	            Canvas[] all = Resources.FindObjectsOfTypeAll<Canvas>();
1413	            foreach (Canvas c in all)
1414	            {
1415	                if (c == null || !c.gameObject.activeInHierarchy) continue;
1416	                if (c.name != null && c.name.IndexOf(namePart, StringComparison.OrdinalIgnoreCase) >= 0)
1417	                    return c;
1418	            }
1419	            return null;
1420	        }
