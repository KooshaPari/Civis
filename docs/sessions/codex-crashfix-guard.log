 1255:         /// mesh/material mismatches.
 1256:         /// </summary>
 1257:         private static (Mesh? mesh, Material? material) ResolveReplacementAssets(AssetBundle bundle, string requestedName)
 1258:         {
 1259:             // 1. Fast path: exact-name bare assets.
 1260:             Mesh? mesh = bundle.LoadAsset<Mesh>(requestedName);
 1261:             Material? material = bundle.LoadAsset<Material>(requestedName);
 1262:             if (mesh != null || material != null)
 1263:             {
 1264:                 DebugLog.Write("AssetSwap", $"ResolveReplacementAssets: resolved bare asset by name '{requestedName}'");
 1265:                 return (mesh, material);
 1266:             }
 1267: 
 1268:             // 2. Prefab path: extract from the first GameObject's renderer.
 1269:             GameObject[] prefabs = bundle.LoadAllAssets<GameObject>();
 1270:             foreach (GameObject prefab in prefabs)
 1271:             {
 1272:                 if (prefab == null) continue;
 1273: 
 1274:                 SkinnedMeshRenderer? smr = prefab.GetComponentInChildren<SkinnedMeshRenderer>(true);
 1275:                 if (smr != null && smr.sharedMesh != null)
 1276:                 {
 1277:                     mesh = smr.sharedMesh;
 1278:                     if (smr.sharedMaterials != null && smr.sharedMaterials.Length > 0)
