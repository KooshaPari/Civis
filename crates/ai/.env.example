# civ-ai (CIVAI_*) configuration — copy to .env (gitignored) and fill in.
# See docs/design/civ-ai-crate.md §7. No secrets are committed here.

# GGUF path for LocalSlmProvider (required if the `local` feature is enabled).
CIVAI_LOCAL_MODEL_PATH=

# Model id for the legends/chatter narrator role.
CIVAI_NARRATOR_MODEL=qwen2.5-1.5b-instruct

# Embedding model id (drift/speciation + log triage).
CIVAI_EMBED_MODEL=all-MiniLM-L6-v2

# Hard cap on in-flight generations (VRAM/latency budget).
CIVAI_MAX_CONCURRENT_GEN=2

# Default max_tokens ceiling.
CIVAI_GEN_TOKEN_BUDGET=600

# Opt-in cloud heavy-reasoning fallback (1 to enable). Off by default.
CIVAI_ENABLE_CLOUD=0

# Dev-only Ollama endpoint (OpenAI-compatible).
CIVAI_OLLAMA_URL=http://localhost:11434

# Cloud creds (already documented in repo-root .env.example).
# KIMI_API_KEY=
# FIREPASS_BASE_URL=https://api.firepass.dev/v1
