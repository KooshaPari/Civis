1567:            {
1568:                System.Reflection.FieldInfo? fi = typeof(UnityEngine.Events.UnityEventBase)
1569:                    .GetField("m_PersistentCalls",
1570:                        System.Reflection.BindingFlags.NonPublic | System.Reflection.BindingFlags.Instance);
1571:                if (fi != null)
1572:                {
