                {
                    try
                    {
                        DebugLog.Write("Plugin", "[RuntimeDriver] F10 pressed → MODS menu (via KeyInputSystem)");
                        if (_uguiReady && _dfCanvas != null) _dfCanvas.ToggleModMenu();
                        else _modMenuHost?.Toggle();
                    }
                    catch (Exception ex)
