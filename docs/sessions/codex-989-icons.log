3123	        /// <summary>Refreshes the profile dropdown options from the ProfileManager.</summary>
3124	        private void RefreshProfileDropdown()
3125	        {
3126	            if (_profileDropdown == null) return;
3127	
3128	            _profileDropdown.options.Clear();
3129	
3130	            IReadOnlyList<string> names = _profileManager?.ListProfiles() ?? new List<string>();
3131	            if (names.Count == 0)
3132	            {
3133	                _profileDropdown.options.Add(new Dropdown.OptionData("(no profiles)"));
3134	            }
3135	            else
3136	            {
3137	                foreach (string name in names)
3138	                    _profileDropdown.options.Add(new Dropdown.OptionData(name));
3139	            }
3140	
3141	            _profileDropdown.value = 0;
3142	            _profileDropdown.RefreshShownValue();
3143	        }
