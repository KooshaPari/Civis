2049	        /// <summary>Coroutine: loads an image file from disk into a Texture2D and assigns it to target.</summary>
2050	        private System.Collections.IEnumerator LoadTextureAsync(string path, Image target, Text loadingLabel)
2051	        {
2052	            yield return null; // yield once so we don't block the frame
2053	
2054	            Texture2D? tex = null;
2055	            try
2056	            {
2057	                byte[] bytes = System.IO.File.ReadAllBytes(path);
2058	                tex = new Texture2D(2, 2, TextureFormat.RGBA32, false);
2059	                if (!tex.LoadImage(bytes))
2060	                {
2061	                    Destroy(tex);
2062	                    tex = null;
2063	                }
2064	            }
2065	            catch (Exception ex)
2066	            {
2067	                // safe-swallow: screenshot load is best-effort UI decoration
2068	                System.Diagnostics.Debug.WriteLine($"ModMenuPanel screenshot load failed: {ex.Message}");
2069	            }
2070	
2071	            if (target == null) yield break; // UI was destroyed while loading
2072	
2073	            if (tex != null)
2074	            {
2075	                target.sprite = Sprite.Create(tex, new Rect(0, 0, tex.width, tex.height),
2076	                    new Vector2(0.5f, 0.5f));
2077	                target.color = Color.white;
2078	                if (loadingLabel != null) Destroy(loadingLabel.gameObject);
2079	            }
2080	            else
2081	            {
2082	                if (loadingLabel != null) loadingLabel.text = "⚠";
2083	            }
2084	        }
