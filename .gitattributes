# Normalize line endings to LF in repository, checkout as-is on all platforms
* text=auto eol=lf

# Explicitly text files
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
packages.lock.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.xml text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.dll binary
*.exe binary
*.zip binary
*.nupkg binary

# LFS preventive patterns (2026-04-27) — history migration is a separate task
*.psd filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.unitypackage filter=lfs diff=lfs merge=lfs -text
packs/*/assets/** filter=lfs diff=lfs merge=lfs -text
