                catch (Exception ex)
                {
                    _log.LogError($"[RuntimeDriver] ModPlatform initialization failed: {ex}");
                    _modPlatform = null;
                }
            });
            yield return null;

            RunPhaseWithAbortGuard("ProfileManager.Initialize", () =>
            {
                try
